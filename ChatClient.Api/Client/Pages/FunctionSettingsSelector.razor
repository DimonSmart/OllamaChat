@using ChatClient.Domain.Models

<FunctionSelector AvailableFunctions="@AvailableFunctions"
                  SelectedFunctions="@FunctionSettings.SelectedFunctions"
                  SelectedFunctionsChanged="OnSelectedFunctionsChanged"
                  Expanded="@Expanded"
                  ExpandedChanged="@ExpandedChanged"
                  AutoSelectCount="@FunctionSettings.AutoSelectCount"
                  AutoSelectCountChanged="OnAutoSelectCountChanged"
                  ShowAutoSelectCount="true"
                  Disabled="false"
                  Title="Select Functions to use:" />

@code {
    [Parameter] public List<FunctionInfo> AvailableFunctions { get; set; } = [];
    [Parameter] public FunctionSettings FunctionSettings { get; set; } = new();
    [Parameter] public EventCallback<FunctionSettings> FunctionSettingsChanged { get; set; }
    [Parameter] public bool Expanded { get; set; }
    [Parameter] public EventCallback<bool> ExpandedChanged { get; set; }

    private async Task OnSelectedFunctionsChanged(List<string> selectedFunctions)
    {
        FunctionSettings.SelectedFunctions = selectedFunctions;
        await FunctionSettingsChanged.InvokeAsync(FunctionSettings);
    }

    private async Task OnAutoSelectCountChanged(int value)
    {
        FunctionSettings.AutoSelectCount = value;
        await FunctionSettingsChanged.InvokeAsync(FunctionSettings);
    }
}
