    }

    private async Task ConfirmLoadWorkflowAsync()
    {
        if (!selectedWorkflowIdToLoad.HasValue)
        {
            return;
        }

        var savedWorkflow = savedWorkflows.FirstOrDefault(workflow => workflow.Id == selectedWorkflowIdToLoad.Value);
        if (savedWorkflow is null)
        {
            Snackbar.Add("Selected workflow was not found.", Severity.Warning);
            return;
        }

        workflowSourceCode = savedWorkflow.SourceCode;
        currentSavedWorkflow = savedWorkflow;
        currentSavedWorkflowId = savedWorkflow.Id;
        workflowSourceDirty = false;
        workflowCompileError = null;
        isWorkflowSourceExpanded = false;
        showLoadWorkflowDialog = false;
        await CompileWorkflowSourceAsync(expandEditorOnError: true);
    }

    private void OpenDeleteWorkflowDialog()
    {
        if (!currentSavedWorkflowId.HasValue)
        {
            return;
        }

        showDeleteWorkflowDialog = true;
    }

    private void CloseDeleteWorkflowDialog()
    {
        showDeleteWorkflowDialog = false;
    }

    private async Task SaveWorkflowAsync()
    {
        if (!await CompileWorkflowSourceAsync(expandEditorOnError: true) || compiledWorkflow is null)
        {
            Snackbar.Add("Workflow compilation failed. Fix the source code before saving.", Severity.Error);
            return;
        }

        SavedWorkflowDefinition savedWorkflow;
        if (currentSavedWorkflowId.HasValue)
        {
            savedWorkflow = await WorkflowDefinitionService.GetByIdAsync(currentSavedWorkflowId.Value) ??
                            new SavedWorkflowDefinition { Id = currentSavedWorkflowId.Value };
        }
        else
        {
            savedWorkflow = new SavedWorkflowDefinition();
        }

        savedWorkflow.Kind = compiledWorkflow.Kind;
        savedWorkflow.WorkflowId = compiledWorkflow.WorkflowId;
        savedWorkflow.DisplayName = compiledWorkflow.DisplayName;
        savedWorkflow.Description = compiledWorkflow.Description;
        savedWorkflow.SourceCode = workflowSourceCode;

        if (currentSavedWorkflowId.HasValue &&
            await WorkflowDefinitionService.GetByIdAsync(currentSavedWorkflowId.Value) is not null)
        {
            await WorkflowDefinitionService.UpdateAsync(savedWorkflow);
        }
        else
        {
            await WorkflowDefinitionService.CreateAsync(savedWorkflow);
        }

        currentSavedWorkflow = savedWorkflow;
        currentSavedWorkflowId = savedWorkflow.Id;
        workflowSourceDirty = false;
        await RefreshSavedWorkflowsAsync();
        Snackbar.Add($"Workflow '{savedWorkflow.DisplayName}' saved.", Severity.Success);
    }

    private async Task DeleteCurrentWorkflowAsync()
    {
        if (!currentSavedWorkflowId.HasValue)
        {
            return;
        }

        await WorkflowDefinitionService.DeleteAsync(currentSavedWorkflowId.Value);
        currentSavedWorkflow = null;
        currentSavedWorkflowId = null;
        workflowSourceDirty = false;
        showDeleteWorkflowDialog = false;
        await RefreshSavedWorkflowsAsync();
        Snackbar.Add("Saved workflow deleted.", Severity.Success);
    }

    private async Task SaveCurrentChat()
    {
        if (!WorkflowSessionService.Messages.Any())
        {
            Snackbar.Add("Nothing to save", Severity.Info);
            return;
        }

        var parameters = new DialogParameters
        {
            ["InitialTitle"] = lastSavedChatId.HasValue ? lastSavedChatTitle : string.Empty
        };
        var dialog = await DialogService.ShowAsync<SaveChatDialog>("Save Chat", parameters);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        var title = result.Data as string ?? string.Empty;
        var participants = WorkflowSessionService.AgentDescriptions
            .Select(agent => new SavedChatParticipant(agent.AgentId, agent.AgentName, ChatRole.Assistant))
            .ToList();
        participants.Add(new SavedChatParticipant(userSettings.UserName.ToLowerInvariant(), userSettings.UserName, ChatRole.User));

        var agentMap = WorkflowSessionService.AgentDescriptions
            .ToDictionary(agent => agent.AgentName, agent => agent.AgentId, StringComparer.OrdinalIgnoreCase);

        var messages = WorkflowSessionService.Messages
            .Where(message => !message.IsStreaming && !message.IsCanceled && message.Role != ChatRole.System)
            .Where(message => !string.IsNullOrWhiteSpace(message.Content) || message.Files.Count > 0)
            .Select(message => new SavedChatMessage(
                message.Id,
                message.Content,
                message.MsgDateTime,
                message.Role,
                message.Role == ChatRole.Assistant &&
                message.AgentName is not null &&
                agentMap.TryGetValue(message.AgentName, out var agentId)
                    ? agentId
                    : null,
                message.AgentName))
            .ToList();

        var chatId = lastSavedChatId ?? Guid.NewGuid();
        var chat = new SavedChat(chatId, title, DateTime.UtcNow, messages, participants);
        await SavedChatService.SaveAsync(chat);

        lastSavedChatId = chatId;
        lastSavedChatTitle = title;
        Snackbar.Add("Chat saved", Severity.Success);
    }

