    }

    private async Task<McpElicitationResponse> HandleElicitationAsync(
        McpElicitationPrompt prompt,
        CancellationToken cancellationToken)
    {
        try
        {
            cancellationToken.ThrowIfCancellationRequested();

            var parameters = new DialogParameters
            {
                ["Prompt"] = prompt
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                BackdropClick = false,
                CloseOnEscapeKey = true,
                CloseButton = true
            };

            IDialogReference? dialog = null;
            await InvokeAsync(async () =>
            {
                dialog = await DialogService.ShowAsync<McpElicitationDialog>(
                    $"MCP input: {prompt.ServerName}",
                    parameters,
                    options);
            });

            if (dialog is null)
            {
                return McpElicitationResponse.Cancel;
            }

            using var registration = cancellationToken.Register(() =>
            {
                _ = InvokeAsync(() => dialog.Close(DialogResult.Ok(McpElicitationResponse.Cancel)));
            });

            var result = await dialog.Result;
            return result?.Canceled == false
                ? result.Data as McpElicitationResponse ?? McpElicitationResponse.Cancel
                : McpElicitationResponse.Cancel;
        }
        catch (OperationCanceledException)
        {
            return McpElicitationResponse.Cancel;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to handle MCP user prompt: {ex.Message}", Severity.Warning);
            return McpElicitationResponse.Cancel;
        }
    }

    private IReadOnlyList<AgentWorkflowHandoffDefinition> GetOutgoingHandoffs(string agentId) =>
        (currentWorkflow as AgentWorkflowDefinition)?.Handoffs
            .Where(handoff => string.Equals(handoff.FromAgentId, agentId, StringComparison.OrdinalIgnoreCase))
            .ToList()
        ?? [];

    private static string GetGroupChatManagerLabel(GroupChatWorkflowDefinition workflow)
    {
        return workflow.Manager.Kind switch
        {
            GroupChatWorkflowManagerKind.Custom when !string.IsNullOrWhiteSpace(workflow.Manager.ImplementationKey) =>
                $"{workflow.Manager.Kind} ({workflow.Manager.ImplementationKey}, max {workflow.Manager.MaximumIterations})",
            GroupChatWorkflowManagerKind.Programmable =>
                $"{workflow.Manager.Kind} ({workflow.Manager.ProgramDisplayName ?? "custom code"}, max {workflow.Manager.MaximumIterations})",
            _ => $"{workflow.Manager.Kind} (max {workflow.Manager.MaximumIterations})"
        };
    }

    private static string GetConcurrentAggregationLabel(ConcurrentWorkflowDefinition workflow)
        => workflow.Aggregation.Kind.ToString();

    private static AgentTemplateDefinition GetRequiredAgentDraft(WorkflowParticipantDefinition agent) =>
        agent.AgentDraft ?? throw new InvalidOperationException(
            $"Workflow agent '{agent.Id}' was not materialized.");

    private static Color GetCapabilityColor(AgentWorkflowCapabilityAvailability availability) =>
        availability switch
        {
            AgentWorkflowCapabilityAvailability.Available => Color.Success,
            AgentWorkflowCapabilityAvailability.Partial => Color.Warning,
            _ => Color.Error
        };

    public async ValueTask DisposeAsync()
    {
        WorkflowChatViewModelService.AnsweringStateChanged -= OnAnsweringStateChanged;
        WorkflowChatViewModelService.ChatReset -= OnChatReset;
        if (messageAddedHandler is not null)
        {
            WorkflowChatViewModelService.MessageAdded -= messageAddedHandler;
        }

        if (messageUpdatedHandler is not null)
        {
            WorkflowChatViewModelService.MessageUpdated -= messageUpdatedHandler;
        }

        if (messageDeletedHandler is not null)
        {
            WorkflowChatViewModelService.MessageDeleted -= messageDeletedHandler;
        }

        elicitationHandlerRegistration?.Dispose();
        await WorkflowSessionService.CancelAsync();
        await WorkflowSessionService.ResetAsync();
    }
}
