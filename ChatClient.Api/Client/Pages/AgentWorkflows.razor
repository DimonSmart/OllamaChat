@page "/agent-workflows"
@implements IAsyncDisposable
@using System.Collections.Immutable
@using ChatClient.Api.AgentWorkflows
@using ChatClient.Api.Client.Components
@using ChatClient.Api.Client.Services
@using ChatClient.Api.Client.Services.Agentic
@using ChatClient.Api.Client.ViewModels
@using ChatClient.Api.Services
@using ChatClient.Application.Helpers
@using ChatClient.Application.Services
@using ChatClient.Application.Services.Agentic
@using ChatClient.Domain.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.AI
@using Microsoft.JSInterop
@using MudBlazor
@inject IAgentWorkflowCatalog WorkflowCatalog
@inject IHandoffWorkflowSessionService WorkflowSessionService
@inject IHandoffWorkflowChatViewModelService WorkflowChatViewModelService
@inject IUserSettingsService UserSettingsService
@inject ISavedChatService SavedChatService
@inject IMcpUserInteractionService McpUserInteractionService
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Handoff Workflows</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-4" Outlined="true">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">Handoff Workflows</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Fixed workflow templates for multi-agent handoff scenarios. This slice mirrors the article's 5-agent interview coach topology, persists shared task state through MCP, and executes turns through the official workflow runtime.
            </MudText>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <MudAlert Severity="Severity.Error" Dense="true">
            @loadError
        </MudAlert>
    }
    else if (template is null)
    {
        <MudPaper Class="pa-6" Outlined="true">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                <MudText Typo="Typo.body2">Loading workflow template...</MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" lg="7">
                <MudStack Spacing="3">
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">@template.DisplayName</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@template.Description</MudText>

                            <MudAlert Severity="Severity.Info" Dense="true">
                                Fluent builder is sufficient for these agents: names, prompts, models, execution settings, and per-agent MCP bindings are already expressible with the current DSL.
                            </MudAlert>

                            <div class="handoff-workflow-flow">
                                @foreach (var agentId in OrderedAgentIds)
                                {
                                    var agent = GetAgent(agentId);
                                    if (agent is null)
                                    {
                                        continue;
                                    }

                                    <MudPaper Class="handoff-workflow-node pa-3" Outlined="true">
                                        <MudStack Spacing="1">
                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                <MudText Typo="Typo.subtitle2">@agent.AgentDraft.AgentName</MudText>
                                                @if (string.Equals(agent.Id, template.Workflow.StartAgentId, StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Start</MudChip>
                                                }
                                            </MudStack>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@agent.Role</MudText>
                                        </MudStack>
                                    </MudPaper>

                                    @if (!string.Equals(agentId, OrderedAgentIds.Last(), StringComparison.OrdinalIgnoreCase))
                                    {
                                        <div class="handoff-workflow-arrow" aria-hidden="true">
                                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                                        </div>
                                    }
                                }
                            </div>

                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Happy path: triage -> receptionist -> behavioural -> technical -> summarizer. Specialists also expose fallback edges back to triage.
                            </MudText>
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-4" Outlined="true">
                        <MudStack Spacing="2">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="handoff-workflow-start-header">
                                <MudText Typo="Typo.h6">Start Fixed Workflow</MudText>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           Disabled="@isStartingWorkflow"
                                           OnClick="LoadSampleData">
                                    Load Sample Data
                                </MudButton>
                            </MudStack>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Step 1 prepares the shared task session and optional markdown documents. Step 2 starts a separate handoff chat on top of that state.
                            </MudText>

                            @if (!HasSelectedModel)
                            {
                                <MudAlert Severity="Severity.Warning" Dense="true">
                                    Select a model in the global UI model selector before starting the workflow.
                                </MudAlert>
                            }

                            @if (!string.IsNullOrWhiteSpace(WorkflowSessionService.TaskSessionId))
                            {
                                <MudAlert Severity="Severity.Success" Dense="true">
                                    Active task session: @WorkflowSessionService.TaskSessionId
                                </MudAlert>
                            }

                            <MudTextField T="string"
                                          Label="Session Title"
                                          Value="sessionTitle"
                                          ValueChanged="value => sessionTitle = value"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />

                            <MudTextField T="string"
                                          Label="Scenario Description"
                                          Value="sessionDescription"
                                          ValueChanged="value => sessionDescription = value"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="4"
                                          AutoGrow="true" />

                            <MudTextField T="string"
                                          Label="Resume Markdown"
                                          Value="resumeMarkdown"
                                          ValueChanged="value => resumeMarkdown = value"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="8"
                                          AutoGrow="true" />

                            <MudTextField T="string"
                                          Label="Job Description Markdown"
                                          Value="jobDescriptionMarkdown"
                                          ValueChanged="value => jobDescriptionMarkdown = value"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="8"
                                          AutoGrow="true" />

                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@(!CanStartWorkflow)"
                                           OnClick="StartWorkflowAsync">
                                    Start Workflow
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Disabled="@(!workflowStarted)"
                                           OnClick="ResetWorkflowAsync">
                                    New Session
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-4" Outlined="true">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">Project Fit</MudText>

                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">Fluent Builder</MudText>
                                <MudText Typo="Typo.body2">@template.Assessment.FluentBuilderReason</MudText>
                            </MudPaper>

                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">Existing Saved Agents</MudText>
                                <MudText Typo="Typo.body2">@template.Assessment.ExistingSavedAgentsReason</MudText>
                            </MudPaper>

                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">Reusable Project Pieces</MudText>
                                @foreach (var item in template.Assessment.ReusableProjectPieces)
                                {
                                    <MudText Typo="Typo.body2">- @item</MudText>
                                }
                            </MudPaper>

                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">Missing Pieces</MudText>
                                @foreach (var item in template.Assessment.MissingProjectPieces)
                                {
                                    <MudText Typo="Typo.body2">- @item</MudText>
                                }
                            </MudPaper>
                        </MudStack>
                    </MudPaper>
                </MudStack>
            </MudItem>

            <MudItem xs="12" lg="5">
                <MudStack Spacing="3">
                    @foreach (var agent in template.Workflow.Agents)
                    {
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudStack Spacing="2">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.h6">@agent.AgentDraft.AgentName</MudText>
                                    @if (!string.IsNullOrWhiteSpace(agent.AgentDraft.ShortName))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@agent.AgentDraft.ShortName</MudChip>
                                    }
                                </MudStack>

                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@agent.Role</MudText>
                                <MudText Typo="Typo.body2">@agent.Summary</MudText>

                                <MudDivider />

                                <MudText Typo="Typo.subtitle2">Outgoing Handoffs</MudText>
                                <div class="handoff-workflow-chip-list">
                                    @foreach (var handoff in GetOutgoingHandoffs(agent.Id))
                                    {
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(handoff.IsFallback ? Color.Warning : Color.Primary)"
                                                 Variant="@(handoff.IsFallback ? Variant.Outlined : Variant.Filled)">
                                            @($"{handoff.ToAgentId} : {handoff.Label}")
                                        </MudChip>
                                    }
                                </div>

                                <MudText Typo="Typo.subtitle2">Capability Requirements</MudText>
                                @foreach (var capability in agent.CapabilityRequirements)
                                {
                                    <MudPaper Class="pa-3" Outlined="true">
                                        <MudStack Spacing="1">
                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                <MudText Typo="Typo.subtitle2">@capability.DisplayName</MudText>
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="@GetCapabilityColor(capability.Availability)"
                                                         Variant="Variant.Filled">
                                                    @capability.Availability
                                                </MudChip>
                                            </MudStack>
                                            <MudText Typo="Typo.body2">@capability.Purpose</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@capability.AvailabilityNote</MudText>
                                        </MudStack>
                                    </MudPaper>
                                }

                                <MudText Typo="Typo.subtitle2">Workflow Prompt</MudText>
                                <pre class="handoff-workflow-prompt">@agent.AgentDraft.Content</pre>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            </MudItem>
        </MudGrid>

        @if (workflowStarted)
        {
            <MudPaper Class="pa-4" Outlined="true">
                <MudStack Spacing="2">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="handoff-session-header">
                        <MudText Typo="Typo.h6">Workflow Chat</MudText>
                        @if (!string.IsNullOrWhiteSpace(WorkflowSessionService.TaskSessionId))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@WorkflowSessionService.TaskSessionId</MudChip>
                        }
                    </MudStack>

                    <AgenticChatSession @ref="chatSessionView"
                                        Messages="WorkflowChatViewModelService.Messages"
                                        Agents="WorkflowSessionService.AgentDescriptions"
                                        IsLlmAnswering="isLlmAnswering"
                                        UserName="userSettings.UserName"
                                        IsMultiAgent="true"
                                        OnSaveChat="SaveCurrentChat"
                                        OnSendMessage="SendChatMessageAsync"
                                        OnStop="CancelAsync"
                                        OnDeleteMessage="DeleteMessageAsync"
                                        OnCopyVisibleMessage="CopyVisibleMessageAsync"
                                        OnCopyRawMessage="CopyRawMessageAsync"
                                        OnCopyChat="CopyChatAsync" />
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    private const int UpdateIntervalMs = 500;
    private const string WorkflowTemplateId = "interview-coach-fixed-handoff";
    private const string SampleSessionTitle = "Senior .NET Interview Practice";

    private static readonly string SampleSessionDescription =
        """
        I want to practice for a Senior .NET Backend Engineer interview.
        Please review the resume and the job description first, then run a behavioural round,
        then a technical round, and finish with a concise summary.
        Respond in English.
        """;

    private static readonly string SampleResumeMarkdown =
        """
        # Alex Carter
        
        Senior .NET backend engineer with 9+ years of experience building distributed systems.
        
        ## Summary
        
        I design backend platforms with ASP.NET Core, PostgreSQL, Redis, RabbitMQ, and Kubernetes.
        I have worked on billing systems, document ingestion pipelines, and internal developer platforms.
        
        ## Experience
        
        ### Lead Backend Engineer, Northwind Payments
        - Designed payment orchestration services for card and bank transfer flows.
        - Improved P95 API latency by 32% through caching and query optimization.
        - Introduced the outbox pattern and idempotent consumers for asynchronous processing.
        - Mentored 5 backend engineers and led architecture reviews.
        
        ### Senior Software Engineer, Fabrikam Documents
        - Built document intake and search services with ASP.NET Core and PostgreSQL.
        - Added observability with traces, structured logs, and service-level dashboards.
        - Reduced failed background jobs by improving retries and dead-letter handling.
        
        ## Skills
        
        - C#
        - ASP.NET Core
        - PostgreSQL
        - Redis
        - RabbitMQ
        - Docker
        - Kubernetes
        - Distributed systems
        - System design
        - Observability
        """;

    private static readonly string SampleJobDescriptionMarkdown =
        """
        # Senior .NET Backend Engineer
        
        We are hiring a Senior .NET Backend Engineer to build scalable services for a multi-product platform.
        
        ## Responsibilities
        
        - Design and implement backend services in ASP.NET Core.
        - Work with PostgreSQL, Redis, and asynchronous messaging.
        - Improve reliability, observability, and performance.
        - Participate in system design and mentor other engineers.
        
        ## Requirements
        
        - Strong experience with C# and ASP.NET Core.
        - Experience with distributed systems and event-driven architectures.
        - Solid SQL and PostgreSQL knowledge.
        - Experience with Docker and Kubernetes.
        - Ability to explain architectural tradeoffs clearly.
        
        ## Nice to Have
        
        - Experience with document processing pipelines.
        - Experience with payment or billing systems.
        """;

    private static readonly string[] OrderedAgentIds =
    [
        "triage",
        "receptionist",
        "behavioural",
        "technical",
        "summarizer"
    ];

    private AgentWorkflowTemplate? template;
    private string? loadError;
    private string? sessionTitle;
    private string? sessionDescription;
    private string? resumeMarkdown;
    private string? jobDescriptionMarkdown;
    private bool workflowStarted;
    private bool isStartingWorkflow;
    private bool isLlmAnswering;
    private Guid? lastSavedChatId;
    private string lastSavedChatTitle = string.Empty;
    private UserSettings userSettings = new();
    private AgenticChatSession? chatSessionView;
    private StreamingDebouncer? renderDebouncer;
    private Func<AppChatMessageViewModel, Task>? messageAddedHandler;
    private Func<AppChatMessageViewModel, MessageUpdateOptions, Task>? messageUpdatedHandler;
    private Func<AppChatMessageViewModel, Task>? messageDeletedHandler;
    private IDisposable? elicitationHandlerRegistration;

    [CascadingParameter(Name = "UiModelSelection")]
    public ServerModelSelection UiModelSelection { get; set; } = new(null, null);

    private bool HasSelectedModel => TryResolveEffectiveModel(out _);

    private bool CanStartWorkflow =>
        template is not null &&
        HasSelectedModel &&
        !isStartingWorkflow &&
        !workflowStarted;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            template = await WorkflowCatalog.GetRequiredAsync(WorkflowTemplateId);
            userSettings = await UserSettingsService.GetSettingsAsync();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
            return;
        }

        elicitationHandlerRegistration = McpUserInteractionService.RegisterElicitationHandler(
            McpInteractionScope.Chat,
            HandleElicitationAsync);

        renderDebouncer = new StreamingDebouncer(UpdateIntervalMs, () => InvokeAsync(StateHasChanged));
        WorkflowChatViewModelService.AnsweringStateChanged += OnAnsweringStateChanged;
        WorkflowChatViewModelService.ChatReset += OnChatReset;
        messageAddedHandler = message => InvokeAsync(() => OnMessageAddedAsync(message));
        messageUpdatedHandler = (message, options) => InvokeAsync(() => OnMessageUpdatedAsync(message, options));
        messageDeletedHandler = message => InvokeAsync(() => OnMessageDeleted(message));
        WorkflowChatViewModelService.MessageAdded += messageAddedHandler;
        WorkflowChatViewModelService.MessageUpdated += messageUpdatedHandler;
        WorkflowChatViewModelService.MessageDeleted += messageDeletedHandler;
    }

    private async Task StartWorkflowAsync()
    {
        if (template is null || !TryResolveEffectiveModel(out var model))
        {
            return;
        }

        isStartingWorkflow = true;

        try
        {
            var runtimeAgents = template.Workflow.Agents
                .Select(agent => AgentDescriptionFactory.CreateResolved(agent.AgentDraft, model))
                .ToList();

            var documents = BuildDocumentInputs();
            var request = new HandoffWorkflowSessionStartRequest
            {
                Workflow = template.Workflow,
                Agents = runtimeAgents,
                Configuration = new AppChatConfiguration(model.ModelName, []),
                SessionTitle = sessionTitle,
                SessionDescription = sessionDescription,
                Documents = documents
            };

            await WorkflowSessionService.StartAsync(request);
            workflowStarted = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isStartingWorkflow = false;
        }
    }

    private async Task ResetWorkflowAsync()
    {
        await WorkflowSessionService.CancelAsync();
        WorkflowSessionService.ResetChat();
        workflowStarted = false;
        lastSavedChatId = null;
        lastSavedChatTitle = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private void LoadSampleData()
    {
        sessionTitle = SampleSessionTitle;
        sessionDescription = SampleSessionDescription;
        resumeMarkdown = SampleResumeMarkdown;
        jobDescriptionMarkdown = SampleJobDescriptionMarkdown;
    }

    private IReadOnlyList<HandoffWorkflowDocumentInput> BuildDocumentInputs()
    {
        List<HandoffWorkflowDocumentInput> documents = [];

        if (!string.IsNullOrWhiteSpace(resumeMarkdown))
        {
            documents.Add(new HandoffWorkflowDocumentInput
            {
                Kind = "resume",
                Title = "Resume",
                Markdown = resumeMarkdown
            });
        }

        if (!string.IsNullOrWhiteSpace(jobDescriptionMarkdown))
        {
            documents.Add(new HandoffWorkflowDocumentInput
            {
                Kind = "job_description",
                Title = "Job Description",
                Markdown = jobDescriptionMarkdown
            });
        }

        return documents;
    }

    private bool TryResolveEffectiveModel(out ServerModel model) =>
        ModelSelectionHelper.TryGetEffectiveModel(
            new ServerModelSelection(null, null),
            UiModelSelection,
            out model);

    private async Task SaveCurrentChat()
    {
        if (!WorkflowSessionService.Messages.Any())
        {
            Snackbar.Add("Nothing to save", Severity.Info);
            return;
        }

        var parameters = new DialogParameters
        {
            ["InitialTitle"] = lastSavedChatId.HasValue ? lastSavedChatTitle : string.Empty
        };
        var dialog = await DialogService.ShowAsync<SaveChatDialog>("Save Chat", parameters);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        var title = result.Data as string ?? string.Empty;
        var participants = WorkflowSessionService.AgentDescriptions
            .Select(agent => new SavedChatParticipant(agent.AgentId, agent.AgentName, ChatRole.Assistant))
            .ToList();
        participants.Add(new SavedChatParticipant(userSettings.UserName.ToLowerInvariant(), userSettings.UserName, ChatRole.User));

        var agentMap = WorkflowSessionService.AgentDescriptions
            .ToDictionary(agent => agent.AgentName, agent => agent.AgentId, StringComparer.OrdinalIgnoreCase);

        var messages = WorkflowSessionService.Messages
            .Where(message => !message.IsStreaming && !message.IsCanceled && message.Role != ChatRole.System)
            .Where(message => !string.IsNullOrWhiteSpace(message.Content) || message.Files.Count > 0)
            .Select(message => new SavedChatMessage(
                message.Id,
                message.Content,
                message.MsgDateTime,
                message.Role,
                message.Role == ChatRole.Assistant &&
                message.AgentName is not null &&
                agentMap.TryGetValue(message.AgentName, out var agentId)
                    ? agentId
                    : null,
                message.AgentName))
            .ToList();

        var chatId = lastSavedChatId ?? Guid.NewGuid();
        var chat = new SavedChat(chatId, title, DateTime.UtcNow, messages, participants);
        await SavedChatService.SaveAsync(chat);

        lastSavedChatId = chatId;
        lastSavedChatTitle = title;
        Snackbar.Add("Chat saved", Severity.Success);
    }

    private async Task SendChatMessageAsync((string text, IReadOnlyList<AppChatMessageFile> files) messageData)
    {
        if (string.IsNullOrWhiteSpace(messageData.text) || isLlmAnswering || !workflowStarted)
        {
            return;
        }

        await WorkflowSessionService.SendAsync(messageData.text.Trim(), messageData.files);
        await ScrollToBottomAsync();
    }

    private Task CancelAsync() =>
        WorkflowSessionService.CancelAsync();

    private async Task DeleteMessageAsync(AppChatMessageViewModel message)
    {
        if (isLlmAnswering)
        {
            return;
        }

        await WorkflowSessionService.DeleteMessageAsync(message.Id);
    }

    private Task CopyVisibleMessageAsync(AppChatMessageViewModel message) =>
        JSRuntime.InvokeVoidAsync("copyText", message.Content).AsTask();

    private async Task CopyRawMessageAsync(AppChatMessageViewModel message)
    {
        if (!string.IsNullOrEmpty(message.RawContent))
        {
            await JSRuntime.InvokeVoidAsync("copyText", message.RawContent);
        }
    }

    private Task CopyChatAsync(ChatFormat format)
    {
        var text = ChatTranscriptFormatter.Format(WorkflowChatViewModelService.Messages, format);
        return JSRuntime.InvokeVoidAsync("copyText", text).AsTask();
    }

    private async Task ScrollToBottomAsync() =>
        await (chatSessionView?.ScrollToBottomAsync() ?? Task.CompletedTask);

    private void OnAnsweringStateChanged(bool answering)
    {
        isLlmAnswering = answering;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnMessageAddedAsync(AppChatMessageViewModel message)
    {
        StateHasChanged();
        await ScrollToBottomAsync();
    }

    private Task OnMessageUpdatedAsync(AppChatMessageViewModel message, MessageUpdateOptions options) =>
        renderDebouncer?.TriggerAsync(options) ?? Task.CompletedTask;

    private void OnMessageDeleted(AppChatMessageViewModel message)
    {
        StateHasChanged();
    }

    private void OnChatReset()
    {
        workflowStarted = false;
        isLlmAnswering = false;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task<McpElicitationResponse> HandleElicitationAsync(
        McpElicitationPrompt prompt,
        CancellationToken cancellationToken)
    {
        try
        {
            cancellationToken.ThrowIfCancellationRequested();

            var parameters = new DialogParameters
            {
                ["Prompt"] = prompt
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                BackdropClick = false,
                CloseOnEscapeKey = true,
                CloseButton = true
            };

            IDialogReference? dialog = null;
            await InvokeAsync(async () =>
            {
                dialog = await DialogService.ShowAsync<McpElicitationDialog>(
                    $"MCP input: {prompt.ServerName}",
                    parameters,
                    options);
            });

            if (dialog is null)
            {
                return McpElicitationResponse.Cancel;
            }

            using var registration = cancellationToken.Register(() =>
            {
                _ = InvokeAsync(() => dialog.Close(DialogResult.Ok(McpElicitationResponse.Cancel)));
            });

            var result = await dialog.Result;
            return result?.Canceled == false
                ? result.Data as McpElicitationResponse ?? McpElicitationResponse.Cancel
                : McpElicitationResponse.Cancel;
        }
        catch (OperationCanceledException)
        {
            return McpElicitationResponse.Cancel;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to handle MCP user prompt: {ex.Message}", Severity.Warning);
            return McpElicitationResponse.Cancel;
        }
    }

    private AgentWorkflowAgentDefinition? GetAgent(string agentId) =>
        template?.Workflow.Agents.FirstOrDefault(agent =>
            string.Equals(agent.Id, agentId, StringComparison.OrdinalIgnoreCase));

    private IReadOnlyList<AgentWorkflowHandoffDefinition> GetOutgoingHandoffs(string agentId) =>
        template?.Workflow.Handoffs
            .Where(handoff => string.Equals(handoff.FromAgentId, agentId, StringComparison.OrdinalIgnoreCase))
            .ToList()
        ?? [];

    private static Color GetCapabilityColor(AgentWorkflowCapabilityAvailability availability) =>
        availability switch
        {
            AgentWorkflowCapabilityAvailability.Available => Color.Success,
            AgentWorkflowCapabilityAvailability.Partial => Color.Warning,
            _ => Color.Error
        };

    public async ValueTask DisposeAsync()
    {
        WorkflowChatViewModelService.AnsweringStateChanged -= OnAnsweringStateChanged;
        WorkflowChatViewModelService.ChatReset -= OnChatReset;
        if (messageAddedHandler is not null)
        {
            WorkflowChatViewModelService.MessageAdded -= messageAddedHandler;
        }

        if (messageUpdatedHandler is not null)
        {
            WorkflowChatViewModelService.MessageUpdated -= messageUpdatedHandler;
        }

        if (messageDeletedHandler is not null)
        {
            WorkflowChatViewModelService.MessageDeleted -= messageDeletedHandler;
        }

        elicitationHandlerRegistration?.Dispose();
        await WorkflowSessionService.CancelAsync();
        WorkflowSessionService.ResetChat();
    }
}
