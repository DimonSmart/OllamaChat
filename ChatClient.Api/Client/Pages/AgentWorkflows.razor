@page "/agent-workflows"
@implements IAsyncDisposable
@using System.Collections.Immutable
@using ChatClient.Api.AgentWorkflows
@using ChatClient.Api.Client.Components
@using ChatClient.Api.Client.Services
@using ChatClient.Api.Client.Services.Agentic
@using ChatClient.Api.Client.ViewModels
@using ChatClient.Api.Services
@using ChatClient.Application.Helpers
@using ChatClient.Application.Services
@using ChatClient.Application.Services.Agentic
@using ChatClient.Domain.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using MudBlazor
@inject IWorkflowDefinitionCompiler WorkflowCompiler
@inject IWorkflowAgentDraftMaterializer WorkflowAgentDraftMaterializer
@inject IWorkflowDefinitionService WorkflowDefinitionService
@inject IOrchestrationWorkflowSessionService WorkflowSessionService
@inject IOrchestrationWorkflowChatViewModelService WorkflowChatViewModelService
@inject IUserSettingsService UserSettingsService
@inject IMcpUserInteractionService McpUserInteractionService
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Agent Orchestrations</PageTitle>

<MudStack Spacing="3">
    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <MudAlert Severity="Severity.Error" Dense="true">
            @loadError
        </MudAlert>
    }
    else if (isPageLoading)
    {
        <MudPaper Class="pa-6" Outlined="true">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                <MudText Typo="Typo.body2">Loading workflow editor...</MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        @if (isWorkflowSourceExpanded)
        {
            <MudPaper Class="pa-4" Outlined="true">
                <MudStack Spacing="2">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="handoff-workflow-start-header">
                        <MudText Typo="Typo.h6">Workflow Source</MudText>
                        <MudStack Row="true" Spacing="2" Class="handoff-workflow-command-row">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       Disabled="@(!CanCompileWorkflow)"
                                       OnClick="CompileWorkflowAsync">
                                @(isCompilingWorkflow ? "Compiling..." : "Compile Workflow")
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       OnClick="ToggleWorkflowSourceEditor">
                                Hide Source
                            </MudButton>
                        </MudStack>
                    </MudStack>

                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Compile the current source to refresh the workflow preview and required inputs.
                    </MudText>

                    <WorkflowSourceCodeEditor Value="@workflowSourceCode"
                                              ValueChanged="OnWorkflowSourceChanged"
                                              Disabled="@workflowStarted"
                                              MinLines="28" />
                </MudStack>
            </MudPaper>
        }

        <MudGrid>
            <MudItem xs="12" lg="@(ShowWorkflowSidebar ? 7 : 12)">
                <MudStack Spacing="3">
                    @if (ShowWorkflowStartPanel)
                    {
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudStack Spacing="2">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="handoff-workflow-start-header">
                                    <MudText Typo="Typo.h6">Start Workflow</MudText>
                                    @if (currentWorkflow is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@currentWorkflow.Kind</MudChip>
                                    }
                                </MudStack>

                                @if (!string.IsNullOrWhiteSpace(workflowCompileError))
                                {
                                    <MudAlert Severity="Severity.Error" Dense="true">
                                        @workflowCompileError
                                    </MudAlert>
                                }

                                @if (!HasSelectedModel)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true">
                                        Select a model in the global UI model selector before starting the workflow.
                                    </MudAlert>
                                }

                                @if (currentWorkflow is null)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true">
                                        Compile the current workflow source to inspect its required inputs and enable Start Workflow.
                                    </MudAlert>

                                    @if (HasWorkflowSource)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Check"
                                                   Disabled="@(!CanCompileWorkflow)"
                                                   OnClick="CompileWorkflowAsync">
                                            @(isCompilingWorkflow ? "Compiling..." : "Compile Workflow")
                                        </MudButton>
                                    }
                                }
                                else if (!AreRequiredStartInputsSatisfied)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true">
                                        Fill in all required workflow inputs before starting the workflow.
                                    </MudAlert>
                                }

                                @if (!string.IsNullOrWhiteSpace(WorkflowSessionService.TaskSessionId))
                                {
                                    <MudAlert Severity="Severity.Success" Dense="true">
                                        Active task session: @WorkflowSessionService.TaskSessionId
                                    </MudAlert>
                                }

                                @if (currentWorkflow is not null)
                                {
                                    @if (currentWorkflow.StartInputs.Count > 0)
                                    {
                                        <MudText Typo="Typo.subtitle2">Workflow Inputs</MudText>
                                    }

                                    @foreach (var input in currentWorkflow.StartInputs)
                                    {
                                        <MudStack Spacing="1">
                                            @switch (input.Kind)
                                            {
                                                case WorkflowStartInputKind.MarkdownDocument:
                                                case WorkflowStartInputKind.Json:
                                                    <MudTextField T="string"
                                                                  Label="@GetStartInputLabel(input)"
                                                                  HelperText="@input.Description"
                                                                  Value="GetStartInputValue(input.Key)"
                                                                  ValueChanged="value => SetStartInputValue(input.Key, value)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Placeholder="@input.Placeholder"
                                                                  Lines="8"
                                                                  AutoGrow="true" />
                                                    break;

                                                case WorkflowStartInputKind.Boolean:
                                                    <MudSwitch T="bool"
                                                               Label="@GetStartInputLabel(input)"
                                                               Value="GetBooleanStartInputValue(input)"
                                                               ValueChanged="value => SetBooleanStartInputValue(input.Key, value)"
                                                               Color="Color.Primary" />
                                                    if (!string.IsNullOrWhiteSpace(input.Description))
                                                    {
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@input.Description</MudText>
                                                    }
                                                    break;

                                                default:
                                                    <MudTextField T="string"
                                                                  Label="@GetStartInputLabel(input)"
                                                                  HelperText="@input.Description"
                                                                  Value="GetStartInputValue(input.Key)"
                                                                  ValueChanged="value => SetStartInputValue(input.Key, value)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Placeholder="@input.Placeholder"
                                                                  InputType="@(input.Kind == WorkflowStartInputKind.Number ? InputType.Number : InputType.Text)" />
                                                    break;
                                            }
                                        </MudStack>
                                    }
                                }

                                <MudStack Row="true" Spacing="2" Class="handoff-workflow-command-row">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@(!CanStartWorkflow)"
                                               OnClick="StartWorkflowAsync">
                                        Start Workflow
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Disabled="@(!workflowStarted)"
                                               OnClick="ResetWorkflowAsync">
                                        New Session
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Class="pa-6 workflow-empty-state" Outlined="true">
                            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h5">No Workflow Loaded</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary workflow-empty-state-copy">
                                    Load a saved workflow, or open the source editor and compile a local draft to review its inputs and launch an orchestration.
                                </MudText>
                                <MudStack Row="true" Spacing="2" Class="handoff-workflow-command-row">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@workflowStarted"
                                               OnClick="OpenLoadWorkflowDialogAsync">
                                        Load Saved Workflow
                                    </MudButton>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Default"
                                               Size="Size.Small"
                                               OnClick="ToggleWorkflowSourceEditor">
                                        @(isWorkflowSourceExpanded ? "Hide Source" : "Show Source")
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            </MudItem>

            @if (ShowWorkflowSidebar)
            {
                <MudItem xs="12" lg="5">
                    <MudStack Spacing="3">
                        @if (ShowWorkflowSummaryCard)
                        {
                            <MudPaper Class="pa-4" Outlined="true">
                                <MudStack Spacing="2">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="handoff-workflow-title-row">
                                            <MudText Typo="Typo.h6">@WorkflowCardDisplayName</MudText>
                                            @if (currentSavedWorkflowId.HasValue)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Saved</MudChip>
                                            }
                                            @if (currentSavedWorkflowId.HasValue && workflowSourceDirty)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Modified</MudChip>
                                            }
                                        </MudStack>
                                        @if (!string.IsNullOrWhiteSpace(WorkflowCardDescription))
                                        {
                                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@WorkflowCardDescription</MudText>
                                        }
                                    </MudStack>

                                    <MudStack Row="true" Spacing="2" Class="handoff-workflow-command-row">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Check"
                                                   Disabled="@(!CanCompileWorkflow)"
                                                   OnClick="CompileWorkflowAsync">
                                            @(isCompilingWorkflow ? "Compiling..." : "Compile Workflow")
                                        </MudButton>
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Default"
                                                   Size="Size.Small"
                                                   OnClick="ToggleWorkflowSourceEditor">
                                            @(isWorkflowSourceExpanded ? "Hide Source" : "Show Source")
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Default"
                                                   Size="Size.Small"
                                                   Disabled="@workflowStarted"
                                                   OnClick="OpenLoadWorkflowDialogAsync">
                                            Load Saved Workflow
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }

                        @if (currentWorkflow is not null)
                        {
                            <MudPaper Class="pa-4" Outlined="true">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.h6">Orchestration Preview</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@currentWorkflow.Kind</MudChip>
                                    </MudStack>

                                    @if (currentWorkflow is AgentWorkflowDefinition handoffWorkflow)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Start agent: @handoffWorkflow.StartAgentId</MudText>
                                        <div class="handoff-workflow-chip-list">
                                            @foreach (var handoff in handoffWorkflow.Handoffs)
                                            {
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="@(handoff.IsFallback ? Color.Warning : Color.Primary)"
                                                         Variant="@(handoff.IsFallback ? Variant.Outlined : Variant.Filled)">
                                                    @($"{handoff.FromAgentId} -> {handoff.ToAgentId} : {handoff.Label}")
                                                </MudChip>
                                            }
                                        </div>
                                    }
                                    else if (currentWorkflow is GroupChatWorkflowDefinition groupChatWorkflow)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                            Manager: @GetGroupChatManagerLabel(groupChatWorkflow)
                                        </MudText>
                                        <div class="handoff-workflow-chip-list">
                                            @foreach (var participant in groupChatWorkflow.ParticipantAgentIds)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@participant</MudChip>
                                            }
                                        </div>
                                    }
                                    else if (currentWorkflow is SequentialWorkflowDefinition sequentialWorkflow)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Sequential order</MudText>
                                        <div class="handoff-workflow-chip-list">
                                            @foreach (var agentId in sequentialWorkflow.AgentOrder)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@agentId</MudChip>
                                            }
                                        </div>
                                    }
                                    else if (currentWorkflow is ConcurrentWorkflowDefinition concurrentWorkflow)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                            Aggregation: @GetConcurrentAggregationLabel(concurrentWorkflow)
                                        </MudText>
                                        <div class="handoff-workflow-chip-list">
                                            @foreach (var participant in concurrentWorkflow.ParticipantAgentIds)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@participant</MudChip>
                                            }
                                        </div>
                                    }
                                </MudStack>
                            </MudPaper>

                            <MudExpansionPanels MultiExpansion="true" Outlined="true" Class="handoff-workflow-agent-panels">
                                @foreach (var agent in currentWorkflow.Participants)
                                {
                                    var agentDraft = GetRequiredAgentDraft(agent);
                                    <MudExpansionPanel Expanded="false">
                                        <TitleContent>
                                            <MudStack Spacing="1">
                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="handoff-workflow-agent-title">
                                                    <MudText Typo="Typo.subtitle1">@agentDraft.AgentName</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(agentDraft.ShortName))
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@agentDraft.ShortName</MudChip>
                                                    }
                                                </MudStack>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@agent.Role</MudText>
                                            </MudStack>
                                        </TitleContent>

                                        <ChildContent>
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.body2">@agent.Summary</MudText>

                                                @if (currentWorkflow is AgentWorkflowDefinition)
                                                {
                                                    <MudDivider />

                                                    <MudText Typo="Typo.subtitle2">Outgoing Handoffs</MudText>
                                                    <div class="handoff-workflow-chip-list">
                                                        @foreach (var handoff in GetOutgoingHandoffs(agent.Id))
                                                        {
                                                            <MudChip T="string" Size="Size.Small"
                                                                     Color="@(handoff.IsFallback ? Color.Warning : Color.Primary)"
                                                                     Variant="@(handoff.IsFallback ? Variant.Outlined : Variant.Filled)">
                                                                @($"{handoff.ToAgentId} : {handoff.Label}")
                                                            </MudChip>
                                                        }
                                                    </div>
                                                }

                                                <MudText Typo="Typo.subtitle2">Capability Requirements</MudText>
                                                @foreach (var capability in agent.CapabilityRequirements)
                                                {
                                                    <MudPaper Class="pa-3" Outlined="true">
                                                        <MudStack Spacing="1">
                                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                <MudText Typo="Typo.subtitle2">@capability.DisplayName</MudText>
                                                                <MudChip T="string" Size="Size.Small"
                                                                         Color="@GetCapabilityColor(capability.Availability)"
                                                                         Variant="Variant.Filled">
                                                                    @capability.Availability
                                                                </MudChip>
                                                            </MudStack>
                                                            <MudText Typo="Typo.body2">@capability.Purpose</MudText>
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@capability.AvailabilityNote</MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                }

                                                <MudText Typo="Typo.subtitle2">Workflow Prompt</MudText>
                                                <pre class="handoff-workflow-prompt">@agentDraft.Content</pre>
                                            </MudStack>
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        }
                    </MudStack>
                </MudItem>
            }
        </MudGrid>

        @if (workflowStarted)
        {
            <MudPaper Class="pa-4" Outlined="true">
                <MudStack Spacing="2">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="handoff-session-header">
                        <MudText Typo="Typo.h6">Workflow Chat</MudText>
                        @if (!string.IsNullOrWhiteSpace(WorkflowSessionService.TaskSessionId))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@WorkflowSessionService.TaskSessionId</MudChip>
                        }
                    </MudStack>

                                        <AgenticChatSession @ref="chatSessionView"
                                                           Messages="WorkflowChatViewModelService.Messages"
                                                           Agents="WorkflowSessionService.Agents"
                                                           IsLlmAnswering="isLlmAnswering"
                                                           UserName="userSettings.UserName"
                                                           IsMultiAgent="true"
                                                           OnSendMessage="SendChatMessageAsync"
                                                           OnStop="CancelAsync"
                                                           AllowMessageDeletion="true"
                                                           OnDeleteMessage="DeleteMessageAsync"
                                        OnCopyChat="CopyChatAsync" />
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

<MudDialog @bind-Visible="@showLoadWorkflowDialog" Options="loadWorkflowDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Load Workflow</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField T="string"
                          Value="workflowSearchText"
                          ValueChanged="OnWorkflowSearchChanged"
                          Placeholder="Filter workflows..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="200" />

            @if (filteredSavedWorkflows.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No saved workflows found.</MudText>
            }
            else
            {
                <div class="workflow-load-list">
                    @foreach (var workflow in filteredSavedWorkflows)
                    {
                        var isSelected = workflow.Id == selectedWorkflowIdToLoad;
                        <MudPaper Class="@($"pa-3 workflow-load-item {(isSelected ? "workflow-load-item-selected" : string.Empty)}")"
                                  Outlined="true"
                                  Style="cursor:pointer;"
                                  @onclick="() => SelectWorkflowToLoad(workflow.Id)"
                                  @ondblclick="ConfirmLoadWorkflowAsync">
                            <MudStack Spacing="1">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="handoff-workflow-title-row">
                                    <MudText Typo="Typo.subtitle2">@workflow.DisplayName</MudText>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@workflow.Kind</MudChip>
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(workflow.Description))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@workflow.Description</MudText>
                                }
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Id: @workflow.WorkflowId</MudText>
                            </MudStack>
                        </MudPaper>
                    }
                </div>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseLoadWorkflowDialog" Size="Size.Medium">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   OnClick="ConfirmLoadWorkflowAsync"
                   Size="Size.Medium"
                   Disabled="@(!selectedWorkflowIdToLoad.HasValue)">
            OK
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private const int UpdateIntervalMs = 500;
    private readonly Dictionary<string, string?> startInputValues = new(StringComparer.OrdinalIgnoreCase);
    private readonly DialogOptions loadWorkflowDialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true,
        CloseButton = true
    };

    private CompiledWorkflowDefinition? compiledWorkflow;
    private SavedWorkflowDefinition? currentSavedWorkflow;
    private string? loadError;
    private string workflowSourceCode = string.Empty;
    private string? workflowCompileError;
    private string workflowSearchText = string.Empty;
    private bool isPageLoading = true;
    private bool isWorkflowSourceExpanded;
    private bool workflowSourceDirty;
    private bool isCompilingWorkflow;
    private bool workflowStarted;
    private bool isStartingWorkflow;
    private bool isLlmAnswering;
    private bool showLoadWorkflowDialog;
    private Guid? currentSavedWorkflowId;
    private Guid? selectedWorkflowIdToLoad;
    private UserSettings userSettings = new();
    private List<SavedWorkflowDefinition> savedWorkflows = [];
    private List<SavedWorkflowDefinition> filteredSavedWorkflows = [];
    private AgenticChatSession? chatSessionView;
    private StreamingDebouncer? renderDebouncer;
    private Func<AppChatMessageViewModel, Task>? messageAddedHandler;
    private Func<AppChatMessageViewModel, MessageUpdateOptions, Task>? messageUpdatedHandler;
    private Func<AppChatMessageViewModel, Task>? messageDeletedHandler;
    private IDisposable? elicitationHandlerRegistration;

    [CascadingParameter(Name = "UiModelSelection")]
    public ServerModelSelection UiModelSelection { get; set; } = new(null, null);

    private IOrchestrationWorkflowDefinition? currentWorkflow => compiledWorkflow?.Workflow;

    private bool HasWorkflowSource => !string.IsNullOrWhiteSpace(workflowSourceCode);

    private bool HasWorkflowContext =>
        currentWorkflow is not null ||
        currentSavedWorkflow is not null ||
        HasWorkflowSource;

    private bool ShowWorkflowStartPanel => HasWorkflowContext;

    private bool ShowWorkflowSummaryCard => HasWorkflowContext;

    private bool ShowWorkflowSidebar => ShowWorkflowSummaryCard;

    private string WorkflowCardDisplayName =>
        currentWorkflow?.DisplayName ??
        currentSavedWorkflow?.DisplayName ??
        "Workflow Draft";

    private string? WorkflowCardDescription =>
        currentWorkflow?.Description ??
        currentSavedWorkflow?.Description;

    private bool HasSelectedModel => TryResolveEffectiveModel(out _);

    private bool AreRequiredStartInputsSatisfied =>
        currentWorkflow?.StartInputs.All(IsStartInputSatisfied) ?? true;

    private bool CanCompileWorkflow =>
        !isCompilingWorkflow &&
        !isStartingWorkflow &&
        !workflowStarted &&
        HasWorkflowSource;

    private bool CanStartWorkflow =>
        HasSelectedModel &&
        !isStartingWorkflow &&
        !string.IsNullOrWhiteSpace(workflowSourceCode) &&
        currentWorkflow is not null &&
        AreRequiredStartInputsSatisfied &&
        !workflowStarted;

    protected override async Task OnInitializedAsync()
    {
        isPageLoading = true;

        try
        {
            var userSettingsTask = UserSettingsService.GetSettingsAsync();
            var savedWorkflowsTask = WorkflowDefinitionService.GetAllAsync();

            userSettings = await userSettingsTask;
            savedWorkflows = (await savedWorkflowsTask).ToList();
            ApplyWorkflowFilter();

            workflowSourceCode = string.Empty;
            workflowSourceDirty = false;
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isPageLoading = false;
        }

        if (!string.IsNullOrWhiteSpace(loadError))
        {
            return;
        }

        elicitationHandlerRegistration = McpUserInteractionService.RegisterElicitationHandler(
            McpInteractionScope.Chat,
            HandleElicitationAsync);

        renderDebouncer = new StreamingDebouncer(UpdateIntervalMs, () => InvokeAsync(StateHasChanged));
        WorkflowChatViewModelService.AnsweringStateChanged += OnAnsweringStateChanged;
        WorkflowChatViewModelService.ChatReset += OnChatReset;
        messageAddedHandler = message => InvokeAsync(() => OnMessageAddedAsync(message));
        messageUpdatedHandler = (message, options) => InvokeAsync(() => OnMessageUpdatedAsync(message, options));
        messageDeletedHandler = message => InvokeAsync(() => OnMessageDeleted(message));
        WorkflowChatViewModelService.MessageAdded += messageAddedHandler;
        WorkflowChatViewModelService.MessageUpdated += messageUpdatedHandler;
        WorkflowChatViewModelService.MessageDeleted += messageDeletedHandler;
    }

    private async Task StartWorkflowAsync()
    {
        if (!TryResolveEffectiveModel(out var model))
        {
            return;
        }

        isStartingWorkflow = true;

        try
        {
            if (!await CompileWorkflowSourceAsync(expandEditorOnError: true))
            {
                return;
            }

            if (currentWorkflow is null)
            {
                Snackbar.Add("Workflow source did not produce a valid orchestration workflow definition.", Severity.Error);
                return;
            }

            if (!AreRequiredStartInputsSatisfied)
            {
                Snackbar.Add("Fill in all required workflow inputs before starting the workflow.", Severity.Warning);
                return;
            }

            var runtimeAgents = currentWorkflow.Participants
                .Select(agent => ResolvedChatAgentFactory.Resolve(GetRequiredAgentDraft(agent), model))
                .ToList();

            var startInputs = BuildStartInputs();
            var request = new OrchestrationWorkflowSessionStartRequest
            {
                Workflow = currentWorkflow,
                Agents = runtimeAgents,
                Configuration = new AppChatConfiguration(model.ModelName, []),
                StartInputs = startInputs
            };

            await WorkflowSessionService.StartAsync(request);
            workflowStarted = true;

            if (currentWorkflow.Execution.Mode == AgentWorkflowExecutionMode.Autonomous)
            {
                await WorkflowSessionService.KickoffAsync();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isStartingWorkflow = false;
        }
    }

    private async Task CompileWorkflowAsync()
    {
        if (!CanCompileWorkflow)
        {
            return;
        }

        isCompilingWorkflow = true;

        try
        {
            if (await CompileWorkflowSourceAsync(expandEditorOnError: true))
            {
                Snackbar.Add("Workflow compiled. Review the inputs and start when ready.", Severity.Success);
                return;
            }

            if (!string.IsNullOrWhiteSpace(workflowCompileError))
            {
                Snackbar.Add(workflowCompileError, Severity.Error);
            }
        }
        finally
        {
            isCompilingWorkflow = false;
        }
    }

    private async Task ResetWorkflowAsync()
    {
        await WorkflowSessionService.CancelAsync();
        await WorkflowSessionService.ResetAsync();
        workflowStarted = false;
        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<OrchestrationWorkflowStartInputValue> BuildStartInputs()
    {
        if (currentWorkflow is null)
        {
            return [];
        }

        List<OrchestrationWorkflowStartInputValue> inputs = [];

        foreach (var definition in currentWorkflow.StartInputs)
        {
            var value = GetStartInputValue(definition.Key);
            if (string.IsNullOrWhiteSpace(value))
            {
                continue;
            }

            inputs.Add(new OrchestrationWorkflowStartInputValue
            {
                Key = definition.Key,
                Value = value
            });
        }

        return inputs;
    }

    private bool TryResolveEffectiveModel(out ServerModel model) =>
        ModelSelectionHelper.TryGetEffectiveModel(
            new ServerModelSelection(null, null),
            UiModelSelection,
            out model);

    private async Task<bool> CompileWorkflowSourceAsync(bool expandEditorOnError)
    {
        workflowCompileError = null;

        try
        {
            var compiled = await WorkflowCompiler.CompileAsync(workflowSourceCode);
            var workflow = compiled.Workflow;
            if (workflow is null)
            {
                compiledWorkflow = null;
                workflowCompileError = "Workflow source did not produce an orchestration definition.";
                return false;
            }

            var materializedWorkflow = await WorkflowAgentDraftMaterializer.MaterializeAsync(workflow);
            compiledWorkflow = new CompiledWorkflowDefinition
            {
                Kind = compiled.Kind,
                WorkflowId = materializedWorkflow.Id,
                DisplayName = materializedWorkflow.DisplayName,
                Description = materializedWorkflow.Description,
                Workflow = materializedWorkflow,
                HandoffWorkflow = materializedWorkflow as AgentWorkflowDefinition,
                SequentialWorkflow = materializedWorkflow as SequentialWorkflowDefinition,
                ConcurrentWorkflow = materializedWorkflow as ConcurrentWorkflowDefinition,
                GroupChatWorkflow = materializedWorkflow as GroupChatWorkflowDefinition
            };
            SynchronizeStartInputValues(materializedWorkflow);
            return true;
        }
        catch (WorkflowCompilationException ex)
        {
            compiledWorkflow = null;
            workflowCompileError = ex.Message;
        }
        catch (Exception ex)
        {
            compiledWorkflow = null;
            workflowCompileError = ex.Message;
        }

        if (expandEditorOnError)
        {
            isWorkflowSourceExpanded = true;
        }

        return false;
    }

    private async Task RefreshSavedWorkflowsAsync()
    {
        savedWorkflows = (await WorkflowDefinitionService.GetAllAsync()).ToList();
        ApplyWorkflowFilter();
    }

    private void ApplyWorkflowFilter()
    {
        var filter = workflowSearchText.Trim();
        if (string.IsNullOrWhiteSpace(filter))
        {
            filteredSavedWorkflows = savedWorkflows.ToList();
            return;
        }

        filteredSavedWorkflows = savedWorkflows
            .Where(workflow =>
                workflow.DisplayName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                workflow.WorkflowId.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                workflow.Description.Contains(filter, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void SynchronizeStartInputValues(IOrchestrationWorkflowDefinition workflow)
    {
        var validKeys = workflow.StartInputs
            .Select(static input => input.Key)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        foreach (var existingKey in startInputValues.Keys.Except(validKeys, StringComparer.OrdinalIgnoreCase).ToList())
        {
            startInputValues.Remove(existingKey);
        }

        foreach (var input in workflow.StartInputs)
        {
            if (!startInputValues.ContainsKey(input.Key))
            {
                startInputValues[input.Key] = input.DefaultValue;
            }
        }
    }

    private string? GetStartInputValue(string key) =>
        startInputValues.TryGetValue(key, out var value) ? value : null;

    private void SetStartInputValue(string key, string? value)
    {
        startInputValues[key] = string.IsNullOrWhiteSpace(value) ? null : value;
    }

    private bool GetBooleanStartInputValue(WorkflowStartInputDefinition input) =>
        bool.TryParse(GetStartInputValue(input.Key) ?? input.DefaultValue, out var value) && value;

    private void SetBooleanStartInputValue(string key, bool value)
    {
        startInputValues[key] = value
            ? bool.TrueString.ToLowerInvariant()
            : bool.FalseString.ToLowerInvariant();
    }

    private string GetStartInputLabel(WorkflowStartInputDefinition input) =>
        input.IsRequired
            ? $"{input.DisplayName} *"
            : input.DisplayName;

    private bool IsStartInputSatisfied(WorkflowStartInputDefinition input)
    {
        if (!input.IsRequired)
        {
            return true;
        }

        if (input.Kind == WorkflowStartInputKind.Boolean)
        {
            return true;
        }

        var value = GetStartInputValue(input.Key) ?? input.DefaultValue;
        return !string.IsNullOrWhiteSpace(value);
    }

    private void ToggleWorkflowSourceEditor()
    {
        isWorkflowSourceExpanded = !isWorkflowSourceExpanded;
    }

    private void OnWorkflowSourceChanged(string? value)
    {
        workflowSourceCode = value ?? string.Empty;
        workflowSourceDirty = true;
        workflowCompileError = null;
        compiledWorkflow = null;
    }

    private async Task OpenLoadWorkflowDialogAsync()
    {
        await RefreshSavedWorkflowsAsync();
        workflowSearchText = string.Empty;
        ApplyWorkflowFilter();
        selectedWorkflowIdToLoad = currentSavedWorkflowId;
        showLoadWorkflowDialog = true;
    }

    private void CloseLoadWorkflowDialog()
    {
        showLoadWorkflowDialog = false;
    }

    private void OnWorkflowSearchChanged(string? value)
    {
        workflowSearchText = value?.Trim() ?? string.Empty;
        ApplyWorkflowFilter();
    }

    private void SelectWorkflowToLoad(Guid workflowId)
    {
        selectedWorkflowIdToLoad = workflowId;
    }

    private async Task ConfirmLoadWorkflowAsync()
    {
        if (!selectedWorkflowIdToLoad.HasValue)
        {
            return;
        }

        var savedWorkflow = savedWorkflows.FirstOrDefault(workflow => workflow.Id == selectedWorkflowIdToLoad.Value);
        if (savedWorkflow is null)
        {
            Snackbar.Add("Selected workflow was not found.", Severity.Warning);
            return;
        }

        workflowSourceCode = savedWorkflow.SourceCode;
        currentSavedWorkflow = savedWorkflow;
        currentSavedWorkflowId = savedWorkflow.Id;
        workflowSourceDirty = false;
        workflowCompileError = null;
        isWorkflowSourceExpanded = false;
        showLoadWorkflowDialog = false;
        await CompileWorkflowSourceAsync(expandEditorOnError: true);
    }

    private async Task SendChatMessageAsync((string text, IReadOnlyList<AppChatMessageFile> files) messageData)
    {
        if (string.IsNullOrWhiteSpace(messageData.text) || isLlmAnswering || !workflowStarted)
        {
            return;
        }

        await WorkflowSessionService.SendAsync(messageData.text.Trim(), messageData.files);
        await ScrollToBottomAsync();
    }

