@using ChatClient.Domain.Models
@using MudBlazor

<MudCollapse Expanded="@Expanded" ExpandedChanged="@(v => ExpandedChanged.InvokeAsync(v))">
    <MudCard Outlined="true" Class="pa-4">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <MudCardHeader Class="pb-2">
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@Title</MudText>
                </CardHeaderContent>
            </MudCardHeader>
        }

        <MudCardContent Class="pt-0">
            @if (ShowAutoSelectCount)
            {
                <MudNumericField T="int"
                                 Value="@AutoSelectCount"
                                 ValueChanged="OnAutoSelectCountChanged"
                                 Class="mt-2"
                                 Min="0"
                                 Max="10"
                                 Variant="Variant.Outlined"
                                 Label="@AutoSelectLabel"
                                 Immediate="true"
                                 Style="max-width: 220px;"
                                 title="@AutoSelectHelperText" />
            }

            @if (AvailableFunctions.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                    @EmptyText
                </MudAlert>
            }
            else
            {
                <MudExpansionPanels Class="mt-2">
                    @foreach (var group in AvailableFunctions.GroupBy(f => f.ServerName))
                    {
                        <MudExpansionPanel Text="@group.Key">
                            <MudStack Spacing="1">
                                <MudCheckBox T="bool"
                                             Label="Select All"
                                             ValueChanged="@(async (bool v) => await OnServerToggled(group.Key, v))"
                                             Value="@serverSelections.GetValueOrDefault(group.Key)"
                                             Dense="true"
                                             Disabled="@SelectionDisabled" />

                                @foreach (var fn in group)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="ml-4">
                                        <MudCheckBox T="bool"
                                                     ValueChanged="@(async (bool v) => await OnFunctionToggled(fn, v))"
                                                     Value="@internalSelectedFunctions.Contains(fn.Name)"
                                                     Dense="true"
                                                     Disabled="@SelectionDisabled" />
                                        <div style="flex-grow:1">
                                            <MudText Typo="Typo.body2" Class="mb-0">
                                                <strong>@fn.DisplayName</strong> - @fn.Description
                                            </MudText>
                                        </div>
                                    </MudStack>
                                }
                            </MudStack>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }

            @if (ShowAutoSelectCount && !string.IsNullOrWhiteSpace(AutoSelectHelperText))
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                    @AutoSelectHelperText
                </MudText>
            }
        </MudCardContent>
    </MudCard>
</MudCollapse>

@code {
    [Parameter] public List<FunctionInfo> AvailableFunctions { get; set; } = [];
    [Parameter] public List<string> SelectedFunctions { get; set; } = [];
    [Parameter] public EventCallback<List<string>> SelectedFunctionsChanged { get; set; }
    [Parameter] public bool Expanded { get; set; } = true;
    [Parameter] public EventCallback<bool> ExpandedChanged { get; set; }
    [Parameter] public int AutoSelectCount { get; set; }
    [Parameter] public EventCallback<int> AutoSelectCountChanged { get; set; }
    [Parameter] public bool ShowAutoSelectCount { get; set; } = true;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Title { get; set; } = "Function Settings";
    [Parameter] public string AutoSelectLabel { get; set; } = "Auto-select count";
    [Parameter] public string AutoSelectHelperText { get; set; } = "Set auto-select count to 0 to choose functions manually. It is not recommended to select more than 5 functions.";
    [Parameter] public string EmptyText { get; set; } = "No MCP functions available.";

    private HashSet<string> internalSelectedFunctions = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, bool> serverSelections = new(StringComparer.OrdinalIgnoreCase);

    private bool SelectionDisabled =>
        Disabled || (ShowAutoSelectCount && AutoSelectCount > 0);

    protected override void OnParametersSet()
    {
        internalSelectedFunctions = new HashSet<string>(SelectedFunctions, StringComparer.OrdinalIgnoreCase);
        serverSelections = AvailableFunctions
            .GroupBy(f => f.ServerName)
            .ToDictionary(g => g.Key, g => g.All(f => internalSelectedFunctions.Contains(f.Name)), StringComparer.OrdinalIgnoreCase);
    }

    private async Task OnServerToggled(string serverName, bool isChecked)
    {
        var serverFunctions = AvailableFunctions
            .Where(f => string.Equals(f.ServerName, serverName, StringComparison.OrdinalIgnoreCase))
            .Select(f => f.Name);

        foreach (var fn in serverFunctions)
            UpdateFunctionSelection(fn, isChecked);

        serverSelections[serverName] = isChecked;
        await NotifySelectionChanged();
    }

    private async Task OnFunctionToggled(FunctionInfo fn, bool isChecked)
    {
        UpdateFunctionSelection(fn.Name, isChecked);
        UpdateServerSelection(fn.ServerName);
        await NotifySelectionChanged();
    }

    private void UpdateFunctionSelection(string functionName, bool isSelected)
    {
        if (isSelected)
            internalSelectedFunctions.Add(functionName);
        else
            internalSelectedFunctions.Remove(functionName);
    }

    private void UpdateServerSelection(string serverName)
    {
        serverSelections[serverName] = AvailableFunctions
            .Where(f => string.Equals(f.ServerName, serverName, StringComparison.OrdinalIgnoreCase))
            .All(f => internalSelectedFunctions.Contains(f.Name));
    }

    private async Task NotifySelectionChanged()
    {
        await SelectedFunctionsChanged.InvokeAsync(
            AvailableFunctions
                .Where(f => internalSelectedFunctions.Contains(f.Name))
                .Select(f => f.Name)
                .ToList());
    }

    private async Task OnAutoSelectCountChanged(int value)
    {
        AutoSelectCount = value;
        StateHasChanged();
        await AutoSelectCountChanged.InvokeAsync(value);
    }
}
