@page "/multi-agent-chat"
@page "/multi-agent-chat-agentic"
@using System.Collections.Generic
@using System.Collections.Immutable
@using System.Linq
@using ChatClient.Api.Client.Components
@using ChatClient.Application.Helpers
@using ChatClient.Application.Services.Agentic
@using ChatClient.Domain.Models
@using ChatClient.Domain.Models.ChatStrategies
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.AI
@using MudBlazor
@inherits AgenticChatPageBase

<PageTitle>Multi-Agentic Chat</PageTitle>

<OllamaCheck>
    <MudStack Class="chat-container">
    @if (isLoadingInitialData)
    {
        <MudOverlay Visible="true" DarkBackground="true" Absolute="true">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="mt-2">Loading chat...</MudText>
        </MudOverlay>
    }
    else if (!chatStarted)
    {
        <MudCard Class="ma-auto" Style="max-width: 600px; width: 100%;">
            <MudCardContent>
                @if (agents.Count == 0)
                {
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    <MudText>Loading agents...</MudText>
                }
                else
                {
                    <MudStack Spacing="3">
                        <MudSelect T="AgentDescription" Label="Select Agents" SelectedValues="selectedAgents" SelectedValuesChanged="OnSelectedAgentsChanged" MultiSelection="true" Variant="Variant.Outlined" FullWidth="true" Dense="true">
                            @foreach (var agent in agents)
                            {
                                <MudSelectItem Value="@agent">@agent.AgentName</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="string"
                                   Label="Chat Strategy"
                                   Value="chatStrategyName"
                                   ValueChanged="OnChatStrategyChanged"
                                   Variant="Variant.Outlined"
                                   FullWidth="true"
                                   Dense="true">
                            @foreach (var strategy in chatStrategies)
                            {
                                <MudSelectItem Value="@strategy">@strategy</MudSelectItem>
                            }
                        </MudSelect>

                        @if (editorType is not null)
                        {
                            <DynamicComponent Type="editorType" Parameters="editorParams" />
                        }
                        else
                        {
                            <em>Editor for '@chatStrategyOptions.GetType().Name' not found</em>
                        }

                        @if (selectedAgentDrafts.Count > 0)
                        {
                            @foreach (var agentDraft in selectedAgentDrafts)
                            {
                                <MudPaper Outlined="true" Class="pa-3">
                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.subtitle2">@agentDraft.AgentName</MudText>
                                        <McpServerBindingsEditor Bindings="@agentDraft.McpServerBindings"
                                                                 BindingsChanged="@(bindings => OnDraftMcpBindingsChanged(agentDraft, bindings))"
                                                                 Title=""
                                                                 Description=""
                                                                 EmptyBindingsText="" />
                                    </MudStack>
                                </MudPaper>
                            }
                        }

                        <MudTooltip Text="Select server and model" Disabled="@CanStartChat">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       Size="Size.Medium"
                                       Disabled="@(!CanStartChat)"
                                       OnClick="StartChat">
                                Start Chat
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <AgenticChatSession @ref="chatSessionView"
                            Messages="ChatViewModelService.Messages"
                            Agents="agents"
                            IsLlmAnswering="isLLMAnswering"
                            UserName="userSettings.UserName"
                            IsMultiAgent="true"
                            OnSaveChat="SaveCurrentChat"
                            OnSendMessage="SendChatMessageAsync"
                            OnStop="Cancel"
                            OnDeleteMessage="DeleteMessage"
                            OnCopyVisibleMessage="CopyVisibleMessage"
                            OnCopyRawMessage="CopyRawMessage"
                            OnCopyChat="CopyChatAsync" />
    }
    </MudStack>
</OllamaCheck>

@code {
    private const string RoundRobinChatStrategy = "RoundRobin";
    private const string RoundRobinSummaryChatStrategy = "RoundRobinWithSummary";

    private List<AgentDescription> agents = new();
    private List<AgentDescription> selectedAgents { get; set; } = new();
    private List<AgentDescription> selectedAgentDrafts { get; set; } = new();
    private List<string> chatStrategies = new();
    private IChatStrategyOptions chatStrategyOptions = new RoundRobinChatStrategyOptions();
    private string chatStrategyName = RoundRobinChatStrategy;
    private string? currentModelName;

    [CascadingParameter(Name = "UiModelSelection")]
    public ServerModelSelection UiModelSelection { get; set; } = new(null, null);

    private bool CanStartChat =>
        selectedAgentDrafts.Count > 0 &&
        selectedAgentDrafts.All(agent => TryResolveEffectiveModel(agent, out _));

    private static readonly IReadOnlyDictionary<Type, Type> Editors = new Dictionary<Type, Type>
    {
        { typeof(RoundRobinChatStrategyOptions), typeof(RoundRobinChatStrategyParameters) },
        { typeof(RoundRobinSummaryChatStrategyOptions), typeof(RoundRobinSummaryChatStrategyParameters) },
    }.ToImmutableDictionary();

    private Type? editorType => Editors.TryGetValue(chatStrategyOptions.GetType(), out var editor) ? editor : null;

    private Dictionary<string, object?> editorParams =>
        new() { ["Context"] = new ChatStrategyEditorContext(chatStrategyOptions, agents) };

    protected override string ElicitationLogContext => "multi-agent chat";

    protected override Task OnBeforeInitialLoadAsync()
    {
        chatStrategies = new() { RoundRobinChatStrategy, RoundRobinSummaryChatStrategy };
        return Task.CompletedTask;
    }

    protected override async Task LoadAgentsAsync()
    {
        agents = (await AgentService.GetAllAsync()).ToList();
        selectedAgents = [];
        selectedAgentDrafts = [];
    }

    protected override async Task LoadUserSettingsAsync()
    {
        userSettings = await UserSettingsService.GetSettingsAsync();
        chatStrategyName = string.IsNullOrWhiteSpace(userSettings.ChatStrategyName)
            ? RoundRobinChatStrategy
            : userSettings.ChatStrategyName;

        chatStrategyOptions = chatStrategyName switch
        {
            RoundRobinChatStrategy => new RoundRobinChatStrategyOptions(),
            RoundRobinSummaryChatStrategy => new RoundRobinSummaryChatStrategyOptions(),
            _ => new RoundRobinChatStrategyOptions()
        };

        if (userSettings.MultiAgentSelectedAgents?.Count > 0)
        {
            var persistedAgents = userSettings.MultiAgentSelectedAgents
                .Select(name => agents.FirstOrDefault(agent => agent.AgentName == name))
                .Where(agent => agent is not null)
                .Select(agent => agent!)
                .ToList();

            UpdateSelectedAgents(persistedAgents);
        }
    }

    protected override async Task LoadSavedChatAsync(Guid savedChatId)
    {
        var saved = await SavedChatService.GetByIdAsync(savedChatId);
        if (saved is null)
        {
            Snackbar.Add("Saved chat not found", Severity.Error);
            return;
        }

        var assistantIds = saved.Participants
            .Where(participant => participant.Role == ChatRole.Assistant)
            .Select(participant => participant.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var savedAgents = agents
            .Where(agent => assistantIds.Contains(agent.AgentId))
            .ToList();

        if (savedAgents.Count == 0)
        {
            Snackbar.Add("Agents for saved chat not found", Severity.Error);
            return;
        }

        UpdateSelectedAgents(savedAgents);

        var runtimeAgents = BuildRuntimeAgents(selectedAgentDrafts);
        currentModelName = runtimeAgents[0].Model.ModelName;

        var chatConfiguration = new AppChatConfiguration(currentModelName, []);
        var savedMessages = saved.Messages
            .Select(message =>
            {
                var chatMessage = new AppChatMessage(message.Content, message.MsgDateTime, message.Role, agentName: message.AgentName);
                chatMessage.Id = message.Id;
                return (IAppChatMessage)chatMessage;
            })
            .ToList();

        var request = new ChatEngineSessionStartRequest
        {
            Configuration = chatConfiguration,
            Agents = runtimeAgents,
            History = savedMessages,
            ChatStrategyName = chatStrategyName,
            ChatStrategyOptions = chatStrategyOptions
        };

        try
        {
            await ChatService.StartAsync(request);
            chatStarted = true;
            lastSavedChatId = savedChatId;
            lastSavedChatTitle = saved.Title;
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void OnChatStrategyChanged(string name)
    {
        chatStrategyName = name;
        chatStrategyOptions = name switch
        {
            RoundRobinChatStrategy => new RoundRobinChatStrategyOptions(),
            RoundRobinSummaryChatStrategy => new RoundRobinSummaryChatStrategyOptions(),
            _ => new RoundRobinChatStrategyOptions()
        };
    }

    private async Task StartChat()
    {
        if (!CanStartChat)
            return;

        userSettings.ChatStrategyName = chatStrategyName;
        userSettings.MultiAgentSelectedAgents = selectedAgentDrafts.Select(agent => agent.AgentName).ToList();
        await UserSettingsService.SaveSettingsAsync(userSettings);

        var runtimeAgents = BuildRuntimeAgents(selectedAgentDrafts);
        currentModelName = runtimeAgents[0].Model.ModelName;

        var chatConfiguration = new AppChatConfiguration(currentModelName, []);
        var request = new ChatEngineSessionStartRequest
        {
            Configuration = chatConfiguration,
            Agents = runtimeAgents,
            ChatStrategyName = chatStrategyName,
            ChatStrategyOptions = chatStrategyOptions
        };

        try
        {
            await ChatService.StartAsync(request);
            chatStarted = true;
            StateHasChanged();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private Task OnSelectedAgentsChanged(IEnumerable<AgentDescription> agents)
    {
        UpdateSelectedAgents(agents);
        return Task.CompletedTask;
    }

    private Task OnDraftMcpBindingsChanged(AgentDescription agentDraft, List<McpServerSessionBinding> bindings)
    {
        agentDraft.McpServerBindings = bindings
            .Select(static binding => binding.Clone())
            .ToList();

        return Task.CompletedTask;
    }

    private bool TryResolveEffectiveModel(AgentDescription agent, out ServerModel model) =>
        ModelSelectionHelper.TryGetEffectiveModel(
            new ServerModelSelection(agent.LlmId, agent.ModelName),
            UiModelSelection,
            out model);

    private ServerModel GetEffectiveModel(AgentDescription agent) =>
        ModelSelectionHelper.GetEffectiveModel(
            new ServerModelSelection(agent.LlmId, agent.ModelName),
            UiModelSelection,
            $"Agent: {agent.AgentName}",
            Logger);

    private List<ResolvedChatAgent> BuildRuntimeAgents(IReadOnlyCollection<AgentDescription> drafts) =>
        drafts
            .Select(agent =>
            {
                var effectiveModel = GetEffectiveModel(agent);
                return AgentDescriptionFactory.CreateResolved(agent, effectiveModel);
            })
            .ToList();

    private void UpdateSelectedAgents(IEnumerable<AgentDescription> selected)
    {
        var selectedList = selected.ToList();
        var existingDrafts = selectedAgentDrafts.ToDictionary(static agent => agent.Id);

        selectedAgents = selectedList;
        selectedAgentDrafts = selectedList
            .Select(agent => existingDrafts.TryGetValue(agent.Id, out var existingDraft)
                ? existingDraft
                : AgentDescriptionFactory.CreateDraft(agent))
            .ToList();
    }
}
