@page "/chat-planning"
@using ChatClient.Api.Client.Components
@using ChatClient.Api.Client.Components.Planning
@using ChatClient.Api.PlanningRuntime.Common
@using ChatClient.Api.PlanningRuntime.Execution
@using ChatClient.Api.PlanningRuntime.Host
@using ChatClient.Api.PlanningRuntime.Planning
@using ChatClient.Api.Services
@using ChatClient.Application.Services.Agentic
@using ChatClient.Domain.Models
@using MudBlazor
@implements IDisposable
@inject IPlanningSessionService PlanningSessionService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IMcpUserInteractionService McpUserInteractionService
@inject IAppToolCatalog AppToolCatalog
@inject ILogger<ChatPlanning> Logger

<PageTitle>Planning Chat</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-4" Outlined="true">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">Planning Chat</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Enter a user request, configure the planner draft MCP bindings, and inspect the generated plan, execution trace, and replanning logic.
            </MudText>

            @if (!HasModelSelection && !UsingPreviewScenario)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Select a server and model in the top bar before starting a planning run.
                </MudAlert>
            }

            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="planning-preview-toolbar">
                <MudSelect T="string"
                           Label="Plan Preview Data"
                           Value="@selectedPreviewScenarioId"
                           ValueChanged="OnPreviewScenarioChanged"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="min-width: 260px;">
                    <MudSelectItem Value="@PlanningPreviewScenarios.LiveScenarioId">Live planner</MudSelectItem>
                    @foreach (var scenario in PlanningPreviewScenarios.All)
                    {
                        <MudSelectItem Value="@scenario.Id">@scenario.DisplayName</MudSelectItem>
                    }
                </MudSelect>

                @if (ActivePreviewScenario is not null)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary planning-preview-description">
                        @ActivePreviewScenario.Description
                    </MudText>
                }
            </MudStack>

            @if (UsingPreviewScenario)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Preview mode is active. The page shows local mock planning data and disables live execution controls.
                </MudAlert>
            }

            <MudTextField T="string"
                          Label="User request"
                          Value="@DisplayedUserQuery"
                          ValueChanged="OnUserQueryChanged"
                          Lines="4"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Disabled="@UsingPreviewScenario" />

            <McpServerBindingsEditor Bindings="@plannerDraft.McpServerBindings"
                                     BindingsChanged="OnPlannerMcpBindingsChanged"
                                     Title=""
                                     Description=""
                                     EmptyBindingsText=""
                                     Class="mt-2"
                                     Disabled="@(UsingPreviewScenario || PlanningSessionService.State.IsRunning)" />

            @if (!UsingPreviewScenario)
            {
                @if (availablePlanningFunctions.Count == 0)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        No MCP tools selected.
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @GetPlanningToolSummary()
                    </MudText>
                }
            }

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@(!CanStart)"
                           OnClick="StartRunAsync">
                    Run
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           Disabled="@(!CanCancel)"
                           OnClick="CancelRunAsync">
                    Cancel
                </MudButton>
                <MudButton Variant="Variant.Text"
                           Disabled="@(!CanReset)"
                           OnClick="Reset">
                    Reset
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" lg="7">
            <PlanningGraph Plan="@CurrentPlan"
                           ActiveStepId="@CurrentActiveStepId"
                           SelectedStepId="@selectedStepId"
                           Events="@CurrentEvents"
                           AvailableTools="@CurrentAvailableTools"
                           FinalResult="@CurrentFinalResult"
                           SelectedStepIdChanged="OnSelectedStepChanged" />
        </MudItem>
        <MudItem xs="12" lg="5">
            <PlanningStepDetails Plan="@CurrentPlan"
                                 ActiveStepId="@CurrentActiveStepId"
                                 SelectedStepId="@selectedStepId"
                                 Events="@CurrentEvents"
                                 AvailableTools="@CurrentAvailableTools"
                                 FinalResult="@CurrentFinalResult" />
        </MudItem>
    </MudGrid>

    <PlanningReplanLog Events="CurrentEvents" LogLines="CurrentLogLines" />
</MudStack>

@code {
    private string userQuery = "Find two popular robot vacuum cleaners, compare their specs, and recommend which one is better.";
    private string selectedPreviewScenarioId = PlanningPreviewScenarios.LiveScenarioId;
    private string? selectedStepId;
    private string? selectedStepContextKey;

    private List<FunctionInfo> availablePlanningFunctions = [];
    private AgentDescription plannerDraft = AgentDescriptionFactory.CreateTransient("Planner", "planner");
    private IDisposable? elicitationHandlerRegistration;

    [CascadingParameter(Name = "UiModelSelection")]
    public ServerModelSelection UiModelSelection { get; set; } = new(null, null);

    private bool HasModelSelection =>
        UiModelSelection.ServerId.HasValue &&
        UiModelSelection.ServerId.Value != Guid.Empty &&
        !string.IsNullOrWhiteSpace(UiModelSelection.ModelName);

    private PlanningPreviewScenario? ActivePreviewScenario =>
        PlanningPreviewScenarios.Get(selectedPreviewScenarioId);

    private bool UsingPreviewScenario => ActivePreviewScenario is not null;

    private bool HasConfiguredPlannerBindings =>
        plannerDraft.McpServerBindings.Any(static binding => binding.Enabled && binding.HasIdentity);

    private string DisplayedUserQuery =>
        ActivePreviewScenario?.UserQuery ?? userQuery;

    private PlanDefinition? CurrentPlan =>
        ActivePreviewScenario?.Plan ?? PlanningSessionService.State.CurrentPlan;

    private string? CurrentActiveStepId =>
        ActivePreviewScenario?.ActiveStepId ?? PlanningSessionService.State.ActiveStepId;

    private IReadOnlyList<PlanRunEvent> CurrentEvents =>
        ActivePreviewScenario?.Events ?? GetStateEventsSnapshot();

    private IReadOnlyList<PlanningToolOption> CurrentAvailableTools =>
        ActivePreviewScenario?.AvailableTools ?? GetStateAvailableToolsSnapshot();

    private IReadOnlyList<string> CurrentLogLines =>
        ActivePreviewScenario?.LogLines ?? GetStateLogLinesSnapshot();

    private ResultEnvelope<JsonElement?>? CurrentFinalResult =>
        ActivePreviewScenario?.FinalResult ?? PlanningSessionService.State.FinalResult;

    private string CurrentGraphKey
    {
        get
        {
            var currentEvents = CurrentEvents;
            var currentAvailableTools = CurrentAvailableTools;
            return BuildGraphKey(CurrentPlan, currentEvents, currentAvailableTools, CurrentFinalResult);
        }
    }

    private bool CanStart =>
        !UsingPreviewScenario &&
        HasModelSelection &&
        !PlanningSessionService.State.IsRunning &&
        !string.IsNullOrWhiteSpace(userQuery) &&
        availablePlanningFunctions.Count > 0;

    private bool CanCancel =>
        !UsingPreviewScenario && PlanningSessionService.State.IsRunning;

    private bool CanReset =>
        UsingPreviewScenario ||
        PlanningSessionService.State.IsRunning ||
        PlanningSessionService.State.CurrentPlan is not null ||
        PlanningSessionService.State.FinalResult is not null ||
        selectedStepId is not null;

    protected override async Task OnInitializedAsync()
    {
        elicitationHandlerRegistration = McpUserInteractionService.RegisterElicitationHandler(
            McpInteractionScope.Planning,
            HandleElicitationAsync);
        await RefreshToolSelectionsAsync();
        PlanningSessionService.StateChanged += OnStateChanged;
        SyncSelectedStepId(CurrentPlan, CurrentActiveStepId, CurrentFinalResult);
    }

    private async Task StartRunAsync()
    {
        if (UsingPreviewScenario)
        {
            return;
        }

        if (!HasModelSelection)
        {
            Snackbar.Add("Select a server and model first.", Severity.Warning);
            return;
        }

        var plannerModel = new ServerModel(UiModelSelection.ServerId!.Value, UiModelSelection.ModelName!);
        await PlanningSessionService.StartAsync(new PlanningRunRequest
        {
            Planner = AgentDescriptionFactory.CreateResolved(plannerDraft, plannerModel),
            UserQuery = userQuery
        });
    }

    private Task CancelRunAsync() =>
        CanCancel
            ? PlanningSessionService.CancelAsync()
            : Task.CompletedTask;

    private void Reset()
    {
        if (!UsingPreviewScenario)
        {
            PlanningSessionService.Reset();
        }

        SyncSelectedStepId(CurrentPlan, CurrentActiveStepId, CurrentFinalResult, forceReset: true);
    }

    private Task OnSelectedStepChanged(string stepId)
    {
        selectedStepId = stepId;
        selectedStepContextKey = CurrentGraphKey;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnUserQueryChanged(string? value)
    {
        userQuery = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnPreviewScenarioChanged(string? value)
    {
        selectedPreviewScenarioId = string.IsNullOrWhiteSpace(value)
            ? PlanningPreviewScenarios.LiveScenarioId
            : value;

        SyncSelectedStepId(CurrentPlan, CurrentActiveStepId, CurrentFinalResult, forceReset: true);
        return InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            SyncSelectedStepId(CurrentPlan, CurrentActiveStepId, CurrentFinalResult);
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        PlanningSessionService.StateChanged -= OnStateChanged;
        elicitationHandlerRegistration?.Dispose();
    }

    private IReadOnlyList<PlanRunEvent> GetStateEventsSnapshot()
    {
        lock (PlanningSessionService.State.Events)
        {
            return [.. PlanningSessionService.State.Events];
        }
    }

    private IReadOnlyList<string> GetStateLogLinesSnapshot()
    {
        lock (PlanningSessionService.State.LogLines)
        {
            return [.. PlanningSessionService.State.LogLines];
        }
    }

    private IReadOnlyList<PlanningToolOption> GetStateAvailableToolsSnapshot()
    {
        lock (PlanningSessionService.State.AvailableTools)
        {
            return [.. PlanningSessionService.State.AvailableTools];
        }
    }

    private void SyncSelectedStepId(
        PlanDefinition? plan,
        string? activeStepId,
        ResultEnvelope<JsonElement?>? finalResult,
        bool forceReset = false)
    {
        var currentEvents = CurrentEvents;
        var currentAvailableTools = CurrentAvailableTools;
        var contextKey = BuildGraphKey(plan, currentEvents, currentAvailableTools, finalResult);
        var validNodeIds = PlanningVirtualNodeProjection.BuildSelectionKeys(plan, currentEvents, currentAvailableTools, finalResult);

        if (validNodeIds.Count == 0)
        {
            selectedStepId = null;
            selectedStepContextKey = contextKey;
            return;
        }

        if (!forceReset &&
            string.Equals(selectedStepContextKey, contextKey, StringComparison.Ordinal) &&
            !string.IsNullOrWhiteSpace(selectedStepId) &&
            validNodeIds.Contains(selectedStepId))
        {
            return;
        }

        selectedStepId = PlanningVirtualNodeProjection.ResolveDefaultSelectionId(
            plan,
            currentEvents,
            currentAvailableTools,
            finalResult,
            activeStepId);
        selectedStepContextKey = contextKey;
    }

    private string BuildGraphKey(
        PlanDefinition? plan,
        IReadOnlyList<PlanRunEvent> events,
        IReadOnlyList<PlanningToolOption> availableTools,
        ResultEnvelope<JsonElement?>? finalResult)
    {
        var planStepIds = string.Join("|", plan?.Steps.Select(step => step.Id) ?? []);
        var virtualNodeKeys = string.Join("|", PlanningVirtualNodeProjection.Build(plan, events, availableTools, finalResult)
            .Select(node => $"{node.Id}:{node.StatusValue}"));

        return $"{selectedPreviewScenarioId}:{planStepIds}:{virtualNodeKeys}";
    }

    private async Task RefreshToolSelectionsAsync()
    {
        try
        {
            if (!HasConfiguredPlannerBindings)
            {
                availablePlanningFunctions = [];
                return;
            }

            var plannerBindings = plannerDraft.McpServerBindings;
            var requestContext = new McpClientRequestContext(plannerBindings);
            var availableTools = McpBindingToolSelectionResolver.FilterAvailableTools(
                plannerBindings,
                await AppToolCatalog.ListToolsAsync(requestContext));
            availablePlanningFunctions = availableTools
                .Select(static tool => new FunctionInfo
                {
                    Name = tool.QualifiedName,
                    ServerName = tool.ServerName,
                    DisplayName = tool.DisplayName,
                    Description = tool.Description
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load planning tools.");
            Snackbar.Add($"Failed to load planning tools: {ex.Message}", Severity.Warning);
        }
    }

    private async Task OnPlannerMcpBindingsChanged(List<McpServerSessionBinding> bindings)
    {
        plannerDraft.McpServerBindings = bindings
            .Select(static binding => binding.Clone())
            .ToList();
        await RefreshToolSelectionsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private string GetPlanningToolSummary()
    {
        return availablePlanningFunctions.Count switch
        {
            0 => "No MCP tools selected.",
            1 => "1 MCP tool selected.",
            _ => $"{availablePlanningFunctions.Count} MCP tools selected."
        };
    }

    private async Task<McpElicitationResponse> HandleElicitationAsync(
        McpElicitationPrompt prompt,
        CancellationToken cancellationToken)
    {
        try
        {
            cancellationToken.ThrowIfCancellationRequested();

            var parameters = new DialogParameters
            {
                ["Prompt"] = prompt
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                BackdropClick = false,
                CloseOnEscapeKey = true,
                CloseButton = true
            };

            IDialogReference? dialog = null;
            await InvokeAsync(async () =>
            {
                dialog = await DialogService.ShowAsync<McpElicitationDialog>(
                    $"MCP input: {prompt.ServerName}",
                    parameters,
                    options);
            });

            if (dialog is null)
                return McpElicitationResponse.Cancel;

            Logger.LogInformation(
                "Elicitation dialog opened in planning UI. Server: {ServerName}. Mode: {Mode}. Fields: {FieldCount}.",
                prompt.ServerName,
                prompt.Mode,
                prompt.Fields.Count);

            using var registration = cancellationToken.Register(() =>
            {
                _ = InvokeAsync(() => dialog.Close(DialogResult.Ok(McpElicitationResponse.Cancel)));
            });

            var result = await dialog.Result;
            if (result?.Canceled != false)
            {
                Logger.LogInformation(
                    "Elicitation dialog closed in planning UI with cancel. Server: {ServerName}.",
                    prompt.ServerName);
                return McpElicitationResponse.Cancel;
            }

            var response = result.Data as McpElicitationResponse ?? McpElicitationResponse.Cancel;
            Logger.LogInformation(
                "Elicitation dialog completed in planning UI. Server: {ServerName}. Action: {Action}.",
                prompt.ServerName,
                response.Action);
            return response;
        }
        catch (OperationCanceledException)
        {
            Logger.LogInformation(
                "Elicitation dialog canceled by token in planning UI. Server: {ServerName}.",
                prompt.ServerName);
            return McpElicitationResponse.Cancel;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to render elicitation dialog in planning UI.");
            Snackbar.Add($"Failed to handle MCP user prompt: {ex.Message}", Severity.Warning);
            return McpElicitationResponse.Cancel;
        }
    }
}
