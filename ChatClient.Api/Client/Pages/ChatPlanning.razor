@page "/chat-planning"
@using ChatClient.Api.Client.Components
@using ChatClient.Api.Client.Components.Planning
@using ChatClient.Api.PlanningRuntime.Common
@using ChatClient.Api.PlanningRuntime.Execution
@using ChatClient.Api.PlanningRuntime.Host
@using ChatClient.Api.PlanningRuntime.Shared
@using ChatClient.Api.Services
@using ChatClient.Application.Services.Agentic
@using ChatClient.Domain.Models
@using MudBlazor
@implements IDisposable
@inject IPlanningSessionService PlanningSessionService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IMcpUserInteractionService McpUserInteractionService
@inject IAppToolCatalog AppToolCatalog
@inject ILogger<ChatPlanning> Logger

<PageTitle>Planning Chat</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-4" Outlined="true">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">Planning Chat</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Run the production three-layer planning runtime and inspect the request brief, outline plan, low-level plan, runtime plan, diagnostics, and final result.
            </MudText>

            @if (!HasModelSelection)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Select a server and model in the top bar before starting a planning run.
                </MudAlert>
            }

            <MudTextField T="string"
                          Label="User request"
                          Value="@userQuery"
                          ValueChanged="OnUserQueryChanged"
                          Lines="4"
                          Variant="Variant.Outlined"
                          Immediate="true" />

            <McpServerBindingsEditor Bindings="@plannerDraft.McpServerBindings"
                                     BindingsChanged="OnPlannerMcpBindingsChanged"
                                     Title=""
                                     Description=""
                                     EmptyBindingsText=""
                                     Class="mt-2"
                                     Disabled="@PlanningSessionService.State.IsRunning" />

            @if (availablePlanningFunctions.Count == 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    No MCP tools selected.
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @GetPlanningToolSummary()
                </MudText>
            }

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@(!CanStart)"
                           OnClick="StartRunAsync">
                    Run
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           Disabled="@(!CanCancel)"
                           OnClick="CancelRunAsync">
                    Cancel
                </MudButton>
                <MudButton Variant="Variant.Text"
                           Disabled="@(!CanReset)"
                           OnClick="Reset">
                    Reset
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <RuntimeWorkflowGraph Plan="@PlanningSessionService.State.RuntimePlan"
                          Events="@GetEvents()"
                          FinalResult="@PlanningSessionService.State.FinalResult"
                          ActiveRuntimeStepId="@PlanningSessionService.State.ActiveRuntimeStepId" />

    <MudGrid>
        <MudItem xs="12" lg="6">
            <PlanningArtifactCard Title="Request Brief" Content="@GetRequestBriefJson()" />
        </MudItem>
        <MudItem xs="12" lg="6">
            <PlanningArtifactCard Title="Outline Plan" Content="@GetOutlineJson()" RawContent="@PlanningSessionService.State.OutlineRawResponse" />
        </MudItem>
        <MudItem xs="12" lg="6">
            <PlanningArtifactCard Title="Low-Level Plan" Content="@GetLowLevelJson()" RawContent="@PlanningSessionService.State.LowLevelRawResponse" />
        </MudItem>
        <MudItem xs="12" lg="6">
            <PlanningArtifactCard Title="Runtime Plan" Content="@GetRuntimeJson()" />
        </MudItem>
        <MudItem xs="12" lg="6">
            <MudPaper Class="pa-4 h-100" Outlined="true">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Diagnostics</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Active runtime step: @(PlanningSessionService.State.ActiveRuntimeStepId ?? "<none>")
                    </MudText>
                    @if (CurrentIssues.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No diagnostics.</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="1">
                            @foreach (var issue in CurrentIssues)
                            {
                                <MudText Typo="Typo.body2"><strong>@issue.Layer</strong> (@issue.Code) @issue.Message</MudText>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" lg="6">
            <PlanningArtifactCard Title="Final Result" Content="@GetFinalResultJson()" />
        </MudItem>
        <MudItem xs="12">
            <PlanningArtifactCard Title="Execution Log" Content="@GetLogText()" />
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private string userQuery = "Find two popular robot vacuum cleaners, compare their specs, and recommend which one is better.";
    private List<FunctionInfo> availablePlanningFunctions = [];
    private AgentTemplateDefinition plannerDraft = AgentTemplateBuilder.New("Planner", "planner").Build();
    private IDisposable? elicitationHandlerRegistration;

    [CascadingParameter(Name = "UiModelSelection")]
    public ServerModelSelection UiModelSelection { get; set; } = new(null, null);

    private bool HasModelSelection =>
        UiModelSelection.ServerId.HasValue &&
        UiModelSelection.ServerId.Value != Guid.Empty &&
        !string.IsNullOrWhiteSpace(UiModelSelection.ModelName);

    private bool HasConfiguredPlannerBindings =>
        plannerDraft.McpServerBindings.Any(static binding => binding.Enabled && binding.HasIdentity);

    private bool CanStart =>
        HasModelSelection &&
        !PlanningSessionService.State.IsRunning &&
        !string.IsNullOrWhiteSpace(userQuery) &&
        availablePlanningFunctions.Count > 0;

    private bool CanCancel =>
        PlanningSessionService.State.IsRunning;

    private bool CanReset =>
        PlanningSessionService.State.IsRunning ||
        PlanningSessionService.State.RequestBrief is not null ||
        PlanningSessionService.State.OutlinePlan is not null ||
        PlanningSessionService.State.LowLevelPlan is not null ||
        PlanningSessionService.State.RuntimePlan is not null ||
        PlanningSessionService.State.FinalResult is not null;

    private IReadOnlyList<PlanningIssue> CurrentIssues
    {
        get
        {
            lock (PlanningSessionService.State.Issues)
            {
                return [.. PlanningSessionService.State.Issues];
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        elicitationHandlerRegistration = McpUserInteractionService.RegisterElicitationHandler(
            McpInteractionScope.Planning,
            HandleElicitationAsync);
        await RefreshToolSelectionsAsync();
        PlanningSessionService.StateChanged += OnStateChanged;
    }

    private async Task StartRunAsync()
    {
        if (!HasModelSelection)
        {
            Snackbar.Add("Select a server and model first.", Severity.Warning);
            return;
        }

        var plannerModel = new ServerModel(UiModelSelection.ServerId!.Value, UiModelSelection.ModelName!);
        await PlanningSessionService.StartAsync(new PlanningRunRequest
        {
            Planner = ResolvedChatAgentFactory.Resolve(plannerDraft, plannerModel),
            UserQuery = userQuery
        });
    }

    private Task CancelRunAsync() =>
        CanCancel
            ? PlanningSessionService.CancelAsync()
            : Task.CompletedTask;

    private void Reset()
    {
        PlanningSessionService.Reset();
    }

    private Task OnUserQueryChanged(string? value)
    {
        userQuery = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PlanningSessionService.StateChanged -= OnStateChanged;
        elicitationHandlerRegistration?.Dispose();
    }

    private async Task RefreshToolSelectionsAsync()
    {
        try
        {
            if (!HasConfiguredPlannerBindings)
            {
                availablePlanningFunctions = [];
                return;
            }

            var plannerBindings = plannerDraft.McpServerBindings;
            var requestContext = new McpClientRequestContext(plannerBindings);
            var availableTools = McpBindingToolSelectionResolver.FilterAvailableTools(
                plannerBindings,
                await AppToolCatalog.ListToolsAsync(requestContext));
            availablePlanningFunctions = availableTools
                .Select(static tool => new FunctionInfo
                {
                    Name = tool.QualifiedName,
                    ServerName = tool.ServerName,
                    DisplayName = tool.DisplayName,
                    Description = tool.Description
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load planning tools.");
            Snackbar.Add($"Failed to load planning tools: {ex.Message}", Severity.Warning);
        }
    }

    private async Task OnPlannerMcpBindingsChanged(List<McpServerSessionBinding> bindings)
    {
        plannerDraft.McpServerBindings = bindings
            .Select(static binding => binding.Clone())
            .ToList();
        await RefreshToolSelectionsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private string GetPlanningToolSummary()
    {
        return availablePlanningFunctions.Count switch
        {
            0 => "No MCP tools selected.",
            1 => "1 MCP tool selected.",
            _ => $"{availablePlanningFunctions.Count} MCP tools selected."
        };
    }

    private string GetRequestBriefJson() =>
        PlanningSessionService.State.RequestBrief is null
            ? string.Empty
            : PlanningNodeJson.SerializeIndented(PlanningSessionService.State.RequestBrief);

    private string GetOutlineJson() =>
        PlanningSessionService.State.OutlinePlan is null
            ? string.Empty
            : PlanningNodeJson.SerializeIndented(PlanningSessionService.State.OutlinePlan);

    private string GetLowLevelJson() =>
        PlanningSessionService.State.LowLevelPlan is null
            ? string.Empty
            : PlanningNodeJson.SerializeIndented(PlanningSessionService.State.LowLevelPlan);

    private string GetRuntimeJson() =>
        PlanningSessionService.State.RuntimePlan is null
            ? string.Empty
            : PlanningNodeJson.SerializeIndented(PlanningSessionService.State.RuntimePlan);

    private string GetFinalResultJson() =>
        PlanningSessionService.State.FinalResult is null
            ? string.Empty
            : PlanningSessionService.State.FinalResult.Ok
                ? PlanningJson.SerializeElementIndented(PlanningSessionService.State.FinalResult.Data)
                : PlanningJson.SerializeIndented(PlanningSessionService.State.FinalResult);

    private string GetLogText()
    {
        lock (PlanningSessionService.State.LogLines)
        {
            return string.Join(Environment.NewLine, PlanningSessionService.State.LogLines);
        }
    }

    private IReadOnlyList<PlanRunEvent> GetEvents()
    {
        lock (PlanningSessionService.State.Events)
        {
            return [.. PlanningSessionService.State.Events];
        }
    }

    private async Task<McpElicitationResponse> HandleElicitationAsync(
        McpElicitationPrompt prompt,
        CancellationToken cancellationToken)
    {
        try
        {
            cancellationToken.ThrowIfCancellationRequested();

            var parameters = new DialogParameters
            {
                ["Prompt"] = prompt
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                BackdropClick = false,
                CloseOnEscapeKey = true,
                CloseButton = true
            };

            IDialogReference? dialog = null;
            await InvokeAsync(async () =>
            {
                dialog = await DialogService.ShowAsync<McpElicitationDialog>(
                    $"MCP input: {prompt.ServerName}",
                    parameters,
                    options);
            });

            if (dialog is null)
                return McpElicitationResponse.Cancel;

            using var registration = cancellationToken.Register(() =>
            {
                _ = InvokeAsync(() => dialog.Close(DialogResult.Ok(McpElicitationResponse.Cancel)));
            });

            var result = await dialog.Result;
            if (result?.Canceled != false)
                return McpElicitationResponse.Cancel;

            return result.Data as McpElicitationResponse ?? McpElicitationResponse.Cancel;
        }
        catch (OperationCanceledException)
        {
            return McpElicitationResponse.Cancel;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to render elicitation dialog in planning UI.");
            Snackbar.Add($"Failed to handle MCP user prompt: {ex.Message}", Severity.Warning);
            return McpElicitationResponse.Cancel;
        }
    }
}
