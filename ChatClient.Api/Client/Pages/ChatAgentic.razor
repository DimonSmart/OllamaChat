@page "/"
@page "/chat"
@page "/chat-agentic"
@using System.Linq
@using ChatClient.Api.Client.Components
@using ChatClient.Application.Helpers
@using ChatClient.Application.Services.Agentic
@using ChatClient.Application.Services.AgentRuntime
@using ChatClient.Domain.Models
@using ChatClient.Domain.Models.ChatStrategies
@using Microsoft.AspNetCore.Components
@using MudBlazor
@inherits AgenticChatPageBase

<PageTitle>Agentic Chat with AI Assistant</PageTitle>

<OllamaCheck>
    <MudStack Class="chat-container">
    @if (isLoadingInitialData)
    {
        <MudOverlay Visible="true" DarkBackground="true" Absolute="true">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="mt-2">Loading chat...</MudText>
        </MudOverlay>
    }
    else if (!chatStarted)
    {
        <MudCard Class="ma-auto" Style="max-width: 600px; width: 100%;">
            <MudCardContent>
                @if (agents.Count == 0)
                {
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    <MudText>Loading agents...</MudText>
                }
                else
                {
                    <MudStack Spacing="3">
                        <MudSelect T="AgentDefinitionCatalogItem" Label="Select Agent or Workflow" Value="selectedCatalogItem" ValueChanged="OnCatalogItemChanged" Variant="Variant.Outlined" FullWidth="true" Dense="true">
                            @foreach (var item in catalogItems)
                            {
                                <MudSelectItem Value="@item">@item.Name (@GetKindLabel(item))</MudSelectItem>
                            }
                        </MudSelect>

                        @if (workflowInputDefinitions.Count > 0)
                        {
                            <MudStack Spacing="1">
                                @foreach (var input in workflowInputDefinitions)
                                {
                                    @switch (input.Kind)
                                    {
                                        case AgentInputDefinitionKind.Json:
                                        case AgentInputDefinitionKind.MarkdownDocument:
                                            <MudTextField T="string"
                                                          Label="@GetWorkflowInputLabel(input)"
                                                          HelperText="@input.Description"
                                                          Value="GetWorkflowInputValue(input)"
                                                          ValueChanged="value => SetWorkflowInputValue(input.Key, value)"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Placeholder="@input.Placeholder"
                                                          Lines="6"
                                                          AutoGrow="true" />
                                            break;

                                        case AgentInputDefinitionKind.Boolean:
                                            <MudSwitch T="bool"
                                                       Label="@GetWorkflowInputLabel(input)"
                                                       Value="GetBooleanWorkflowInputValue(input)"
                                                       ValueChanged="value => SetBooleanWorkflowInputValue(input.Key, value)"
                                                       Color="Color.Primary" />
                                            if (!string.IsNullOrWhiteSpace(input.Description))
                                            {
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@input.Description</MudText>
                                            }
                                            break;

                                        default:
                                            <MudTextField T="string"
                                                          Label="@GetWorkflowInputLabel(input)"
                                                          HelperText="@input.Description"
                                                          Value="GetWorkflowInputValue(input)"
                                                          ValueChanged="value => SetWorkflowInputValue(input.Key, value)"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Placeholder="@input.Placeholder"
                                                          InputType="@(input.Kind == AgentInputDefinitionKind.Number ? InputType.Number : InputType.Text)" />
                                            break;
                                    }
                                }
                            </MudStack>
                        }

                        @if (selectedAgentDraft is not null)
                        {
                            <McpServerBindingsEditor Bindings="@selectedAgentDraft.McpServerBindings"
                                                     BindingsChanged="OnDraftMcpBindingsChanged"
                                                     Title=""
                                                     Description=""
                                                     EmptyBindingsText="" />
                        }

                        <MudTooltip Text="Select server and model" Disabled="@CanStartChat">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       Size="Size.Medium"
                                       Disabled="@(!CanStartChat)"
                                       OnClick="StartChat">
                                Start Chat
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <AgenticChatSession @ref="chatSessionView"
                            Messages="ChatViewModelService.Messages"
                            Agents="ChatService.Agents"
                            IsLlmAnswering="isLLMAnswering"
                            UserName="userSettings.UserName"
                            OnSaveChat="SaveCurrentChat"
                            OnSendMessage="SendChatMessageAsync"
                            OnStop="Cancel"
                            OnDeleteMessage="DeleteMessage"
                            OnCopyChat="CopyChatAsync" />
    }
    </MudStack>
</OllamaCheck>

@code {
    private const string DefaultAgentName = "Default Assistant";

    private List<AgentDefinitionCatalogItem> catalogItems = new();
    private List<AgentTemplateDefinition> agents = new();
    private AgentDefinitionCatalogItem? selectedCatalogItem { get; set; }
    private AgentTemplateDefinition? selectedAgent { get; set; }
    private AgentTemplateDefinition? selectedAgentDraft;
    private IReadOnlyList<AgentInputDefinition> workflowInputDefinitions = [];
    private readonly Dictionary<string, string> workflowInputValues = new(StringComparer.OrdinalIgnoreCase);

    [Inject]
    private IAgentDefinitionCatalog AgentDefinitionCatalog { get; set; } = null!;

    [Inject]
    private IAgentInputDefinitionProvider AgentInputDefinitionProvider { get; set; } = null!;

    [CascadingParameter(Name = "UiModelSelection")]
    public ServerModelSelection UiModelSelection { get; set; } = new(null, null);

    private ServerModel? effectiveModel;
    private string CurrentModelName => effectiveModel!.ModelName;

    private bool CanStartChat =>
        selectedCatalogItem is { RuntimeKind: AgentRuntimeKind.WorkflowAgent } && AreRequiredWorkflowInputsSatisfied() ||
        selectedAgentDraft is not null && TryResolveEffectiveModel(selectedAgentDraft, out _);

    protected override bool CanSendMessages => selectedCatalogItem is not null;

    protected override async Task LoadAgentsAsync()
    {
        catalogItems = (await AgentDefinitionCatalog.GetAllAsync()).ToList();
        agents = (await AgentService.GetAllAsync()).ToList();
        var defaultAgent = AgentSelectionHelper.FindByName(agents, DefaultAgentName);
        var defaultItem = defaultAgent is null
            ? catalogItems.FirstOrDefault()
            : catalogItems.FirstOrDefault(item =>
                item.Reference.Kind == AgentDefinitionKind.SavedAgent &&
                string.Equals(item.Reference.Id, defaultAgent.Id.ToString("D"), StringComparison.OrdinalIgnoreCase));
        await SetSelectedCatalogItemAsync(defaultItem);
    }

    protected override async Task LoadUserSettingsAsync()
    {
        userSettings = await UserSettingsService.GetSettingsAsync();
    }

    protected override async Task LoadSavedChatAsync(Guid savedChatId)
    {
        var saved = await SavedChatService.GetByIdAsync(savedChatId);
        if (saved is null)
        {
            Snackbar.Add("Saved chat not found", Severity.Error);
            return;
        }

        var assistantIds = saved.Participants
            .Where(participant => participant.Role == AppChatRole.Assistant)
            .Select(participant => participant.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var agentsForChat = agents
            .Where(agent => assistantIds.Contains(agent.AgentId))
            .ToList();

        if (agentsForChat.Count == 0)
        {
            Snackbar.Add("Agents for saved chat not found", Severity.Error);
            return;
        }

        var selectedItem = catalogItems.FirstOrDefault(item =>
            item.Reference.Kind == AgentDefinitionKind.SavedAgent &&
            string.Equals(item.Reference.Id, agentsForChat[0].Id.ToString("D"), StringComparison.OrdinalIgnoreCase));
        await SetSelectedCatalogItemAsync(selectedItem);
        var selectedAgentForChat = selectedAgent
            ?? throw new InvalidOperationException("Selected agent is not initialized.");
        var selectedAgentDraftForChat = selectedAgentDraft
            ?? throw new InvalidOperationException("Selected agent draft is not initialized.");

        if (!TryResolveEffectiveModel(selectedAgentDraftForChat, out var resolvedModel))
            throw new InvalidOperationException($"Model selection for Agent: {selectedAgentDraftForChat.AgentName} is incomplete.");

        effectiveModel = resolvedModel;

        var runtimeAgents = agentsForChat
            .Select(agent =>
            {
                var template = agent.Id == selectedAgentForChat.Id
                    ? selectedAgentDraftForChat
                    : agent;
                var model = new ServerModel(template.LlmId!.Value, template.ModelName!);
                return ResolvedChatAgentFactory.Resolve(template, model);
            })
            .ToList();

        var chatConfiguration = new AppChatConfiguration(CurrentModelName, []);
        var savedMessages = saved.Messages
            .Select(message =>
            {
                var chatMessage = new AppChatMessage(
                    message.Content,
                    message.MsgDateTime,
                    message.Role,
                    agentId: message.AgentId,
                    agentName: message.AgentName);
                chatMessage.Id = message.Id;
                return (IAppChatMessage)chatMessage;
            })
            .ToList();

        var request = new ChatEngineSessionStartRequest
        {
            Configuration = chatConfiguration,
            Agents = runtimeAgents,
            RuntimeReference = new AgentDefinitionReference(
                AgentDefinitionKind.SavedAgent,
                selectedAgentForChat.Id.ToString("D")),
            RuntimeDefaultModel = effectiveModel,
            History = savedMessages,
            ChatStrategyName = "RoundRobin",
            ChatStrategyOptions = new RoundRobinChatStrategyOptions { Rounds = 1 }
        };

        try
        {
            await ChatService.StartAsync(request);
            chatStarted = true;
            lastSavedChatId = savedChatId;
            lastSavedChatTitle = saved.Title;
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task StartChat()
    {
        if (selectedCatalogItem is null)
            return;

        var runtimeAgents = new List<ResolvedChatAgent>();
        ServerModel? resolvedModel = null;

        if (selectedCatalogItem.Reference.Kind == AgentDefinitionKind.SavedAgent)
        {
            if (selectedAgentDraft is null)
                return;

            if (!TryResolveEffectiveModel(selectedAgentDraft, out resolvedModel))
                throw new InvalidOperationException($"Model selection for Agent: {selectedAgentDraft.AgentName} is incomplete.");

            effectiveModel = resolvedModel;
            runtimeAgents.Add(ResolvedChatAgentFactory.Resolve(selectedAgentDraft, effectiveModel));
        }
        else
        {
            resolvedModel = TryResolveUiModel(out var uiModel)
                ? uiModel
                : null;
            effectiveModel = resolvedModel;
            runtimeAgents.Add(new ResolvedChatAgent(
                new AgentExecutionSpec
                {
                    RuntimeAgentId = selectedCatalogItem.Reference.Id,
                    AgentName = selectedCatalogItem.Name,
                    Summary = selectedCatalogItem.Description,
                    ShortName = "WF"
                },
                resolvedModel ?? new ServerModel(Guid.Empty, string.Empty)));
        }

        var chatConfiguration = new AppChatConfiguration(resolvedModel?.ModelName ?? string.Empty, []);
        var request = new ChatEngineSessionStartRequest
        {
            Configuration = chatConfiguration,
            Agents = runtimeAgents,
            RuntimeReference = selectedCatalogItem.Reference,
            RuntimeDefaultModel = resolvedModel,
            RuntimeInputs = BuildWorkflowInputs(),
            ChatStrategyName = "RoundRobin",
            ChatStrategyOptions = new RoundRobinChatStrategyOptions { Rounds = 1 }
        };

        try
        {
            await ChatService.StartAsync(request);
            chatStarted = true;
            StateHasChanged();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OnCatalogItemChanged(AgentDefinitionCatalogItem? item)
    {
        await SetSelectedCatalogItemAsync(item);
    }

    private async Task SetSelectedCatalogItemAsync(AgentDefinitionCatalogItem? item)
    {
        selectedCatalogItem = item;
        workflowInputDefinitions = [];
        workflowInputValues.Clear();

        if (item?.Reference.Kind == AgentDefinitionKind.SavedAgent &&
            Guid.TryParse(item.Reference.Id, out var agentId))
        {
            SetSelectedAgent(agents.FirstOrDefault(agent => agent.Id == agentId));
            return;
        }

        SetSelectedAgent(null);
        if (item?.Reference.Kind == AgentDefinitionKind.SavedWorkflow)
        {
            workflowInputDefinitions = await AgentInputDefinitionProvider.GetInputsAsync(item.Reference);
            foreach (var input in workflowInputDefinitions)
            {
                if (input.DefaultValue is not null)
                {
                    workflowInputValues[input.Key] = input.DefaultValue;
                }
            }
        }
    }

    private void SetSelectedAgent(AgentTemplateDefinition? agent)
    {
        selectedAgent = agent;
        selectedAgentDraft = agent?.Clone();
    }

    private Task OnDraftMcpBindingsChanged(List<McpServerSessionBinding> bindings)
    {
        if (selectedAgentDraft is not null)
        {
            selectedAgentDraft.McpServerBindings = bindings
                .Select(static binding => binding.Clone())
                .ToList();
        }

        return Task.CompletedTask;
    }

    private bool TryResolveEffectiveModel(AgentTemplateDefinition agent, out ServerModel model) =>
        ModelSelectionHelper.TryGetEffectiveModel(
            new ServerModelSelection(agent.LlmId, agent.ModelName),
            UiModelSelection,
            out model);

    private bool TryResolveUiModel(out ServerModel model)
    {
        if (UiModelSelection.ServerId is { } serverId &&
            serverId != Guid.Empty &&
            !string.IsNullOrWhiteSpace(UiModelSelection.ModelName))
        {
            model = new ServerModel(serverId, UiModelSelection.ModelName);
            return true;
        }

        model = default!;
        return false;
    }

    private static string GetKindLabel(AgentDefinitionCatalogItem item) =>
        item.RuntimeKind == AgentRuntimeKind.WorkflowAgent ? "workflow" : "agent";

    private IReadOnlyDictionary<string, string> BuildWorkflowInputs() =>
        workflowInputDefinitions
            .Where(input => workflowInputValues.TryGetValue(input.Key, out var value) &&
                            (!string.IsNullOrWhiteSpace(value) || input.Kind == AgentInputDefinitionKind.Boolean))
            .ToDictionary(
                input => input.Key,
                input => workflowInputValues[input.Key],
                StringComparer.OrdinalIgnoreCase);

    private string GetWorkflowInputValue(AgentInputDefinition input) =>
        workflowInputValues.TryGetValue(input.Key, out var value)
            ? value
            : input.DefaultValue ?? string.Empty;

    private void SetWorkflowInputValue(string key, string? value)
    {
        workflowInputValues[key] = value ?? string.Empty;
    }

    private bool GetBooleanWorkflowInputValue(AgentInputDefinition input) =>
        bool.TryParse(GetWorkflowInputValue(input), out var value) && value;

    private void SetBooleanWorkflowInputValue(string key, bool value)
    {
        workflowInputValues[key] = value.ToString();
    }

    private static string GetWorkflowInputLabel(AgentInputDefinition input) =>
        input.IsRequired ? $"{input.DisplayName} *" : input.DisplayName;

    private bool AreRequiredWorkflowInputsSatisfied() =>
        workflowInputDefinitions
            .Where(static input => input.IsRequired && input.Kind != AgentInputDefinitionKind.Boolean)
            .All(input => !string.IsNullOrWhiteSpace(GetWorkflowInputValue(input)));
}
