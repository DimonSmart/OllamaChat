@page "/"
@page "/chat"
@page "/chat-agentic"
@using System.Linq
@using ChatClient.Api.Client.Components
@using ChatClient.Application.Helpers
@using ChatClient.Application.Services.Agentic
@using ChatClient.Application.Services.AgentRuntime
@using ChatClient.Domain.Models
@using ChatClient.Domain.Models.ChatStrategies
@using Microsoft.AspNetCore.Components
@using MudBlazor
@inherits AgenticChatPageBase

<PageTitle>Agentic Chat with AI Assistant</PageTitle>

<OllamaCheck>
    <MudStack Class="chat-container">
    @if (isLoadingInitialData)
    {
        <MudOverlay Visible="true" DarkBackground="true" Absolute="true">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="mt-2">Loading chat...</MudText>
        </MudOverlay>
    }
    else if (!chatStarted)
    {
        <MudCard Class="ma-auto" Style="max-width: 600px; width: 100%;">
            <MudCardContent>
                @if (catalogItems.Count == 0)
                {
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    <MudText>Loading agents...</MudText>
                }
                else
                {
                    <MudStack Spacing="3">
                        <MudSelect T="AgentDefinitionDescriptor" Label="Select Agent or Workflow" Value="selectedDefinition" ValueChanged="OnDefinitionChanged" Variant="Variant.Outlined" FullWidth="true" Dense="true">
                            @foreach (var item in catalogItems)
                            {
                                <MudSelectItem Value="@item">@item.Name (@GetKindLabel(item))</MudSelectItem>
                            }
                        </MudSelect>

                        @if (inputDefinitions.Count > 0)
                        {
                            <MudStack Spacing="1">
                                @foreach (var input in inputDefinitions)
                                {
                                    @switch (input.Kind)
                                    {
                                        case AgentInputDefinitionKind.Json:
                                        case AgentInputDefinitionKind.MarkdownDocument:
                                            <MudTextField T="string"
                                                          Label="@GetInputLabel(input)"
                                                          HelperText="@input.Description"
                                                          Value="GetInputValue(input)"
                                                          ValueChanged="value => SetInputValue(input.Key, value)"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Placeholder="@input.Placeholder"
                                                          Lines="6"
                                                          AutoGrow="true" />
                                            break;

                                        case AgentInputDefinitionKind.Boolean:
                                            <MudSwitch T="bool"
                                                       Label="@GetInputLabel(input)"
                                                       Value="GetBooleanInputValue(input)"
                                                       ValueChanged="value => SetBooleanInputValue(input.Key, value)"
                                                       Color="Color.Primary" />
                                            if (!string.IsNullOrWhiteSpace(input.Description))
                                            {
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@input.Description</MudText>
                                            }
                                            break;

                                        default:
                                            <MudTextField T="string"
                                                          Label="@GetInputLabel(input)"
                                                          HelperText="@input.Description"
                                                          Value="GetInputValue(input)"
                                                          ValueChanged="value => SetInputValue(input.Key, value)"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Placeholder="@input.Placeholder"
                                                          InputType="@(input.Kind == AgentInputDefinitionKind.Number ? InputType.Number : InputType.Text)" />
                                            break;
                                    }
                                }
                            </MudStack>
                        }

                        <MudTooltip Text="Select server and model" Disabled="@CanStartChat">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       Size="Size.Medium"
                                       Disabled="@(!CanStartChat)"
                                       OnClick="StartChat">
                                Start Chat
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <AgenticChatSession @ref="chatSessionView"
                            Messages="ChatViewModelService.Messages"
                            Agents="ChatService.Agents"
                            IsLlmAnswering="isLLMAnswering"
                            UserName="userSettings.UserName"
                            OnSaveChat="SaveCurrentChat"
                            OnSendMessage="SendChatMessageAsync"
                            OnStop="Cancel"
                            OnDeleteMessage="DeleteMessage"
                            OnCopyChat="CopyChatAsync" />
    }
    </MudStack>
</OllamaCheck>

@code {
    private const string DefaultAgentName = "Default Assistant";

    private List<AgentDefinitionDescriptor> catalogItems = new();
    private AgentDefinitionDescriptor? selectedDefinition { get; set; }
    private IReadOnlyList<AgentInputDefinition> inputDefinitions = [];
    private readonly Dictionary<string, string> inputValues = new(StringComparer.OrdinalIgnoreCase);

    [Inject]
    private IAgentDefinitionCatalog AgentDefinitionCatalog { get; set; } = null!;

    [Inject]
    private IAgentSessionDefinitionResolver SessionDefinitionResolver { get; set; } = null!;

    [CascadingParameter(Name = "UiModelSelection")]
    public ServerModelSelection UiModelSelection { get; set; } = new(null, null);

    private ServerModel? effectiveModel;
    private string CurrentModelName => effectiveModel!.ModelName;

    private bool CanStartChat => selectedDefinition is not null && AreRequiredInputsSatisfied();

    protected override bool CanSendMessages => selectedDefinition is not null;

    protected override async Task LoadAgentsAsync()
    {
        catalogItems = (await AgentDefinitionCatalog.GetAllAsync()).ToList();
        var defaultItem = catalogItems.FirstOrDefault(item =>
            string.Equals(item.Name, DefaultAgentName, StringComparison.OrdinalIgnoreCase)) ?? catalogItems.FirstOrDefault();
        SetSelectedDefinition(defaultItem);
    }

    protected override async Task LoadUserSettingsAsync()
    {
        userSettings = await UserSettingsService.GetSettingsAsync();
    }

    protected override async Task LoadSavedChatAsync(Guid savedChatId)
    {
        var saved = await SavedChatService.GetByIdAsync(savedChatId);
        if (saved is null)
        {
            Snackbar.Add("Saved chat not found", Severity.Error);
            return;
        }

        var assistantIds = saved.Participants
            .Where(participant => participant.Role == AppChatRole.Assistant)
            .Select(participant => participant.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var savedAgents = await AgentService.GetAllAsync();
        var agentsForChat = savedAgents
            .Where(agent => assistantIds.Contains(agent.AgentId))
            .ToList();

        if (agentsForChat.Count == 0)
        {
            Snackbar.Add("Agents for saved chat not found", Severity.Error);
            return;
        }

        var selectedItem = catalogItems.FirstOrDefault(item =>
            string.Equals(item.Reference.Id, agentsForChat[0].Id.ToString("D"), StringComparison.OrdinalIgnoreCase));
        SetSelectedDefinition(selectedItem);
        if (selectedItem is null)
            return;
        var resolved = await SessionDefinitionResolver.ResolveAsync(selectedItem.Reference, new AgentSessionDefinitionRequest
        {
            UiModelSelection = UiModelSelection
        });
        if (!resolved.Validation.CanLaunch)
        {
            Snackbar.Add(string.Join(" ", resolved.Validation.Problems.Select(problem => problem.Message)), Severity.Error);
            return;
        }
        effectiveModel = resolved.DefaultModel;

        var chatConfiguration = new AppChatConfiguration(CurrentModelName, []);
        var savedMessages = saved.Messages
            .Select(message =>
            {
                var chatMessage = new AppChatMessage(
                    message.Content,
                    message.MsgDateTime,
                    message.Role,
                    agentId: message.AgentId,
                    agentName: message.AgentName);
                chatMessage.Id = message.Id;
                return (IAppChatMessage)chatMessage;
            })
            .ToList();

        var request = new ChatEngineSessionStartRequest
        {
            Configuration = chatConfiguration,
            Agents = [],
            RuntimeParticipant = resolved.PresentationParticipant,
            RuntimeReference = resolved.RuntimeReference,
            RuntimeDefaultModel = resolved.DefaultModel,
            History = savedMessages,
            ChatStrategyName = "RoundRobin",
            ChatStrategyOptions = new RoundRobinChatStrategyOptions { Rounds = 1 }
        };

        try
        {
            await ChatService.StartAsync(request);
            chatStarted = true;
            lastSavedChatId = savedChatId;
            lastSavedChatTitle = saved.Title;
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task StartChat()
    {
        if (selectedDefinition is null)
            return;

        var resolved = await SessionDefinitionResolver.ResolveAsync(selectedDefinition.Reference, new AgentSessionDefinitionRequest
        {
            UiModelSelection = UiModelSelection,
            Inputs = BuildInputs()
        });
        if (!resolved.Validation.CanLaunch)
        {
            Snackbar.Add(string.Join(" ", resolved.Validation.Problems.Select(problem => problem.Message)), Severity.Error);
            return;
        }
        effectiveModel = resolved.DefaultModel;

        var chatConfiguration = new AppChatConfiguration(resolved.DefaultModel?.ModelName ?? string.Empty, []);
        var request = new ChatEngineSessionStartRequest
        {
            Configuration = chatConfiguration,
            Agents = [],
            RuntimeParticipant = resolved.PresentationParticipant,
            RuntimeReference = resolved.RuntimeReference,
            RuntimeDefaultModel = resolved.DefaultModel,
            RuntimeInputs = resolved.Inputs,
            ChatStrategyName = "RoundRobin",
            ChatStrategyOptions = new RoundRobinChatStrategyOptions { Rounds = 1 }
        };

        try
        {
            await ChatService.StartAsync(request);
            chatStarted = true;
            StateHasChanged();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private Task OnDefinitionChanged(AgentDefinitionDescriptor? item)
    {
        SetSelectedDefinition(item);
        return Task.CompletedTask;
    }

    private void SetSelectedDefinition(AgentDefinitionDescriptor? item)
    {
        selectedDefinition = item;
        inputDefinitions = item?.Inputs ?? [];
        inputValues.Clear();
        foreach (var input in inputDefinitions)
        {
            if (input.DefaultValue is not null)
                inputValues[input.Key] = input.DefaultValue;
        }
    }

    private static string GetKindLabel(AgentDefinitionDescriptor item) =>
        item.RuntimeKind == AgentRuntimeKind.WorkflowAgent ? "workflow" : "agent";

    private IReadOnlyDictionary<string, string> BuildInputs() =>
        inputDefinitions
            .Where(input => inputValues.TryGetValue(input.Key, out var value) &&
                            (!string.IsNullOrWhiteSpace(value) || input.Kind == AgentInputDefinitionKind.Boolean))
            .ToDictionary(
                input => input.Key,
                input => inputValues[input.Key],
                StringComparer.OrdinalIgnoreCase);

    private string GetInputValue(AgentInputDefinition input) =>
        inputValues.TryGetValue(input.Key, out var value)
            ? value
            : input.DefaultValue ?? string.Empty;

    private void SetInputValue(string key, string? value)
    {
        inputValues[key] = value ?? string.Empty;
    }

    private bool GetBooleanInputValue(AgentInputDefinition input) =>
        bool.TryParse(GetInputValue(input), out var value) && value;

    private void SetBooleanInputValue(string key, bool value)
    {
        inputValues[key] = value.ToString();
    }

    private static string GetInputLabel(AgentInputDefinition input) =>
        input.IsRequired ? $"{input.DisplayName} *" : input.DisplayName;

    private bool AreRequiredInputsSatisfied() =>
        inputDefinitions
            .Where(static input => input.IsRequired && input.Kind != AgentInputDefinitionKind.Boolean)
            .All(input => !string.IsNullOrWhiteSpace(GetInputValue(input)));
}
