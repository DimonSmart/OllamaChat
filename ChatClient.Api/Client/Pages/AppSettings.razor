@page "/app-settings"
@using ChatClient.Api.Client.Components
@using ChatClient.Api.Client.Services
@using ChatClient.Api.Services
@using ChatClient.Application.Services
@using ChatClient.Domain.Models
@using System.Linq
@using System.Text.Json
@inject IUserSettingsService UserSettingsService
@inject IVoiceInputService VoiceInputService
@inject IOllamaClientService OllamaService
@inject ISnackbar Snackbar
@inject ILogger<AppSettings> Logger
@inject McpFunctionIndexService McpFunctionIndexService

<PageTitle>Application Settings</PageTitle>

<OllamaCheck>
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-3">
        <MudText Class="page-header">Application Settings</MudText>

        @if (_loading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="ml-2">Loading settings...</MudText>
        }
        else
        {
            <MudPaper Elevation="3" Class="pa-3 rounded-lg">
                <MudForm @ref="_form" Model="@_settings">
                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardContent>
                            <ServerModelPicker Value="_defaultModel" ValueChanged="OnDefaultModelChanged" ShowClearButton="true" />
                            <MudText Typo="Typo.caption" Class="mt-2">
                                This server and model will be selected by default when starting a new chat.
                            </MudText>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardContent Class="pt-0">
                            <MudSelect T="AppChatHistoryMode" Label="History Processing" @bind-Value="_settings.ChatHistoryMode" Variant="Variant.Outlined" Dense="true">
                                <MudSelectItem Value="@AppChatHistoryMode.None">None</MudSelectItem>
                                <MudSelectItem Value="@AppChatHistoryMode.Truncate">Truncate</MudSelectItem>
                                <MudSelectItem Value="@AppChatHistoryMode.Summarize">Summarize</MudSelectItem>
                            </MudSelect>
                            <MudText Typo="Typo.caption" Class="mt-2">
                                Determines how message history is prepared before sending to the model.
                            </MudText>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardContent>
                            <MudTextField T="string" Label="Default Chat Message" @bind-Value="_settings.DefaultChatMessage"
                                          Lines="3" Variant="Variant.Outlined" HelperText="Pre-filled message in the chat input (useful for testing)" />
                        </MudCardContent>
                    </MudCard>

                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardContent>
                            <MudTextField T="string" Label="Default Multiagent Chat Message" @bind-Value="_settings.DefaultMultiAgentChatMessage"
                                          Lines="3" Variant="Variant.Outlined" HelperText="Pre-filled message in the multiagent chat input" />
                        </MudCardContent>
                    </MudCard>

                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardHeader Class="pb-2">
                            <MudText Class="section-header">Chat Participants</MudText>
                        </MudCardHeader>
                        <MudCardContent Class="pt-0">
                            <MudTextField T="string" Label="User Name" @bind-Value="_settings.UserName"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Display name for user messages (leave empty to hide avatar)" />
                            <MudTextField T="string" Label="Agent Name" @bind-Value="_settings.AgentName"
                                          Variant="Variant.Outlined"
                                          HelperText="Display name for AI assistant messages (leave empty to hide avatar)" />
                        </MudCardContent>
                    </MudCard>

                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardContent Class="pt-0">
                            <MudTextField T="string" Label="Chat Strategy Name" @bind-Value="_settings.ChatStrategyName"
                                          Variant="Variant.Outlined" HelperText="Default chat strategy for multi-agent conversations" />
                        </MudCardContent>
                    </MudCard>

                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardHeader Class="pb-2">
                            <MudText Class="section-header">Voice Input</MudText>
                        </MudCardHeader>
                        <MudCardContent Class="pt-0">
                            <MudSwitch T="bool"
                                       Value="_settings.VoiceInput.IsEnabled"
                                       ValueChanged="OnVoiceInputEnabledChanged"
                                       Color="Color.Primary"
                                       Label="Enable voice input" />

                            <MudSelect T="string"
                                       Value="_settings.VoiceInput.ModelType"
                                       ValueChanged="OnVoiceInputModelChanged"
                                       Label="Whisper Model"
                                       Variant="Variant.Outlined"
                                       Dense="true"
                                       Class="mt-3"
                                       Disabled="@(_settings.VoiceInput.Status == VoiceInputInitializationStatus.Initializing)">
                                @foreach (var option in VoiceInputModelOptions)
                                {
                                    <MudSelectItem Value="@option.Value">@GetVoiceInputModelLabel(option)</MudSelectItem>
                                }
                            </MudSelect>

                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-3">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           OnClick="InitializeVoiceInput"
                                           Disabled="@(_settings.VoiceInput.Status == VoiceInputInitializationStatus.Initializing)">
                                    Initialize
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           OnClick="ClearDownloadedVoiceModels"
                                           Disabled="@(_settings.VoiceInput.Status == VoiceInputInitializationStatus.Initializing || _voiceInputStorage.TotalBytes == 0)">
                                    Clear Downloaded Models
                                </MudButton>

                                <MudChip T="string"
                                         Color="@GetVoiceInputStatusColor(_settings.VoiceInput.Status)"
                                         Variant="Variant.Outlined"
                                         Size="Size.Small">
                                    @GetVoiceInputStatusText(_settings.VoiceInput.Status)
                                </MudChip>
                            </MudStack>

                            @if (!string.IsNullOrWhiteSpace(_settings.VoiceInput.ErrorMessage))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2">
                                    @_settings.VoiceInput.ErrorMessage
                                </MudText>
                            }
                            else if (!string.IsNullOrWhiteSpace(_voiceInputActivityMessage))
                            {
                                <MudText Typo="Typo.caption" Class="mt-2">
                                    @_voiceInputActivityMessage
                                </MudText>
                            }

                            @if (_voiceInputStorage.DownloadedModels.Count > 0)
                            {
                                <MudText Typo="Typo.caption" Class="mt-2">
                                    Downloaded models:
                                    @string.Join(", ", _voiceInputStorage.DownloadedModels.Select(model => $"{model.DisplayName} ({ChatDisplayHelper.FormatFileSize(model.SizeBytes)})"))
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    Disk usage: @ChatDisplayHelper.FormatFileSize(_voiceInputStorage.TotalBytes)
                                </MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="mt-2">
                                    No Whisper models are currently stored locally.
                                </MudText>
                            }

                            <MudText Typo="Typo.caption" Class="mt-2">
                                Uses local Whisper speech recognition with automatic language detection.
                                For Russian, `Small`, `Medium`, or `LargeV3Turbo` usually work better than `Base`.
                                Do not use `*.En` models unless you only need English.
                            </MudText>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Class="mb-4" Elevation="1">
                        <MudCardContent>
                            <ServerModelPicker Value="_embeddingModel" ValueChanged="OnEmbeddingModelChanged" ShowClearButton="true" />
                            <MudText Typo="Typo.caption" Class="mt-2">
                                Model used for generating embeddings.
                            </MudText>
                            <MudNumericField T="int" @bind-Value="_settings.Embedding.RagLineChunkSize" Label="Line Chunk Size" Min="1" Variant="Variant.Outlined" Class="mt-4" />
                            <MudNumericField T="int" @bind-Value="_settings.Embedding.RagParagraphChunkSize" Label="Paragraph Chunk Size" Min="1" Variant="Variant.Outlined" Class="mt-4" />
                            <MudNumericField T="int" @bind-Value="_settings.Embedding.RagParagraphOverlap" Label="Paragraph Overlap" Min="0" Variant="Variant.Outlined" Class="mt-4" />
                            <MudText Typo="Typo.caption" Class="mt-2">Text chunking parameters for building RAG indexes.</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="RestartEmbeddings" Class="mt-4">
                                Restart Embedding Generation
                            </MudButton>
                        </MudCardContent>
                    </MudCard>

                    <MudButtonGroup Class="mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" Size="Size.Medium">
                            Save Application Settings
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ResetSettings" Size="Size.Medium">
                            Reset
                        </MudButton>
                    </MudButtonGroup>
                </MudForm>
            </MudPaper>
        }
    </MudContainer>
</OllamaCheck>

@code {
    private UserSettings _settings = new();
    private ServerModelSelection _defaultModel = new(null, null);
    private ServerModelSelection _embeddingModel = new(null, null);
    private VoiceInputStorageInfo _voiceInputStorage = new();
    private static readonly IReadOnlyList<VoiceInputModelOption> VoiceInputModelOptions =
    [
        new("Tiny", "Tiny", 75L * 1024 * 1024, false),
        new("Base", "Base", 142L * 1024 * 1024, false),
        new("Small", "Small", 466L * 1024 * 1024, false),
        new("Medium", "Medium", 1536L * 1024 * 1024, false),
        new("LargeV3Turbo", "Large V3 Turbo", 1536L * 1024 * 1024, false),
        new("LargeV3", "Large V3", 2969L * 1024 * 1024, false),
        new("TinyEn", "Tiny", 75L * 1024 * 1024, true),
        new("BaseEn", "Base", 142L * 1024 * 1024, true),
        new("SmallEn", "Small", 466L * 1024 * 1024, true),
        new("MediumEn", "Medium", 1536L * 1024 * 1024, true),
        new("LargeV2", "Large V2", 2969L * 1024 * 1024, false),
        new("LargeV1", "Large V1", 2969L * 1024 * 1024, false)
    ];
    private string _voiceInputActivityMessage = string.Empty;
    private bool _loading = true;
    private MudForm? _form;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            await LoadSettings();
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnDefaultModelChanged(ServerModelSelection model)
    {
        _defaultModel = model;
        _settings.DefaultModel = model;
        return Task.CompletedTask;
    }

    private Task OnEmbeddingModelChanged(ServerModelSelection model)
    {
        _embeddingModel = model;
        _settings.Embedding.Model = model;
        return Task.CompletedTask;
    }

    private async Task LoadSettings()
    {
        try
        {
            _settings = await UserSettingsService.GetSettingsAsync();
            _settings.VoiceInput = await VoiceInputService.GetSettingsAsync();
            _voiceInputStorage = await VoiceInputService.GetStorageInfoAsync();
            _defaultModel = _settings.DefaultModel;
            _embeddingModel = _settings.Embedding.Model;
            _voiceInputActivityMessage = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading settings");
            Snackbar.Add("Failed to load settings.", Severity.Error);
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            if (_settings.Embedding.Model.ServerId is { } serverId && !string.IsNullOrWhiteSpace(_settings.Embedding.Model.ModelName))
            {
                var models = await OllamaService.GetModelsAsync(serverId);
                var exists = models.Any(m => m.Name.Equals(_settings.Embedding.Model.ModelName, StringComparison.OrdinalIgnoreCase));
                if (!exists)
                {
                    Snackbar.Add($"Embedding model '{_settings.Embedding.Model.ModelName}' not found.", Severity.Error);
                    return;
                }
            }

            await UserSettingsService.SaveSettingsAsync(_settings);
            Snackbar.Add("Application settings saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving settings");
            Snackbar.Add($"Failed to save settings: {ex.Message}", Severity.Error);
        }
    }

    private async Task RestartEmbeddings()
    {
        await SaveSettings();
        try
        {
            await McpFunctionIndexService.RebuildAsync();
            Snackbar.Add("Embedding generation restarted", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error restarting embeddings");
            Snackbar.Add("Failed to restart embedding generation", Severity.Error);
        }
    }

    private async Task OnVoiceInputEnabledChanged(bool isEnabled)
    {
        _settings.VoiceInput.IsEnabled = isEnabled;

        try
        {
            await UserSettingsService.SaveVoiceInputSettingsAsync(_settings.VoiceInput);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving voice input toggle");
            Snackbar.Add("Failed to save voice input setting.", Severity.Error);
        }
    }

    private Task OnVoiceInputModelChanged(string modelType)
    {
        if (string.Equals(_settings.VoiceInput.ModelType, modelType, StringComparison.Ordinal))
        {
            return Task.CompletedTask;
        }

        _settings.VoiceInput.ModelType = modelType;
        _settings.VoiceInput.Status = VoiceInputInitializationStatus.NotInitialized;
        _settings.VoiceInput.ErrorMessage = string.Empty;
        _voiceInputActivityMessage = "Save settings and initialize voice input to download and apply the selected model.";
        return Task.CompletedTask;
    }

    private async Task InitializeVoiceInput()
    {
        try
        {
            await UserSettingsService.SaveVoiceInputSettingsAsync(_settings.VoiceInput);

            _settings.VoiceInput.Status = VoiceInputInitializationStatus.Initializing;
            _settings.VoiceInput.ErrorMessage = string.Empty;
            _voiceInputActivityMessage = "Starting voice input initialization...";
            await InvokeAsync(StateHasChanged);

            var progress = new Progress<string>(message =>
            {
                _voiceInputActivityMessage = message;
                _ = InvokeAsync(StateHasChanged);
            });

            _settings.VoiceInput = await VoiceInputService.InitializeAsync(progress);
            _voiceInputStorage = await VoiceInputService.GetStorageInfoAsync();

            if (_settings.VoiceInput.Status == VoiceInputInitializationStatus.Ready)
            {
                _voiceInputActivityMessage = "Voice input is ready.";
                Snackbar.Add("Voice input is ready.", Severity.Success);
                return;
            }

            _voiceInputActivityMessage = _settings.VoiceInput.ErrorMessage;
            Snackbar.Add(
                string.IsNullOrWhiteSpace(_settings.VoiceInput.ErrorMessage)
                    ? "Voice input initialization failed."
                    : _settings.VoiceInput.ErrorMessage,
                Severity.Warning);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing voice input");
            _voiceInputActivityMessage = "Voice input initialization failed.";
            Snackbar.Add("Failed to initialize voice input.", Severity.Error);
        }
    }

    private async Task ClearDownloadedVoiceModels()
    {
        try
        {
            _voiceInputActivityMessage = "Removing downloaded Whisper models...";
            await InvokeAsync(StateHasChanged);

            _settings.VoiceInput = await VoiceInputService.ClearDownloadedModelsAsync();
            _voiceInputStorage = await VoiceInputService.GetStorageInfoAsync();
            _voiceInputActivityMessage = "Downloaded Whisper models were removed.";
            Snackbar.Add("Downloaded Whisper models were removed.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error clearing downloaded Whisper models");
            _voiceInputActivityMessage = "Failed to remove downloaded Whisper models.";
            Snackbar.Add("Failed to remove downloaded Whisper models.", Severity.Error);
        }
    }

    private async Task ResetSettings()
    {
        await LoadSettings();
        Snackbar.Add("Settings reset to last saved values", Severity.Info);
    }

    private static string GetVoiceInputStatusText(VoiceInputInitializationStatus status) =>
        status switch
        {
            VoiceInputInitializationStatus.NotInitialized => "Not initialized",
            VoiceInputInitializationStatus.Initializing => "Initializing",
            VoiceInputInitializationStatus.Ready => "Ready",
            VoiceInputInitializationStatus.Error => "Error",
            _ => "Unknown"
        };

    private static Color GetVoiceInputStatusColor(VoiceInputInitializationStatus status) =>
        status switch
        {
            VoiceInputInitializationStatus.Ready => Color.Success,
            VoiceInputInitializationStatus.Initializing => Color.Info,
            VoiceInputInitializationStatus.Error => Color.Error,
            _ => Color.Default
        };

    private static string GetVoiceInputModelLabel(VoiceInputModelOption option)
    {
        var sizeLabel = ChatDisplayHelper.FormatFileSize(option.ApproximateSizeBytes);
        return option.IsEnglishOnly
            ? $"{option.DisplayName} ({sizeLabel}, English only)"
            : $"{option.DisplayName} ({sizeLabel})";
    }

    private sealed record VoiceInputModelOption(string Value, string DisplayName, long ApproximateSizeBytes, bool IsEnglishOnly);
}
