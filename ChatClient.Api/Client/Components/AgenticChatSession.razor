@using System.Linq
@using ChatClient.Api.Client.Services
@using ChatClient.Api.Client.ViewModels
@using ChatClient.Domain.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@using MudBlazor
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ILogger<AgenticChatSession> Logger

<div class="chat-actions">
    <MudMenu Icon="@Icons.Material.Filled.ContentCopy" AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.TopRight">
        <MudMenuItem OnClick="@(() => OnCopyChat.InvokeAsync(ChatFormat.Text))">Copy as Text</MudMenuItem>
        <MudMenuItem OnClick="@(() => OnCopyChat.InvokeAsync(ChatFormat.Markdown))">Copy as Markdown</MudMenuItem>
        <MudMenuItem OnClick="@(() => OnCopyChat.InvokeAsync(ChatFormat.Html))">Copy as HTML</MudMenuItem>
    </MudMenu>
</div>

<div class="chat-messages-container" @ref="messagesElement">
    @{
        var messageIndex = 0;
    }
    @foreach (var message in Messages)
    {
        if (message.Role == AppChatRole.System)
        {
            continue;
        }

        if (message.Role == AppChatRole.Tool)
        {
            <RagDisplay Text="@message.Content" />
        }
        else
        {
            messageIndex++;
            <MudChat Dense="true" ChatPosition="@(message.Role == AppChatRole.Assistant ? ChatBubblePosition.Start : ChatBubblePosition.End)" @key="@($"{messageIndex}_{message.Id}")">
                <MudChatHeader>
                    <time>@message.MsgDateTime.ToString("g")</time>
                    <CopyButton Text="@message.Content"
                                Tooltip="Copy answer"
                                AriaLabel="Copy answer"
                                Size="Size.Small"
                                Class="chat-message-action" />
                    <CopyButton CopyTextFactory="@(() => GetRawContentAsync(message))"
                                Tooltip="Copy raw text"
                                AriaLabel="Copy raw text"
                                Icon="@Icons.Material.Filled.Description"
                                Size="Size.Small"
                                Class="chat-message-action"
                                Disabled="@string.IsNullOrWhiteSpace(message.RawContent)" />
                    @if (!IsLlmAnswering)
                    {
                        <MudTooltip Text="Delete">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Class="chat-message-action"
                                           OnClick="@(() => OnDeleteMessage.InvokeAsync(message))" />
                        </MudTooltip>
                    }
                </MudChatHeader>

                @{
                    var avatarText = message.Role == AppChatRole.Assistant
                        ? GetAssistantAvatarText(message.AgentId)
                        : GetAvatarText(UserName);
                    var avatarLabel = message.Role == AppChatRole.Assistant
                        ? GetAssistantLabel(message)
                        : UserName;
                }

                @if (!string.IsNullOrEmpty(avatarText))
                {
                    @if (!string.IsNullOrWhiteSpace(avatarLabel))
                    {
                        <MudTooltip Text="@avatarLabel">
                            <MudAvatar Class="chat-avatar" Color="@(message.Role == AppChatRole.Assistant ? Color.Primary : Color.Secondary)">
                                @avatarText
                            </MudAvatar>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudAvatar Class="chat-avatar" Color="@(message.Role == AppChatRole.Assistant ? Color.Primary : Color.Secondary)">
                            @avatarText
                        </MudAvatar>
                    }
                }

                <MudChatBubble Class="@(message.Role == AppChatRole.User ? "chat-user-bubble" : null)">
                    @if (ShouldShowSpeakerLabel(message))
                    {
                        <MudText Typo="Typo.caption" Class="chat-speaker-label">
                            @GetSpeakerLabel(message)
                        </MudText>
                    }

                    @if (message.Files.Any())
                    {
                        <div class="mb-2">
                            @foreach (var file in message.Files)
                            {
                                @if (IsImageFile(file.ContentType))
                                {
                                    <div class="image-thumbnail">
                                        <img src="@GetImageDataUrl(file)"
                                             alt="@file.Name"
                                             style="max-width: 150px; max-height: 150px; object-fit: cover;"
                                             @onclick="@(() => ShowFullSizeImage(file))" />
                                        <MudText Typo="Typo.caption" Class="image-caption mt-1 text-center">
                                            @file.Name (@FormatFileSize(file.Size))
                                        </MudText>
                                    </div>
                                }
                                else
                                {
                                    <MudChip T="string"
                                             Color="Color.Info"
                                             Size="Size.Small"
                                             Class="mb-1 mr-1">
                                        <MudIcon Icon="@GetFileIcon(file.ContentType)" Class="mr-1" />
                                        @file.Name (@FormatFileSize(file.Size))
                                    </MudChip>
                                }
                            }
                        </div>
                    }
                    <div class="chat-markdown-content">
                        @((MarkupString)message.HtmlContent)
                    </div>
                </MudChatBubble>

                @if (message.ThinkSegments.Any())
                {
                    foreach (var thought in GetValidThoughts(message))
                    {
                        <ThoughtDisplay PlainText="@thought.PlainText" HtmlText="@thought.HtmlText" />
                    }
                }

                @if (message.FunctionCalls.Any())
                {
                    foreach (var call in message.FunctionCalls)
                    {
                        <McpCallDisplay Call="@call" />
                    }
                }

                @if (message.IsStreaming || message.IsCanceled || !string.IsNullOrEmpty(message.Statistics))
                {
                    <MudChatFooter>
                        @if (message.IsStreaming)
                        {
                            <MudText Typo="Typo.caption" Class="typing-indicator">typing...</MudText>
                        }
                        @if (message.IsCanceled)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-1">
                                Canceled
                            </MudAlert>
                        }
                        @if (!string.IsNullOrEmpty(message.Statistics))
                        {
                            <div class="mt-1">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @((MarkupString)message.Statistics)
                                </MudText>
                            </div>
                        }
                    </MudChatFooter>
                }
            </MudChat>
        }
    }
</div>

<div class="chat-input-panel">
    <MudStack>
        <ChatInput OnSend="OnSendMessage"
                   ShowStopButton="IsLlmAnswering"
                   OnStopClick="OnStop"
                   IsMultiAgent="IsMultiAgent" />
    </MudStack>
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<AppChatMessageViewModel> Messages { get; set; } = Array.Empty<AppChatMessageViewModel>();

    [Parameter, EditorRequired]
    public IReadOnlyCollection<AgentExecutionSpec> Agents { get; set; } = Array.Empty<AgentExecutionSpec>();

    [Parameter]
    public bool IsLlmAnswering { get; set; }

    [Parameter]
    public string UserName { get; set; } = string.Empty;

    [Parameter]
    public bool IsMultiAgent { get; set; }

    [Parameter]
    public EventCallback<(string text, IReadOnlyList<AppChatMessageFile> files)> OnSendMessage { get; set; }

    [Parameter]
    public EventCallback OnStop { get; set; }

    [Parameter]
    public EventCallback<AppChatMessageViewModel> OnDeleteMessage { get; set; }

    [Parameter]
    public EventCallback<ChatFormat> OnCopyChat { get; set; }

    private ElementReference messagesElement;

    public async Task ScrollToBottomAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("scrollToBottom", messagesElement);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to scroll to bottom");
        }
    }

    private static IEnumerable<(string PlainText, string HtmlText)> GetValidThoughts(AppChatMessageViewModel message)
    {
        var plainSegments = message.ThinkSegments.ToList();
        var htmlSegments = message.HtmlThinkSegments.ToList();
        var count = Math.Min(plainSegments.Count, htmlSegments.Count);

        for (var index = 0; index < count; index++)
        {
            if (string.IsNullOrWhiteSpace(plainSegments[index]))
                continue;

            yield return (plainSegments[index], htmlSegments[index]);
        }
    }

    private async Task ShowFullSizeImage(AppChatMessageFile file)
    {
        var parameters = new DialogParameters
        {
            ["ImageFile"] = file
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true,
            BackdropClick = true
        };

        await DialogService.ShowAsync<ImageViewerDialog>("Image Viewer", parameters, options);
    }

    private static string GetFileIcon(string contentType) =>
        ChatDisplayHelper.GetFileIcon(contentType);

    private static string FormatFileSize(long bytes) =>
        ChatDisplayHelper.FormatFileSize(bytes);

    private static bool IsImageFile(string contentType) =>
        ChatDisplayHelper.IsImageFile(contentType);

    private static string GetImageDataUrl(AppChatMessageFile file) =>
        ChatDisplayHelper.GetImageDataUrl(file);

    private static string GetAvatarText(string? name) =>
        ChatDisplayHelper.GetAvatarText(name);

    private string GetAssistantAvatarText(string? agentId) =>
        ChatDisplayHelper.GetAssistantAvatarText(Agents, agentId);

    private string? GetAssistantLabel(AppChatMessageViewModel message) =>
        ChatDisplayHelper.GetAssistantDisplayName(Agents, message.AgentId);

    private bool ShouldShowSpeakerLabel(AppChatMessageViewModel message) =>
        IsMultiAgent &&
        message.Role == AppChatRole.Assistant &&
        !string.IsNullOrWhiteSpace(GetSpeakerLabel(message));

    private string? GetSpeakerLabel(AppChatMessageViewModel message) =>
        GetAssistantLabel(message);

    private static Task<string> GetRawContentAsync(AppChatMessageViewModel message) =>
        Task.FromResult(message.RawContent ?? string.Empty);
}
