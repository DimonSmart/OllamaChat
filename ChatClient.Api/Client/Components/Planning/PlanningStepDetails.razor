@using System.Text.Json
@using ChatClient.Api.PlanningRuntime.Common
@using ChatClient.Api.PlanningRuntime.Execution
@using ChatClient.Api.PlanningRuntime.Host
@using ChatClient.Api.PlanningRuntime.Planning
@using MudBlazor

@if (SelectedLink is not null)
{
    <MudPaper Class="pa-4 planning-step-details" Outlined="true">
        <MudStack Spacing="2">
            <div>
                <MudText Typo="Typo.h6">@GetLinkTitle(SelectedLink)</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetLinkSubtitle(SelectedLink)</MudText>
            </div>

            <MudText Typo="Typo.subtitle2">Source</MudText>
            <PlanningValueDisplay Text="@BuildStepSummary(SelectedLinkSourceStep, SelectedLink.SourceId)" AutoDetectMarkdown="false" />

            <MudText Typo="Typo.subtitle2">Target</MudText>
            <PlanningValueDisplay Text="@BuildTargetSummary(SelectedLink, SelectedLinkTargetStep)" AutoDetectMarkdown="false" />

            @if (SelectedLink.Kind == PlanningGraphLinkKind.Dependency && SelectedLink.Matches.Count > 0)
            {
                <MudText Typo="Typo.subtitle2">Binding Matches</MudText>
                @foreach (var match in SelectedLink.Matches)
                {
                    <MudPaper Class="pa-3 mb-2 planning-step-call" Outlined="true">
                        <MudText Typo="Typo.caption">
                            input: @match.InputName | path: @match.Path | mode: @(match.Mode ?? "value")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Reference</MudText>
                        <PlanningValueDisplay Text="@match.Reference"
                                             PaperClass="pa-3 mt-1 planning-step-block"
                                             AutoDetectMarkdown="false" />
                        <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Reference Fragment</MudText>
                        <PlanningValueDisplay Text="@match.ReferenceJson"
                                             PaperClass="pa-3 mt-1 planning-step-block"
                                             AutoDetectMarkdown="false" />
                        <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Full Binding</MudText>
                        <PlanningValueDisplay Text="@match.BindingJson"
                                             PaperClass="pa-3 mt-1 planning-step-block"
                                             AutoDetectMarkdown="false" />
                    </MudPaper>
                }
            }

            @if (SelectedLinkSourceStep?.Result is not null)
            {
                <MudText Typo="Typo.subtitle2">Source Result</MudText>
                <PlanningValueDisplay Json="@SelectedLinkSourceStep.Result"
                                     AutoDetectMarkdown="true" />
            }

            @if (SelectedLinkSourceStep?.Error is not null)
            {
                <MudText Typo="Typo.subtitle2">Source Error</MudText>
                <PlanningValueDisplay Text="@SerializeJson(SelectedLinkSourceStep.Error)"
                                     AutoDetectMarkdown="false" />
            }

            @if (SelectedLink.Kind == PlanningGraphLinkKind.Result && FinalResult is not null)
            {
                <MudText Typo="Typo.subtitle2">Final Outcome</MudText>
                <PlanningValueDisplay Text="@($"ok: {FinalResult.Ok.ToString().ToLowerInvariant()}")"
                                     AutoDetectMarkdown="false" />

                @if (FinalResult.Ok && FinalResult.Data is not null)
                {
                    <MudText Typo="Typo.subtitle2">Final Result</MudText>
                    <PlanningValueDisplay Json="@FinalResult.Data"
                                         AutoDetectMarkdown="true" />
                }
                else if (!FinalResult.Ok && FinalResult.Error is not null)
                {
                    <MudText Typo="Typo.subtitle2">Final Error</MudText>
                    <PlanningValueDisplay Text="@SerializeJson(FinalResult.Error)"
                                         AutoDetectMarkdown="false" />
                }
            }
        </MudStack>
    </MudPaper>
}
else if (SelectedVirtualNode is not null)
{
    <MudPaper Class="pa-4 planning-step-details" Outlined="true">
        <MudStack Spacing="2">
            <div>
                <MudText Typo="Typo.h6">@SelectedVirtualNode.Title</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@SelectedVirtualNode.Subtitle | status: @SelectedVirtualNode.StatusValue</MudText>
            </div>

            @if (SelectedVirtualNode.Kind == PlanningVirtualNodeKind.Planning)
            {
                @if (!string.IsNullOrWhiteSpace(SelectedVirtualNode.PlanningStarted?.UserQuery))
                {
                    <MudText Typo="Typo.subtitle2">User Request</MudText>
                    <PlanningValueDisplay Text="@SelectedVirtualNode.PlanningStarted!.UserQuery" AutoDetectMarkdown="false" />
                }

                @if (SelectedVirtualNode.AvailableTools.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2">Available Tools</MudText>
                    <MudPaper Class="pa-3 planning-step-block">
                        <MudStack Spacing="1">
                            @foreach (var tool in SelectedVirtualNode.AvailableTools)
                            {
                                <div>
                                    <MudText Typo="Typo.body2">@tool.DisplayName (@tool.Name)</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@tool.Description</MudText>
                                </div>
                            }
                        </MudStack>
                    </MudPaper>
                }

                @if (SelectedVirtualNode.PlannedDraft is not null)
                {
                    <MudText Typo="Typo.subtitle2">Raw Plan</MudText>
                    <PlanningValueDisplay Text="@SerializeJson(SelectedVirtualNode.PlannedDraft)" AutoDetectMarkdown="false" />
                }
            }
            else if (SelectedVirtualNode.Kind == PlanningVirtualNodeKind.Replanning)
            {
                @if (!string.IsNullOrWhiteSpace(SelectedVirtualNode.ReplanStarted?.Request.GoalVerdict.Reason))
                {
                    <MudText Typo="Typo.subtitle2">Why Replanning Started</MudText>
                    <PlanningValueDisplay Text="@SelectedVirtualNode.ReplanStarted!.Request.GoalVerdict.Reason" AutoDetectMarkdown="false" />
                }

                @if (SelectedVirtualNode.ReplanStarted?.Request.GoalVerdict.Missing.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2">Missing Or Blocked Items</MudText>
                    <PlanningValueDisplay Text="@SerializeJson(SelectedVirtualNode.ReplanStarted!.Request.GoalVerdict.Missing)" AutoDetectMarkdown="false" />
                }

                @if (FailedReplanTraces.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2">Failed Execution Traces</MudText>
                    @foreach (var failedTrace in FailedReplanTraces)
                    {
                        <MudPaper Class="pa-3 mb-2 planning-step-call" Outlined="true">
                            <MudText Typo="Typo.caption">step @failedTrace.StepId | error: @failedTrace.ErrorCode</MudText>
                            @if (!string.IsNullOrWhiteSpace(failedTrace.ErrorMessage))
                            {
                                <MudText Typo="Typo.body2" Class="mt-1">@failedTrace.ErrorMessage</MudText>
                            }
                            @if (failedTrace.ErrorDetails is not null)
                            {
                                <MudText Typo="Typo.caption" Class="mt-1 mud-text-secondary">Details</MudText>
                                <PlanningValueDisplay Json="@failedTrace.ErrorDetails.Value"
                                                     PaperClass="pa-3 mt-1 planning-step-block"
                                                     AutoDetectMarkdown="false" />
                            }
                        </MudPaper>
                    }
                }

                @if (SelectedVirtualNode.ReplanRounds.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2">Replan Rounds</MudText>
                    @foreach (var round in SelectedVirtualNode.ReplanRounds)
                    {
                        <MudPaper Class="pa-3 mb-2 planning-step-call" Outlined="true">
                            <MudText Typo="Typo.caption">round @round.Round | done: @round.Done</MudText>
                            <MudText Typo="Typo.body2" Class="mt-1">@round.Reason</MudText>
                            <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Action Batch</MudText>
                            <PlanningValueDisplay Json="@round.ActionBatch"
                                                 PaperClass="pa-3 mt-1 planning-step-block"
                                                 AutoDetectMarkdown="false" />
                            <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Action Results</MudText>
                            <PlanningValueDisplay Json="@round.ActionResults"
                                                 PaperClass="pa-3 mt-1 planning-step-block"
                                                 AutoDetectMarkdown="false" />
                        </MudPaper>
                    }
                }
            }
            else if (SelectedVirtualNode.FinalResult is not null)
            {
                @if (!string.IsNullOrWhiteSpace(SelectedVirtualNode.Summary))
                {
                    <MudText Typo="Typo.subtitle2">Summary</MudText>
                    <PlanningValueDisplay Text="@SelectedVirtualNode.Summary" AutoDetectMarkdown="false" />
                }

                <MudText Typo="Typo.subtitle2">Outcome</MudText>
                <PlanningValueDisplay Text="@($"ok: {SelectedVirtualNode.FinalResult.Ok.ToString().ToLowerInvariant()}")" AutoDetectMarkdown="false" />

                @if (SelectedVirtualNode.FinalResult.Ok)
                {
                    @if (SelectedVirtualNode.FinalResult.Data is not null)
                    {
                        <MudText Typo="Typo.subtitle2">Result</MudText>
                        <PlanningValueDisplay Json="@SelectedVirtualNode.FinalResult.Data"
                                             AutoDetectMarkdown="true" />
                    }
                }
                else if (SelectedVirtualNode.FinalResult.Error is not null)
                {
                    @if (!string.IsNullOrWhiteSpace(SelectedVirtualNode.FinalResult.Error.Code))
                    {
                        <MudText Typo="Typo.subtitle2">Error Code</MudText>
                        <PlanningValueDisplay Text="@SelectedVirtualNode.FinalResult.Error.Code" AutoDetectMarkdown="false" />
                    }

                    @if (!string.IsNullOrWhiteSpace(SelectedVirtualNode.FinalResult.Error.Message))
                    {
                        <MudText Typo="Typo.subtitle2">Error Message</MudText>
                        <PlanningValueDisplay Text="@SelectedVirtualNode.FinalResult.Error.Message" AutoDetectMarkdown="false" />
                    }

                    @if (SelectedVirtualNode.FinalResult.Error.Details is not null)
                    {
                        <MudText Typo="Typo.subtitle2">Error Details</MudText>
                        <PlanningValueDisplay Json="@SelectedVirtualNode.FinalResult.Error.Details"
                                             AutoDetectMarkdown="false" />
                    }
                }
            }

            @if (SelectedVirtualNode.Diagnostics.Count > 0)
            {
                <MudText Typo="Typo.subtitle2">Diagnostics</MudText>
                @foreach (var diagnostic in SelectedVirtualNode.Diagnostics)
                {
                    <MudPaper Class="pa-3 mb-2 planning-step-call" Outlined="true">
                        <MudText Typo="Typo.caption">@diagnostic.Source</MudText>
                        <MudText Typo="Typo.body2" Class="mt-1">@diagnostic.Message</MudText>
                    </MudPaper>
                }
            }
        </MudStack>
    </MudPaper>
}
else if (SelectedStep is null)
{
    <MudPaper Class="pa-4 planning-step-details" Outlined="true">
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Select a step or connection on the graph to inspect prompts, calls, bindings, and outputs.</MudText>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-4 planning-step-details" Outlined="true">
        <MudStack Spacing="2">
            <div>
                <MudText Typo="Typo.h6">@SelectedStep.Id</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetKind(SelectedStep): @GetName(SelectedStep) | status: @SelectedStep.Status</MudText>
            </div>

            @if (!string.IsNullOrWhiteSpace(SelectedStep.SystemPrompt))
            {
                <MudText Typo="Typo.subtitle2">System Prompt</MudText>
                <PlanningValueDisplay Text="@SelectedStep.SystemPrompt" AutoDetectMarkdown="false" />
            }

            @if (!string.IsNullOrWhiteSpace(SelectedStep.UserPrompt))
            {
                <MudText Typo="Typo.subtitle2">User Prompt</MudText>
                <PlanningValueDisplay Text="@SelectedStep.UserPrompt" AutoDetectMarkdown="false" />
            }

            @foreach (var promptEvent in PromptEvents)
            {
                <MudText Typo="Typo.subtitle2">Prepared Prompt</MudText>
                <PlanningValueDisplay Text="@promptEvent.FullUserPrompt" AutoDetectMarkdown="false" />
            }

            @if (SelectedStep.In.Count > 0)
            {
                <MudText Typo="Typo.subtitle2">Input Bindings</MudText>
                <PlanningValueDisplay Text="@SerializeJson(SelectedStep.In)" AutoDetectMarkdown="false" />
            }

            @if (SelectedStep.Result is not null)
            {
                <MudText Typo="Typo.subtitle2">Result</MudText>
                <PlanningValueDisplay Json="@SelectedStep.Result" AutoDetectMarkdown="true" />
            }

            @if (SelectedStep.Error is not null)
            {
                <MudText Typo="Typo.subtitle2">Error</MudText>
                <PlanningValueDisplay Text="@SerializeJson(SelectedStep.Error)" AutoDetectMarkdown="false" />
            }

            @if (CallEvents.Count > 0)
            {
                <MudText Typo="Typo.subtitle2">Calls</MudText>
                @foreach (var callEvent in CallEvents)
                {
                    <MudPaper Class="pa-3 mb-2 planning-step-call" Outlined="true">
                        <MudText Typo="Typo.caption">call @callEvent.CallIndex | ok: @callEvent.Ok</MudText>
                        @if (callEvent.Output is not null)
                        {
                            <MudText Typo="Typo.caption" Class="mt-1 mud-text-secondary">Output</MudText>
                            <PlanningValueDisplay Json="@callEvent.Output"
                                                 PaperClass="pa-3 mt-1 planning-step-block"
                                                 AutoDetectMarkdown="true" />
                        }
                        @if (callEvent.Error is not null)
                        {
                            <MudText Typo="Typo.caption" Class="mt-1 mud-text-secondary">Error</MudText>
                            <PlanningValueDisplay Text="@SerializeJson(callEvent.Error)"
                                                 PaperClass="pa-3 mt-1 planning-step-block"
                                                 AutoDetectMarkdown="false" />
                        }
                    </MudPaper>
                }
            }

            @foreach (var responseEvent in ResponseEvents)
            {
                <MudText Typo="Typo.subtitle2">Raw LLM Response</MudText>
                <PlanningValueDisplay Text="@responseEvent.RawResponseText" AutoDetectMarkdown="false" />
            }
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public PlanDefinition? Plan { get; set; }
    [Parameter] public string? ActiveStepId { get; set; }
    [Parameter] public string? SelectedStepId { get; set; }
    [Parameter] public IReadOnlyList<PlanRunEvent> Events { get; set; } = [];
    [Parameter] public IReadOnlyList<PlanningToolOption> AvailableTools { get; set; } = [];
    [Parameter] public ResultEnvelope<JsonElement?>? FinalResult { get; set; }

    private IReadOnlyList<PlanningVirtualNodeDescriptor> VirtualNodes =>
        PlanningVirtualNodeProjection.Build(Plan, Events, AvailableTools, FinalResult);

    private IReadOnlyList<PlanningGraphLinkDescriptor> LinkDescriptors =>
        Plan is null
            ? []
            : PlanningGraphLinkProjection.Build(Plan.Steps, FinalResult);

    private PlanningGraphLinkDescriptor? SelectedLink => ResolveSelectedLink();

    private PlanningVirtualNodeDescriptor? SelectedVirtualNode => ResolveSelectedVirtualNode();

    private PlanStep? SelectedStep => ResolveSelectedStep();

    private PlanStep? SelectedLinkSourceStep =>
        SelectedLink is null || Plan is null
            ? null
            : Plan.Steps.FirstOrDefault(step => string.Equals(step.Id, SelectedLink.SourceId, StringComparison.Ordinal));

    private PlanStep? SelectedLinkTargetStep =>
        SelectedLink is null ||
        Plan is null ||
        string.Equals(SelectedLink.TargetId, PlanningVirtualNodeDescriptor.ResultNodeId, StringComparison.Ordinal)
            ? null
            : Plan.Steps.FirstOrDefault(step => string.Equals(step.Id, SelectedLink.TargetId, StringComparison.Ordinal));

    private string? EffectiveStepId => SelectedStep?.Id;

    private IReadOnlyList<StepExecutionTrace> FailedReplanTraces =>
        SelectedVirtualNode?.ReplanStarted?.Request.ExecutionResult.StepTraces
            .Where(trace => !trace.Success)
            .ToList()
        ?? [];

    private IReadOnlyList<AgentPromptPreparedEvent> PromptEvents =>
        Events.OfType<AgentPromptPreparedEvent>()
            .Where(evt => string.Equals(evt.StepId, EffectiveStepId, StringComparison.Ordinal))
            .ToList();

    private IReadOnlyList<AgentResponseReceivedEvent> ResponseEvents =>
        Events.OfType<AgentResponseReceivedEvent>()
            .Where(evt => string.Equals(evt.StepId, EffectiveStepId, StringComparison.Ordinal))
            .ToList();

    private IReadOnlyList<StepCallCompletedEvent> CallEvents =>
        Events.OfType<StepCallCompletedEvent>()
            .Where(evt => string.Equals(evt.StepId, EffectiveStepId, StringComparison.Ordinal))
            .ToList();

    private PlanningGraphLinkDescriptor? ResolveSelectedLink()
    {
        foreach (var candidateId in GetSelectionCandidates())
        {
            if (string.IsNullOrWhiteSpace(candidateId))
                continue;

            var link = LinkDescriptors.FirstOrDefault(candidate =>
                string.Equals(candidate.Id, candidateId, StringComparison.Ordinal));
            if (link is not null)
                return link;
        }

        return null;
    }

    private PlanningVirtualNodeDescriptor? ResolveSelectedVirtualNode()
    {
        foreach (var candidateId in GetSelectionCandidates())
        {
            if (string.IsNullOrWhiteSpace(candidateId))
                continue;

            var virtualNode = VirtualNodes.FirstOrDefault(candidate =>
                string.Equals(candidate.Id, candidateId, StringComparison.Ordinal));
            if (virtualNode is not null)
                return virtualNode;
        }

        return null;
    }

    private PlanStep? ResolveSelectedStep()
    {
        if (Plan is null || Plan.Steps.Count == 0)
            return null;

        foreach (var candidateId in GetSelectionCandidates())
        {
            if (string.IsNullOrWhiteSpace(candidateId))
                continue;

            if (LinkDescriptors.Any(link => string.Equals(link.Id, candidateId, StringComparison.Ordinal)) ||
                VirtualNodes.Any(node => string.Equals(node.Id, candidateId, StringComparison.Ordinal)))
            {
                return null;
            }

            var step = Plan.Steps.FirstOrDefault(candidate =>
                string.Equals(candidate.Id, candidateId, StringComparison.Ordinal));
            if (step is not null)
                return step;
        }

        return VirtualNodes.Count == 0
            ? Plan.Steps[0]
            : null;
    }

    private IEnumerable<string?> GetSelectionCandidates()
    {
        yield return SelectedStepId;
        yield return ActiveStepId;
    }

    private static string GetKind(PlanStep step) =>
        string.IsNullOrWhiteSpace(step.Tool) ? "llm" : "tool";

    private static string GetName(PlanStep step) =>
        string.IsNullOrWhiteSpace(step.Tool) ? step.Llm ?? string.Empty : step.Tool;

    private static string GetLinkTitle(PlanningGraphLinkDescriptor link) =>
        $"{link.SourceId} -> {GetTargetLabel(link)}";

    private static string GetLinkSubtitle(PlanningGraphLinkDescriptor link) =>
        link.Kind == PlanningGraphLinkKind.Dependency
            ? $"dependency | bindings: {link.Matches.Count}"
            : "terminal step -> final result";

    private static string GetTargetLabel(PlanningGraphLinkDescriptor link) =>
        string.Equals(link.TargetId, PlanningVirtualNodeDescriptor.ResultNodeId, StringComparison.Ordinal)
            ? "result"
            : link.TargetId;

    private static string BuildStepSummary(PlanStep? step, string fallbackId)
    {
        if (step is null)
        {
            return fallbackId;
        }

        return $"{step.Id}{Environment.NewLine}{GetKind(step)}: {GetName(step)}{Environment.NewLine}status: {step.Status}";
    }

    private static string BuildTargetSummary(PlanningGraphLinkDescriptor link, PlanStep? targetStep)
    {
        if (link.Kind == PlanningGraphLinkKind.Result)
        {
            return "result node" + Environment.NewLine + "Aggregates the final answer returned by the planning run.";
        }

        return BuildStepSummary(targetStep, link.TargetId);
    }

    private static string SerializeJson<T>(T value) =>
        PlanningJson.SerializeIndented(value);
}
