@using MudBlazor

<MudPaper Class="pa-4 h-100" Outlined="true">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">@Title</MudText>

        @if (string.IsNullOrWhiteSpace(Content))
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">No data.</MudText>
        }
        else
        {
            <MudTextField T="string"
                          Value="@Content"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          Lines="14"
                          FullWidth="true" />
        }

        @if (!string.IsNullOrWhiteSpace(RawContent))
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Raw response</MudText>
            <MudTextField T="string"
                          Value="@RawContent"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          Lines="8"
                          FullWidth="true" />
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;

    [Parameter] public string? Content { get; set; }

    [Parameter] public string? RawContent { get; set; }
}
