@using System.Text.Json
@using System.Text.Json.Nodes
@using ChatClient.Api.PlanningRuntime.Common
@using ChatClient.Api.PlanningRuntime.Execution
@using MudBlazor
@inject IJSRuntime JSRuntime

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Replan And Runtime Log</MudText>
            @if (HasFullLog || HasDiagnosticBundle)
            {
                <MudStack Row="true" Spacing="1">
                    @if (HasFullLog)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   OnClick="CopyFullLogAsync">
                            Copy full log
                        </MudButton>
                    }
                    @if (HasDiagnosticBundle)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   OnClick="CopyDiagnosticBundleAsync">
                            Copy diagnostic bundle
                        </MudButton>
                    }
                </MudStack>
            }
        </MudStack>

        @foreach (var replanEvent in ReplanEvents)
        {
            <MudExpansionPanels MultiExpansion="true">
                <MudExpansionPanel Text="@($"round {replanEvent.Round} | done={replanEvent.Done}")">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@replanEvent.Reason</MudText>
                    <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Action Batch</MudText>
                    <MudPaper Class="pa-3 planning-log-block">@SerializeJson(replanEvent.ActionBatch)</MudPaper>
                    <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Action Results</MudText>
                    <MudPaper Class="pa-3 planning-log-block">@SerializeJson(replanEvent.ActionResults)</MudPaper>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }

        @if (HasFullLog)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Copy full log exports only text log lines. Copy diagnostic bundle exports log lines plus structured runtime events.
            </MudText>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public IReadOnlyList<PlanRunEvent> Events { get; set; } = [];
    [Parameter] public IReadOnlyList<string> LogLines { get; set; } = [];

    private IReadOnlyList<ReplanRoundCompletedEvent> ReplanEvents =>
        Events.OfType<ReplanRoundCompletedEvent>().ToList();

    private bool HasFullLog => LogLines.Count > 0;
    private bool HasDiagnosticBundle => LogLines.Count > 0 || Events.Count > 0;

    private Task CopyFullLogAsync() =>
        JSRuntime.InvokeVoidAsync("copyText", string.Join(Environment.NewLine, LogLines)).AsTask();

    private Task CopyDiagnosticBundleAsync() =>
        JSRuntime.InvokeVoidAsync("copyText", PlanningJson.SerializeNodeIndented(BuildDiagnosticBundle())).AsTask();

    private static string SerializeJson<T>(T value) =>
        PlanningJson.SerializeIndented(value);

    private JsonObject BuildDiagnosticBundle() => new()
    {
        ["copiedAtUtc"] = DateTimeOffset.UtcNow,
        ["logLineCount"] = LogLines.Count,
        ["eventCount"] = Events.Count,
        ["logLines"] = new JsonArray(LogLines.Select(static line => JsonValue.Create(line)).ToArray()),
        ["events"] = new JsonArray(Events.Select(SerializeEvent).ToArray())
    };

    private static JsonObject SerializeEvent(PlanRunEvent planRunEvent)
    {
        var serialized = JsonSerializer.SerializeToNode((object)planRunEvent, planRunEvent.GetType(), PlanningJson.IndentedOptions) as JsonObject
            ?? new JsonObject();

        var result = new JsonObject
        {
            ["eventType"] = planRunEvent.GetType().Name
        };

        foreach (var property in serialized)
            result[property.Key] = property.Value?.DeepClone();

        return result;
    }
}
