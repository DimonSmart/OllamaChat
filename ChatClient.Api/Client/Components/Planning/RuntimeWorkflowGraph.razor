@using System.Text.Json
@using ChatClient.Api.PlanningRuntime.Common
@using ChatClient.Api.PlanningRuntime.Execution
@using ChatClient.Api.PlanningRuntime.LowLevel
@using ChatClient.Api.PlanningRuntime.Outline
@using ChatClient.Api.PlanningRuntime.Planning
@using ChatClient.Api.PlanningRuntime.Runtime
@using ChatClient.Api.PlanningRuntime.Shared
@using Microsoft.JSInterop
@using MudBlazor
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="@GetShellCssClass()">
<MudPaper Class="pa-4" Outlined="true" Style="@GetShellPaperStyle()">
    <MudStack Class="runtime-workflow-shell-stack" Spacing="2">
        <div class="runtime-workflow-header">
            <div>
                <MudText Typo="Typo.h6">Workflow Graph</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Runtime step graph with live execution state and per-element details.
                </MudText>
            </div>
        </div>

        @if (!Graph.HasContent)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Planning stages and runtime workflow will appear here as the run progresses.
            </MudText>
        }
        else
        {
            <div class="runtime-workflow-layout">
                <div class="runtime-workflow-canvas-shell">
                    <div class="runtime-workflow-toolbar">
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Class="runtime-workflow-toolbar-button"
                                       Size="Size.Small"
                                       Variant="Variant.Filled"
                                       Color="Color.Default"
                                       OnClick="ZoomInAsync"
                                       aria-label="Zoom in" />
                        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                       Class="runtime-workflow-toolbar-button"
                                       Size="Size.Small"
                                       Variant="Variant.Filled"
                                       Color="Color.Default"
                                       OnClick="ZoomOutAsync"
                                       aria-label="Zoom out" />
                        <MudButton Variant="Variant.Filled"
                                   Class="runtime-workflow-toolbar-button runtime-workflow-toolbar-button-wide"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   OnClick="FitToScreenAsync">
                            Fit
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Class="runtime-workflow-toolbar-button runtime-workflow-toolbar-button-wide"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   OnClick="ResetViewportAsync">
                            100%
                        </MudButton>
                        <MudTooltip Text="@(_isFullscreen ? "Exit full screen" : "Full screen")">
                            <MudIconButton Icon="@(_isFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                           Class="runtime-workflow-toolbar-button"
                                           Size="Size.Small"
                                           Variant="Variant.Filled"
                                           Color="Color.Default"
                                           OnClick="ToggleFullscreenAsync"
                                           aria-label="@(_isFullscreen ? "Exit full screen" : "Full screen")" />
                        </MudTooltip>
                    </div>

                    <div @ref="_viewportElement"
                         class="@GetViewportCssClass()"
                         tabindex="0">
                        <div class="runtime-workflow-stage" style="@GetStageStyle()">
                            <div class="runtime-workflow-canvas" style="@GetCanvasStyle()">
                                <svg class="runtime-workflow-links"
                                     width="@Graph.Width"
                                     height="@Graph.Height"
                                     viewBox="@($"0 0 {Graph.Width} {Graph.Height}")">
                                    <defs>
                                        <marker id="@ArrowMarkerId"
                                                viewBox="0 0 12 12"
                                                refX="10"
                                                refY="6"
                                                markerWidth="10"
                                                markerHeight="10"
                                                orient="auto"
                                                markerUnits="strokeWidth">
                                            <path d="M 0 1 L 10 6 L 0 11 z" fill="context-stroke" />
                                        </marker>
                                    </defs>

                                    @foreach (var link in Graph.Links)
                                    {
                                        <path class="runtime-workflow-link"
                                              d="@BuildPath(link)"
                                              stroke="@GetLinkStroke(link)"
                                              stroke-width="@GetLinkWidth(link)"
                                              stroke-dasharray="@GetLinkDashArray(link)"
                                              marker-end="@ArrowMarkerUrl"
                                              fill="none" />
                                        <path class="runtime-workflow-link-hit"
                                              d="@BuildPath(link)"
                                              @onclick="@(() => SelectLink(link.Id))" />
                                    }
                                </svg>

                                @foreach (var node in Graph.Nodes)
                                {
                                    <button type="button"
                                            class="@GetNodeCssClass(node)"
                                            style="@GetNodeStyle(node)"
                                            data-node-id="@node.Id"
                                            @onclick="@(() => SelectNode(node.Id))">
                                        <div class="runtime-workflow-node-header">
                                            <span class="runtime-workflow-node-id">@node.Title</span>
                                            <span class="runtime-workflow-node-badge">@GetNodeBadge(node)</span>
                                        </div>
                                        <div class="runtime-workflow-node-meta">@node.Subtitle</div>
                                        @if (!string.IsNullOrWhiteSpace(node.Summary))
                                        {
                                            <div class="runtime-workflow-node-summary">@node.Summary</div>
                                        }
                                        <div class="runtime-workflow-node-status">status: @node.Status</div>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <MudPaper Class="pa-4 runtime-workflow-details-shell" Outlined="true">
                    @if (SelectedNode is not null)
                    {
                        <div class="planning-step-details">
                            <MudStack Spacing="2">
                                <div>
                                    <MudText Typo="Typo.h6">@SelectedNode.Title</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @SelectedNode.Subtitle | status: @SelectedNode.Status
                                    </MudText>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(SelectedNode.Summary) && !ShouldRenderUserFacingAnswerBeforeSummary(SelectedNode))
                                {
                                    <MudText Typo="Typo.subtitle2">Summary</MudText>
                                    <PlanningValueDisplay Text="@SelectedNode.Summary" AutoDetectMarkdown="false" />
                                }

                                @if (SelectedNode.Kind == RuntimeWorkflowNodeKind.RequestBrief && SelectedNode.RequestBrief is not null)
                                {
                                    <MudText Typo="Typo.subtitle2">Rewritten Request</MudText>
                                    <PlanningValueDisplay Text="@SelectedNode.RequestBrief.RewrittenRequest" AutoDetectMarkdown="false" />

                                    <MudText Typo="Typo.subtitle2">Goal</MudText>
                                    <PlanningValueDisplay Text="@SelectedNode.RequestBrief.Goal" AutoDetectMarkdown="false" />

                                    @if (SelectedNode.RequestBrief.Deliverables.Count > 0)
                                    {
                                        <MudText Typo="Typo.subtitle2">Deliverables</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.RequestBrief.Deliverables)" AutoDetectMarkdown="false" />
                                    }

                                    @if (SelectedNode.RequestBrief.Constraints.Count > 0)
                                    {
                                        <MudText Typo="Typo.subtitle2">Constraints</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.RequestBrief.Constraints)" AutoDetectMarkdown="false" />
                                    }

                                    @if (SelectedNode.RequestBrief.SuggestedPlanOutline.Count > 0)
                                    {
                                        <MudText Typo="Typo.subtitle2">Suggested Outline</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.RequestBrief.SuggestedPlanOutline)" AutoDetectMarkdown="false" />
                                    }

                                    <MudText Typo="Typo.subtitle2">Request Brief Contract</MudText>
                                    <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.RequestBrief)" AutoDetectMarkdown="false" />
                                }
                                else if (SelectedNode.Kind == RuntimeWorkflowNodeKind.OutlinePlan)
                                {
                                    @if (SelectedNode.OutlinePlan is null)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                            Outline plan is not available yet.
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.subtitle2">Outline Goal</MudText>
                                        <PlanningValueDisplay Text="@SelectedNode.OutlinePlan.Goal" AutoDetectMarkdown="false" />

                                        @if (!string.IsNullOrWhiteSpace(SelectedNode.OutlinePlan.BlockedReason))
                                        {
                                            <MudText Typo="Typo.subtitle2">Blocked Reason</MudText>
                                            <PlanningValueDisplay Text="@SelectedNode.OutlinePlan.BlockedReason" AutoDetectMarkdown="false" />
                                        }

                                        <MudText Typo="Typo.subtitle2">Outline Plan</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.OutlinePlan)" AutoDetectMarkdown="false" />
                                    }
                                }
                                else if (SelectedNode.Kind == RuntimeWorkflowNodeKind.LowLevelPlan)
                                {
                                    @if (SelectedNode.LowLevelPlan is null)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                            Low-level plan is not available yet.
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.subtitle2">Low-Level Goal</MudText>
                                        <PlanningValueDisplay Text="@SelectedNode.LowLevelPlan.Goal" AutoDetectMarkdown="false" />

                                        @if (!string.IsNullOrWhiteSpace(SelectedNode.LowLevelPlan.BlockedReason))
                                        {
                                            <MudText Typo="Typo.subtitle2">Blocked Reason</MudText>
                                            <PlanningValueDisplay Text="@SelectedNode.LowLevelPlan.BlockedReason" AutoDetectMarkdown="false" />
                                        }

                                        <MudText Typo="Typo.subtitle2">Low-Level Plan</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.LowLevelPlan)" AutoDetectMarkdown="false" />
                                    }
                                }
                                else if (SelectedNode.Kind == RuntimeWorkflowNodeKind.RuntimePlan)
                                {
                                    @if (SelectedNode.CompiledPlan is null)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                            Runtime plan is not available yet.
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.subtitle2">Runtime Goal</MudText>
                                        <PlanningValueDisplay Text="@SelectedNode.CompiledPlan.Goal" AutoDetectMarkdown="false" />

                                        <MudText Typo="Typo.subtitle2">Runtime Plan</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.CompiledPlan)" AutoDetectMarkdown="false" />
                                    }
                                }
                                else if (SelectedNode.Kind == RuntimeWorkflowNodeKind.Step && SelectedNode.Step is not null)
                                {
                                    @if (!string.IsNullOrWhiteSpace(SelectedNode.Step.Purpose))
                                    {
                                        <MudText Typo="Typo.subtitle2">Purpose</MudText>
                                        <PlanningValueDisplay Text="@SelectedNode.Step.Purpose" AutoDetectMarkdown="false" />
                                    }

                                    @if (!string.IsNullOrWhiteSpace(SelectedNode.Step.Instruction)
                                        && !string.Equals(SelectedNode.Step.Instruction, SelectedNode.Step.Purpose, StringComparison.Ordinal))
                                    {
                                        <MudText Typo="Typo.subtitle2">Instruction</MudText>
                                        <PlanningValueDisplay Text="@SelectedNode.Step.Instruction" AutoDetectMarkdown="false" />
                                    }

                                    @if (SelectedNode.Trace?.ResolvedInputs is not null)
                                    {
                                        <MudText Typo="Typo.subtitle2">Resolved Inputs</MudText>
                                        <PlanningValueDisplay Json="@SelectedNode.Trace.ResolvedInputs" AutoDetectMarkdown="false" />
                                    }

                                    @if (SelectedNode.Trace?.Output is not null)
                                    {
                                        <MudText Typo="Typo.subtitle2">Output</MudText>
                                        <PlanningValueDisplay Json="@SelectedNode.Trace.Output" AutoDetectMarkdown="false" />
                                    }

                                    @if (SelectedNode.Trace?.Error is not null)
                                    {
                                        <MudText Typo="Typo.subtitle2">Execution Error</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.Trace.Error)" AutoDetectMarkdown="false" />
                                    }

                                    <MudText Typo="Typo.subtitle2">Step Contract</MudText>
                                    <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.Step)" AutoDetectMarkdown="false" />
                                }
                                else if (SelectedNode.Kind == RuntimeWorkflowNodeKind.Result)
                                {
                                    @if (SelectedNode.FinalResult is null)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                            Final result is not available yet.
                                        </MudText>
                                    }
                                    else if (SelectedNode.FinalResult.Ok)
                                    {
                                        @if (TryExtractUserFacingAnswer(SelectedNode.FinalResult.Data, out var userFacingAnswer))
                                        {
                                            <MudText Typo="Typo.subtitle2">User-Facing Answer</MudText>
                                            <PlanningValueDisplay Text="@userFacingAnswer"
                                                                 AutoDetectMarkdown="true"
                                                                 InitiallyExpanded="true" />

                                            @if (!string.IsNullOrWhiteSpace(SelectedNode.Summary))
                                            {
                                                <MudText Typo="Typo.subtitle2">Summary</MudText>
                                                <PlanningValueDisplay Text="@SelectedNode.Summary" AutoDetectMarkdown="false" />
                                            }

                                            <MudText Typo="Typo.subtitle2">Structured Result</MudText>
                                            <PlanningValueDisplay Json="@SelectedNode.FinalResult.Data" AutoDetectMarkdown="false" />
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.subtitle2">Final Result</MudText>
                                            <PlanningValueDisplay Json="@SelectedNode.FinalResult.Data" />
                                        }
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.subtitle2">Final Error</MudText>
                                        <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.FinalResult)" AutoDetectMarkdown="false" />
                                    }
                                }

                                @if (SelectedNode.Issues.Count > 0)
                                {
                                    <MudText Typo="Typo.subtitle2">Issues</MudText>
                                    <PlanningValueDisplay Text="@SerializeIndented(SelectedNode.Issues)" AutoDetectMarkdown="false" />
                                }
                            </MudStack>
                        </div>
                    }
                    else if (SelectedLink is not null)
                    {
                        <div class="planning-step-details">
                            <MudStack Spacing="2">
                                <div>
                                    <MudText Typo="Typo.h6">@GetNodeTitle(SelectedLink.SourceId) -> @GetNodeTitle(SelectedLink.TargetId)</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @GetLinkMetaText(SelectedLink)
                                    </MudText>
                                </div>

                                <MudText Typo="Typo.subtitle2">Link</MudText>
                                <PlanningValueDisplay Text="@SerializeIndented(new
                                {
                                    kind = SelectedLink.Kind.ToString().ToLowerInvariant(),
                                    from = SelectedLink.From,
                                    label = SelectedLink.Label,
                                    mode = SelectedLink.Mode ?? "value"
                                })" AutoDetectMarkdown="false" />

                                @if (SelectedLinkSource?.Trace?.Output is not null)
                                {
                                    <MudText Typo="Typo.subtitle2">Source Output</MudText>
                                    <PlanningValueDisplay Json="@SelectedLinkSource.Trace.Output" AutoDetectMarkdown="false" />
                                }
                            </MudStack>
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            Select a node or link to inspect it.
                        </MudText>
                    }
                </MudPaper>
            </div>
        }
    </MudStack>
</MudPaper>
</div>

@code {
    private const double ZoomMin = 0.1d;
    private const double ZoomMax = 1.6d;
    private const double ZoomStepFactor = 1.15d;
    private const double ViewportPadding = 28d;
    private const double NodeDragMinX = 0d;
    private const double NodeDragMinY = 0d;
    private const int ViewportMeasurementRetries = 5;

    private RuntimeWorkflowGraphDescriptor Graph { get; set; } = new();
    private readonly Dictionary<string, RuntimeWorkflowNodeLayout> _nodeLayouts = new(StringComparer.Ordinal);
    private string? _selectedElementId;
    private DotNetObjectReference<RuntimeWorkflowGraph>? _selfReference;
    private ElementReference _viewportElement;
    private string? _interopRegistrationId;
    private string? _structureKey;
    private double _zoom = 1d;
    private double _panX;
    private double _panY;
    private double _panStartX;
    private double _panStartY;
    private double _pointerStartX;
    private double _pointerStartY;
    private string? _dragNodeId;
    private double _dragNodeStartX;
    private double _dragNodeStartY;
    private double _dragNodePointerStartX;
    private double _dragNodePointerStartY;
    private bool _fitPending;
    private bool _isPanning;
    private bool _jsRegistrationInFlight;
    private bool _isFullscreen;

    [Parameter] public RuntimePlan? Plan { get; set; }
    [Parameter] public IReadOnlyList<PlanRunEvent> Events { get; set; } = [];
    [Parameter] public ResultEnvelope<JsonElement?>? FinalResult { get; set; }
    [Parameter] public string? ActiveRuntimeStepId { get; set; }

    private string ArrowMarkerId => $"{GetHashCode():x}-runtime-workflow-arrow";

    private string ArrowMarkerUrl => $"url(#{ArrowMarkerId})";

    private RuntimeWorkflowNodeDescriptor? SelectedNode =>
        string.IsNullOrWhiteSpace(_selectedElementId)
            ? null
            : Graph.Nodes.FirstOrDefault(node => string.Equals(node.Id, _selectedElementId, StringComparison.Ordinal));

    private RuntimeWorkflowLinkDescriptor? SelectedLink =>
        SelectedNode is not null || string.IsNullOrWhiteSpace(_selectedElementId)
            ? null
            : Graph.Links.FirstOrDefault(link => string.Equals(link.Id, _selectedElementId, StringComparison.Ordinal));

    private RuntimeWorkflowNodeDescriptor? SelectedLinkSource =>
        SelectedLink is null
            ? null
            : Graph.Nodes.FirstOrDefault(node => string.Equals(node.Id, SelectedLink.SourceId, StringComparison.Ordinal));

    private RuntimeWorkflowNodeDescriptor? SelectedLinkTarget =>
        SelectedLink is null
            ? null
            : Graph.Nodes.FirstOrDefault(node => string.Equals(node.Id, SelectedLink.TargetId, StringComparison.Ordinal));

    private string GetShellCssClass()
    {
        var css = "runtime-workflow-shell";
        if (_isFullscreen)
        {
            css += " runtime-workflow-shell-fullscreen";
        }

        return css;
    }

    private string GetShellPaperStyle() =>
        _isFullscreen
            ? "height:100%;overflow:hidden;"
            : string.Empty;

    protected override void OnParametersSet()
    {
        Graph = RuntimeWorkflowGraphProjection.Build(Plan, Events, FinalResult, ActiveRuntimeStepId);
        PruneNodeLayouts();

        var validIds = Graph.Nodes.Select(static node => node.Id)
            .Concat(Graph.Links.Select(static link => link.Id))
            .ToHashSet(StringComparer.Ordinal);
        if (string.IsNullOrWhiteSpace(_selectedElementId) || !validIds.Contains(_selectedElementId))
            _selectedElementId = Graph.DefaultSelectionId;

        var structureKey = BuildStructureKey(Graph);
        if (!string.Equals(_structureKey, structureKey, StringComparison.Ordinal))
        {
            _structureKey = structureKey;
            if (Graph.HasContent)
            {
                _fitPending = true;
            }
            else
            {
                ResetViewportState();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Graph.HasContent)
            return;

        _selfReference ??= DotNetObjectReference.Create(this);

        if (!_jsRegistrationInFlight)
        {
            try
            {
                _jsRegistrationInFlight = true;
                _interopRegistrationId = await JSRuntime.InvokeAsync<string>(
                    "runtimeWorkflowGraphInterop.refreshRegistration",
                    _viewportElement,
                    _selfReference,
                    _interopRegistrationId);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException)
            {
            }
            finally
            {
                _jsRegistrationInFlight = false;
            }
        }

        if (_fitPending)
            await FitToViewportAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (!string.IsNullOrWhiteSpace(_interopRegistrationId))
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("runtimeWorkflowGraphInterop.unregister", _interopRegistrationId);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException)
            {
            }
        }

        _selfReference?.Dispose();
    }

    [JSInvokable]
    public Task HandleViewportPointerDown(double clientX, double clientY)
    {
        if (!Graph.HasContent)
            return Task.CompletedTask;

        _isPanning = true;
        _panStartX = _panX;
        _panStartY = _panY;
        _pointerStartX = clientX;
        _pointerStartY = clientY;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleViewportPointerMove(double clientX, double clientY)
    {
        if (!_isPanning)
            return Task.CompletedTask;

        _panX = _panStartX + (clientX - _pointerStartX);
        _panY = _panStartY + (clientY - _pointerStartY);
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleViewportPointerUp()
    {
        if (!_isPanning)
            return Task.CompletedTask;

        _isPanning = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleViewportPointerCancel()
    {
        if (!_isPanning)
            return Task.CompletedTask;

        _isPanning = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleNodePointerDown(string nodeId, double clientX, double clientY)
    {
        if (!TryGetNodeLayout(nodeId, out var layout))
            return Task.CompletedTask;

        _dragNodeId = nodeId;
        _dragNodeStartX = layout.X;
        _dragNodeStartY = layout.Y;
        _dragNodePointerStartX = clientX;
        _dragNodePointerStartY = clientY;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleNodePointerMove(string nodeId, double clientX, double clientY)
    {
        if (!string.Equals(_dragNodeId, nodeId, StringComparison.Ordinal))
            return Task.CompletedTask;

        var deltaX = (clientX - _dragNodePointerStartX) / _zoom;
        var deltaY = (clientY - _dragNodePointerStartY) / _zoom;
        _nodeLayouts[nodeId] = ClampNodeLayout(
            _dragNodeStartX + deltaX,
            _dragNodeStartY + deltaY);
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleNodePointerUp(string nodeId)
    {
        if (!string.Equals(_dragNodeId, nodeId, StringComparison.Ordinal))
            return Task.CompletedTask;

        _dragNodeId = null;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleNodePointerCancel(string nodeId)
    {
        if (!string.Equals(_dragNodeId, nodeId, StringComparison.Ordinal))
            return Task.CompletedTask;

        _dragNodeId = null;
        return InvokeAsync(StateHasChanged);
    }

    private void SelectNode(string nodeId) => _selectedElementId = nodeId;

    private void SelectLink(string linkId) => _selectedElementId = linkId;

    private async Task ZoomInAsync() => await ChangeZoomAsync(_zoom * ZoomStepFactor);

    private async Task ZoomOutAsync() => await ChangeZoomAsync(_zoom / ZoomStepFactor);

    private async Task FitToScreenAsync()
    {
        _fitPending = false;
        await FitToViewportAsync();
    }

    private async Task ToggleFullscreenAsync()
    {
        _isFullscreen = !_isFullscreen;
        if (Graph.HasContent)
        {
            _fitPending = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetViewportAsync()
    {
        var viewport = await GetViewportMetricsAsync();
        if (viewport is null)
            return;

        CenterGraph(1d, viewport.Width, viewport.Height);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ChangeZoomAsync(double requestedZoom)
    {
        var viewport = await GetViewportMetricsAsync();
        if (viewport is null)
            return;

        var clampedZoom = Math.Clamp(requestedZoom, ZoomMin, ZoomMax);
        if (Math.Abs(clampedZoom - _zoom) < 0.0001d)
            return;

        var centerGraphX = (viewport.Width / 2d - _panX) / _zoom;
        var centerGraphY = (viewport.Height / 2d - _panY) / _zoom;

        _zoom = clampedZoom;
        _panX = viewport.Width / 2d - centerGraphX * _zoom;
        _panY = viewport.Height / 2d - centerGraphY * _zoom;
        await InvokeAsync(StateHasChanged);
    }

    private async Task FitToViewportAsync()
    {
        var viewport = await GetViewportMetricsAsync();
        if (viewport is null || viewport.Width <= 0d || viewport.Height <= 0d)
            return;

        var transform = PlanningGraphViewportCalculator.Fit(
            GetCurrentBounds(),
            viewport.Width,
            viewport.Height,
            ViewportPadding,
            ZoomMin,
            ZoomMax);
        _zoom = transform.Zoom;
        _panX = transform.PanX;
        _panY = transform.PanY;
        _fitPending = false;
        await InvokeAsync(StateHasChanged);
    }

    private void CenterGraph(double zoom, double viewportWidth, double viewportHeight)
    {
        var transform = PlanningGraphViewportCalculator.Center(
            GetCurrentBounds(),
            viewportWidth,
            viewportHeight,
            zoom,
            ZoomMin,
            ZoomMax);
        _zoom = transform.Zoom;
        _panX = transform.PanX;
        _panY = transform.PanY;
    }

    private async Task<RuntimeWorkflowViewportMetrics?> GetViewportMetricsAsync()
    {
        for (var attempt = 0; attempt < ViewportMeasurementRetries; attempt++)
        {
            try
            {
                var metrics = await JSRuntime.InvokeAsync<RuntimeWorkflowViewportMetrics>(
                    "runtimeWorkflowGraphInterop.getViewportMetrics",
                    _viewportElement);
                if (metrics.Width > 0d && metrics.Height > 0d)
                    return metrics;
            }
            catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException)
            {
                return null;
            }

            await Task.Delay(16);
        }

        return null;
    }

    private static string BuildStructureKey(RuntimeWorkflowGraphDescriptor graph)
    {
        if (!graph.HasContent)
            return "empty";

        var nodePart = string.Join("|", graph.Nodes.Select(static node =>
            FormattableString.Invariant($"{node.Id}:{node.X:F0}:{node.Y:F0}")));
        var linkPart = string.Join("|", graph.Links.Select(static link => link.Id));
        return FormattableString.Invariant($"{graph.Width:F0}x{graph.Height:F0}::{nodePart}::{linkPart}");
    }

    private void ResetViewportState()
    {
        _zoom = 1d;
        _panX = 0d;
        _panY = 0d;
        _fitPending = false;
        _isPanning = false;
        _dragNodeId = null;
        _nodeLayouts.Clear();
    }

    private string GetViewportCssClass()
    {
        var css = "runtime-workflow-viewport";
        if (Graph.HasContent)
            css += " runtime-workflow-pan-ready";
        if (_isPanning)
            css += " runtime-workflow-panning";
        return css;
    }

    private string GetStageStyle() =>
        RuntimeWorkflowGraphFormatting.BuildStageStyle(Graph.Width, Graph.Height, _panX, _panY, _zoom);

    private string GetCanvasStyle() =>
        RuntimeWorkflowGraphFormatting.BuildCanvasStyle(Graph.Width, Graph.Height);

    private string GetNodeCssClass(RuntimeWorkflowNodeDescriptor node)
    {
        var css = "runtime-workflow-node";
        if (string.Equals(node.Status, "running", StringComparison.OrdinalIgnoreCase))
            css += " runtime-workflow-node-running";
        else if (string.Equals(node.Status, "done", StringComparison.OrdinalIgnoreCase))
            css += " runtime-workflow-node-done";
        else if (string.Equals(node.Status, "fail", StringComparison.OrdinalIgnoreCase))
            css += " runtime-workflow-node-fail";
        else
            css += " runtime-workflow-node-pending";

        if (node.Kind == RuntimeWorkflowNodeKind.Result)
            css += " runtime-workflow-node-result";
        else if (node.Kind == RuntimeWorkflowNodeKind.RequestBrief)
            css += " runtime-workflow-node-request-brief";
        else if (node.Kind == RuntimeWorkflowNodeKind.OutlinePlan)
            css += " runtime-workflow-node-outline";
        else if (node.Kind == RuntimeWorkflowNodeKind.LowLevelPlan)
            css += " runtime-workflow-node-low-level";
        else if (node.Kind == RuntimeWorkflowNodeKind.RuntimePlan)
            css += " runtime-workflow-node-runtime-plan";

        if (node.IsActive)
            css += " runtime-workflow-node-active";

        if (string.Equals(node.Id, _selectedElementId, StringComparison.Ordinal))
            css += " runtime-workflow-node-selected";

        if (string.Equals(node.Id, _dragNodeId, StringComparison.Ordinal))
            css += " runtime-workflow-node-dragging";

        return css;
    }

    private string GetNodeStyle(RuntimeWorkflowNodeDescriptor node) =>
        RuntimeWorkflowGraphFormatting.BuildNodeStyle(
            ResolveNodeLayout(node).X,
            ResolveNodeLayout(node).Y);

    private string GetNodeBadge(RuntimeWorkflowNodeDescriptor node) => node.Kind switch
    {
        RuntimeWorkflowNodeKind.RequestBrief => "brief",
        RuntimeWorkflowNodeKind.OutlinePlan => "outline",
        RuntimeWorkflowNodeKind.LowLevelPlan => "low-level",
        RuntimeWorkflowNodeKind.RuntimePlan => "runtime",
        RuntimeWorkflowNodeKind.Result => "result",
        _ => node.Step?.Kind ?? "step"
    };

    private string GetLinkStroke(RuntimeWorkflowLinkDescriptor link) =>
        string.Equals(link.Id, _selectedElementId, StringComparison.Ordinal)
            ? "#ffd28a"
            : link.Kind == RuntimeWorkflowLinkKind.Stage
                ? "#88d8ff"
                : link.Kind == RuntimeWorkflowLinkKind.Result
                    ? "#8cf1de"
                    : "#94a8d9";

    private string GetLinkDashArray(RuntimeWorkflowLinkDescriptor link) =>
        link.Kind == RuntimeWorkflowLinkKind.Stage
            ? "10 8"
            : string.Empty;

    private string GetLinkWidth(RuntimeWorkflowLinkDescriptor link) =>
        string.Equals(link.Id, _selectedElementId, StringComparison.Ordinal)
            ? "3.75"
            : link.Kind == RuntimeWorkflowLinkKind.Result
                ? "2.9"
                : "2.4";

    private string BuildPath(RuntimeWorkflowLinkDescriptor link)
    {
        var source = ResolveNodeLayout(link.SourceId);
        var target = ResolveNodeLayout(link.TargetId);
        var horizontalFlow = target.X >= source.X + RuntimeWorkflowGraphProjection.NodeWidth * 0.75d;
        if (horizontalFlow)
        {
            var sourceX = source.X + RuntimeWorkflowGraphProjection.NodeWidth;
            var sourceY = source.Y + RuntimeWorkflowGraphProjection.NodeHeight / 2d;
            var targetX = target.X;
            var targetY = target.Y + RuntimeWorkflowGraphProjection.NodeHeight / 2d;
            var controlOffset = Math.Max(56d, (targetX - sourceX) / 2d);
            return RuntimeWorkflowGraphFormatting.BuildHorizontalLinkPath(
                sourceX,
                sourceY,
                targetX,
                targetY,
                controlOffset);
        }

        var verticalStartX = source.X + RuntimeWorkflowGraphProjection.NodeWidth / 2d;
        var verticalStartY = source.Y + RuntimeWorkflowGraphProjection.NodeHeight;
        var verticalEndX = target.X + RuntimeWorkflowGraphProjection.NodeWidth / 2d;
        var verticalEndY = target.Y;
        var verticalControlOffset = Math.Max(44d, (verticalEndY - verticalStartY) / 2d);
        return RuntimeWorkflowGraphFormatting.BuildVerticalLinkPath(
            verticalStartX,
            verticalStartY,
            verticalEndX,
            verticalEndY,
            verticalControlOffset);
    }

    private string GetNodeTitle(string nodeId) =>
        Graph.Nodes.FirstOrDefault(node => string.Equals(node.Id, nodeId, StringComparison.Ordinal))?.Title ?? nodeId;

    private string GetLinkMetaText(RuntimeWorkflowLinkDescriptor link) =>
        link.Kind == RuntimeWorkflowLinkKind.Dependency
            ? $"input: {link.Label} | mode: {(link.Mode ?? "value")}"
            : $"transition: {link.Label}";

    private static string SerializeIndented<T>(T value) =>
        PlanningJson.SerializeIndented(value);

    private static bool TryExtractUserFacingAnswer(JsonElement? data, out string markdown) =>
        PlanningFinalResultPresentation.TryExtractUserFacingAnswer(data, out markdown);

    private static bool ShouldRenderUserFacingAnswerBeforeSummary(RuntimeWorkflowNodeDescriptor node) =>
        node.Kind == RuntimeWorkflowNodeKind.Result
        && PlanningFinalResultPresentation.TryExtractUserFacingAnswer(node.FinalResult?.Data, out _);

    private void PruneNodeLayouts()
    {
        if (!Graph.HasContent)
        {
            _nodeLayouts.Clear();
            _dragNodeId = null;
            return;
        }

        var validNodeIds = Graph.Nodes
            .Select(static node => node.Id)
            .ToHashSet(StringComparer.Ordinal);
        var staleNodeIds = _nodeLayouts.Keys
            .Where(nodeId => !validNodeIds.Contains(nodeId))
            .ToArray();

        foreach (var staleNodeId in staleNodeIds)
        {
            _nodeLayouts.Remove(staleNodeId);
        }

        if (!string.IsNullOrWhiteSpace(_dragNodeId) && !validNodeIds.Contains(_dragNodeId))
        {
            _dragNodeId = null;
        }
    }

    private RuntimeWorkflowNodeLayout ResolveNodeLayout(RuntimeWorkflowNodeDescriptor node) =>
        _nodeLayouts.TryGetValue(node.Id, out var layout)
            ? layout
            : new RuntimeWorkflowNodeLayout(node.X, node.Y);

    private RuntimeWorkflowNodeLayout ResolveNodeLayout(string nodeId)
    {
        if (_nodeLayouts.TryGetValue(nodeId, out var layout))
            return layout;

        var node = Graph.Nodes.First(candidate => string.Equals(candidate.Id, nodeId, StringComparison.Ordinal));
        return new RuntimeWorkflowNodeLayout(node.X, node.Y);
    }

    private bool TryGetNodeLayout(string nodeId, out RuntimeWorkflowNodeLayout layout)
    {
        var node = Graph.Nodes.FirstOrDefault(candidate => string.Equals(candidate.Id, nodeId, StringComparison.Ordinal));
        if (node is null)
        {
            layout = default;
            return false;
        }

        layout = ResolveNodeLayout(node);
        return true;
    }

    private RuntimeWorkflowNodeLayout ClampNodeLayout(double x, double y)
    {
        var maxX = Math.Max(NodeDragMinX, Graph.Width - RuntimeWorkflowGraphProjection.NodeWidth);
        var maxY = Math.Max(NodeDragMinY, Graph.Height - RuntimeWorkflowGraphProjection.NodeHeight);

        return new RuntimeWorkflowNodeLayout(
            Math.Clamp(x, NodeDragMinX, maxX),
            Math.Clamp(y, NodeDragMinY, maxY));
    }

    private PlanningGraphBounds GetCurrentBounds()
    {
        if (!Graph.HasContent)
            return Graph.Bounds;

        var left = double.MaxValue;
        var top = double.MaxValue;
        var right = double.MinValue;
        var bottom = double.MinValue;

        foreach (var node in Graph.Nodes)
        {
            var layout = ResolveNodeLayout(node);
            left = Math.Min(left, layout.X);
            top = Math.Min(top, layout.Y);
            right = Math.Max(right, layout.X + RuntimeWorkflowGraphProjection.NodeWidth);
            bottom = Math.Max(bottom, layout.Y + RuntimeWorkflowGraphProjection.NodeHeight);
        }

        return new PlanningGraphBounds(left, top, right, bottom);
    }

    private sealed class RuntimeWorkflowViewportMetrics
    {
        public double Width { get; init; }

        public double Height { get; init; }
    }

    private readonly record struct RuntimeWorkflowNodeLayout(double X, double Y);
}
