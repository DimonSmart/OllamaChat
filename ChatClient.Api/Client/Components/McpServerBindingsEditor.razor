@using System.Globalization
@using ChatClient.Application.Services
@using ChatClient.Domain.Models
@using ChatClient.Api.Services
@using MudBlazor
@inject IMcpServerConfigService McpServerConfigService
@inject IAppToolCatalog AppToolCatalog
@inject ISnackbar Snackbar

<section class="@BuildEditorClass()">
    <div class="@BuildHeaderClass()">
        @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Description))
        {
            <div class="mcp-bindings-editor__title-block">
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <MudText Typo="Typo.h6">@Title</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        @Description
                    </MudText>
                }
            </div>
        }
        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddBindingAsync"
                   Disabled="@(_loadingServers || _availableServers.Count == 0 || Disabled)">
            MCP
        </MudButton>
    </div>

    @if (_loadingServers)
    {
        <div class="mcp-bindings-editor__loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
        </div>
    }

    @if (!_loadingServers && _availableServers.Count == 0)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined" Class="mt-3">
            No MCP servers are registered yet.
        </MudAlert>
    }

    @if (!_loadingServers &&
         _availableServers.Count > 0 &&
         Bindings.Count == 0 &&
         !string.IsNullOrWhiteSpace(EmptyBindingsText))
    {
        <div class="mcp-bindings-editor__empty mt-3">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                @EmptyBindingsText
            </MudText>
        </div>
    }

    @if (!_loadingServers && _availableServers.Count > 0 && Bindings.Count > 0)
    {
        <MudExpansionPanels MultiExpansion="true" Class="mcp-bindings-editor__panels mt-3">
                @for (var i = 0; i < Bindings.Count; i++)
                {
                    var binding = Bindings[i];
                    var bindingIndex = i;
                    var selectedServer = GetSelectedServer(binding);
                    var toolOptions = GetToolOptions(binding);
                    var isLoadingTools = IsLoadingTools(binding);
                    var toolLoadError = GetToolLoadError(binding);

                    <MudExpansionPanel Text="@GetBindingHeader(binding, selectedServer, bindingIndex)"
                                       Expanded="@IsBindingExpanded(binding)"
                                       ExpandedChanged="@(value => OnBindingExpandedChanged(binding, value))">
                        <div>
                            <div class="mcp-binding-toolbar">
                                <div class="mcp-binding-toolbar__summary">
                                    @{
                                        var bindingStatusSummary = GetBindingStatusSummary(binding, selectedServer, toolOptions.Count);
                                    }
                                    @if (!string.IsNullOrWhiteSpace(bindingStatusSummary))
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            @bindingStatusSummary
                                        </MudText>
                                    }
                                </div>

                                <div class="mcp-binding-toolbar__actions">
                                    @if (Bindings.Count > 1)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                                       Size="Size.Small"
                                                       Disabled="@(Disabled || bindingIndex == 0)"
                                                       OnClick="@(() => MoveBindingAsync(bindingIndex, -1))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                                       Size="Size.Small"
                                                       Disabled="@(Disabled || bindingIndex >= Bindings.Count - 1)"
                                                       OnClick="@(() => MoveBindingAsync(bindingIndex, 1))" />
                                    }

                                    <MudSwitch T="bool"
                                               Value="@binding.Enabled"
                                               ValueChanged="@(value => OnEnabledChangedAsync(binding, value))"
                                               Disabled="@Disabled"
                                               Color="Color.Primary"
                                               Class="mcp-binding-toolbar__toggle">
                                        Enabled
                                    </MudSwitch>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               Disabled="@Disabled"
                                               OnClick="@(() => RemoveBindingAsync(binding))">
                                        Remove
                                    </MudButton>
                                </div>
                            </div>

                            <MudGrid>
                                <MudItem xs="12" md="5">
                                    <MudSelect T="Guid?"
                                               Label="MCP Server"
                                               Value="@binding.ServerId"
                                               ValueChanged="@(value => OnServerChangedAsync(binding, value))"
                                               Dense="true"
                                               Disabled="@Disabled">
                                        @foreach (var server in _availableServers.Where(static server => server.Id.HasValue))
                                        {
                                            <MudSelectItem Value="@server.Id">@server.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="7">
                                    <MudTextField T="string"
                                                  Label="Display name (optional)"
                                                  Value="@binding.DisplayName"
                                                  ValueChanged="@(value => OnDisplayNameChangedAsync(binding, value))"
                                                  Immediate="true"
                                                  Disabled="@Disabled" />
                                </MudItem>
                            </MudGrid>

                            @if (selectedServer is null)
                            {
                                <div class="mcp-binding-section mcp-binding-section--warning">
                                    <MudText Typo="Typo.body2" Color="Color.Warning">
                                        Choose a server from the registry to configure overrides, Roots, and tools.
                                    </MudText>
                                </div>
                            }
                            else
                            {
                                @if (selectedServer.OverrideDefinitions.Count > 0)
                                {
                                    <div class="mcp-binding-section">
                                        <MudText Typo="Typo.subtitle2">Per-Usage Overrides</MudText>
                                        <MudGrid Class="mt-2">
                                            @foreach (var definition in selectedServer.OverrideDefinitions)
                                            {
                                                <MudItem xs="12" md="6">
                                                    @switch (definition.GetNormalizedKind())
                                                    {
                                                        case "int":
                                                            <MudNumericField T="int?"
                                                                             Value="@GetIntOverrideValue(binding, definition.Key)"
                                                                             ValueChanged="@(value => OnIntOverrideChangedAsync(binding, definition.Key, value))"
                                                                             Label="@GetOverrideLabel(definition)"
                                                                             HelperText="@definition.Description"
                                                                             Immediate="true"
                                                                             Dense="true"
                                                                             Disabled="@Disabled" />
                                                            break;
                                                        case "bool":
                                                            <MudSwitch T="bool"
                                                                       Value="@GetBoolOverrideValue(binding, definition.Key)"
                                                                       ValueChanged="@(value => OnBoolOverrideChangedAsync(binding, definition.Key, value))"
                                                                       Disabled="@Disabled"
                                                                       Color="Color.Primary">
                                                                @GetOverrideLabel(definition)
                                                            </MudSwitch>
                                                            @if (!string.IsNullOrWhiteSpace(definition.Description))
                                                            {
                                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@definition.Description</MudText>
                                                            }
                                                            break;
                                                        default:
                                                            <MudTextField T="string"
                                                                          Value="@GetStringOverrideValue(binding, definition.Key)"
                                                                          ValueChanged="@(value => OnStringOverrideChangedAsync(binding, definition.Key, value))"
                                                                          Label="@GetOverrideLabel(definition)"
                                                                          HelperText="@definition.Description"
                                                                          InputType="@(definition.Secret ? InputType.Password : InputType.Text)"
                                                                          Immediate="true"
                                                                          Disabled="@Disabled" />
                                                            break;
                                                    }
                                                </MudItem>
                                            }
                                        </MudGrid>
                                    </div>
                                }

                                @if (binding.Roots.Count == 0)
                                {
                                    <div class="mcp-binding-inline-actions">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.CreateNewFolder"
                                                   OnClick="@(() => AddRootAsync(binding))"
                                                   Disabled="@Disabled">
                                            Add Root
                                        </MudButton>
                                    </div>
                                }
                                else
                                {
                                    <div class="mcp-binding-section">
                                        <div class="mcp-binding-section__header">
                                            <MudText Typo="Typo.subtitle2">Roots</MudText>
                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.CreateNewFolder"
                                                       OnClick="@(() => AddRootAsync(binding))"
                                                       Disabled="@Disabled">
                                                Add Root
                                            </MudButton>
                                        </div>

                                        @for (var rootIndex = 0; rootIndex < binding.Roots.Count; rootIndex++)
                                        {
                                            var currentRootIndex = rootIndex;
                                            <div class="mcp-binding-root-row">
                                                <div class="mcp-binding-root-row__field">
                                                    <MudTextField T="string"
                                                                  Value="@binding.Roots[currentRootIndex]"
                                                                  ValueChanged="@(value => OnRootChangedAsync(binding, currentRootIndex, value))"
                                                                  Label="@($"Root {currentRootIndex + 1}")"
                                                                  Immediate="true"
                                                                  Disabled="@Disabled" />
                                                </div>
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Color="Color.Error"
                                                               Size="Size.Small"
                                                               Disabled="@Disabled"
                                                               OnClick="@(() => RemoveRootAsync(binding, currentRootIndex))" />
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="mcp-binding-section">
                                    <MudText Typo="Typo.subtitle2">Tools</MudText>
                                    <MudSwitch T="bool"
                                               Value="@binding.SelectAllTools"
                                               ValueChanged="@(value => OnSelectAllToolsChangedAsync(binding, value))"
                                               Disabled="@Disabled"
                                               Color="Color.Primary"
                                               Class="mt-2">
                                        @GetToolToggleLabel(binding, toolOptions.Count)
                                    </MudSwitch>

                                    @if (isLoadingTools)
                                    {
                                        <div class="mcp-binding-section__loading">
                                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(toolLoadError))
                                    {
                                        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined" Class="mt-2">
                                            @toolLoadError
                                        </MudAlert>
                                    }
                                    else if (toolOptions.Count == 0)
                                    {
                                        @if (!binding.SelectAllTools)
                                        {
                                            <div class="mcp-binding-section__empty">
                                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                                    No tools were returned for this binding.
                                                </MudText>
                                            </div>
                                        }
                                    }
                                    else if (!binding.SelectAllTools)
                                    {
                                        <div class="mcp-binding-tools">
                                            @foreach (var tool in toolOptions)
                                            {
                                                <div class="mcp-binding-tools__item">
                                                    <MudCheckBox T="bool"
                                                                 Value="@IsToolSelected(binding, tool.ToolName)"
                                                                 ValueChanged="@(value => OnToolSelectionChangedAsync(binding, tool.ToolName, value))"
                                                                 Dense="true"
                                                                 Disabled="@Disabled" />
                                                    <div class="mcp-binding-tools__copy">
                                                        <MudText Typo="Typo.body2">
                                                            <strong>@tool.ToolName</strong>
                                                            @if (!string.Equals(tool.DisplayName, tool.ToolName, StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <span> (@tool.DisplayName)</span>
                                                            }
                                                        </MudText>
                                                        @if (!string.IsNullOrWhiteSpace(tool.Description))
                                                        {
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                                @tool.Description
                                                            </MudText>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </MudExpansionPanel>
                }
        </MudExpansionPanels>
    }
</section>

@code {
    [Parameter] public List<McpServerSessionBinding> Bindings { get; set; } = [];
    [Parameter] public EventCallback<List<McpServerSessionBinding>> BindingsChanged { get; set; }
    [Parameter] public string Title { get; set; } = "MCP Servers";
    [Parameter] public string Description { get; set; } = "Attach MCP servers from the registry and adjust run-specific settings.";
    [Parameter] public string EmptyBindingsText { get; set; } = "No run-specific MCP bindings configured.";
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private readonly Dictionary<Guid, List<AppToolDescriptor>> _toolsByBindingId = new();
    private readonly Dictionary<Guid, string> _toolCacheKeys = new();
    private readonly Dictionary<Guid, string> _toolErrors = new();
    private readonly HashSet<Guid> _loadingToolBindings = [];
    private readonly HashSet<Guid> _expandedBindings = [];
    private List<IMcpServerDescriptor> _availableServers = [];
    private bool _loadingServers;

    protected override async Task OnInitializedAsync()
    {
        await LoadServersAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        var changed = NormalizeBindings();
        if (changed)
        {
            await NotifyChangedAsync();
        }

        await RefreshToolsAsync();
    }

    private async Task LoadServersAsync()
    {
        try
        {
            _loadingServers = true;
            _availableServers = (await McpServerConfigService.GetAllAsync())
                .OrderBy(static server => server.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load MCP servers: {ex.Message}", Severity.Error);
            _availableServers = [];
        }
        finally
        {
            _loadingServers = false;
        }
    }

    private bool NormalizeBindings()
    {
        var changed = false;
        foreach (var binding in Bindings)
        {
            if (binding.BindingId is not Guid bindingId || bindingId == Guid.Empty)
            {
                binding.BindingId = Guid.NewGuid();
                changed = true;
            }

            var trimmedDisplayName = binding.DisplayName?.Trim();
            if (!string.Equals(binding.DisplayName, trimmedDisplayName, StringComparison.Ordinal))
            {
                binding.DisplayName = trimmedDisplayName;
                changed = true;
            }

            var selectedServer = GetSelectedServer(binding);
            if (selectedServer is not null)
            {
                if (binding.ServerId != selectedServer.Id)
                {
                    binding.ServerId = selectedServer.Id;
                    changed = true;
                }

                if (!string.Equals(binding.ServerName, selectedServer.Name, StringComparison.Ordinal))
                {
                    binding.ServerName = selectedServer.Name;
                    changed = true;
                }

                var allowedKeys = selectedServer.OverrideDefinitions
                    .Select(static definition => definition.Key)
                    .Where(static key => !string.IsNullOrWhiteSpace(key))
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);

                foreach (var parameterKey in binding.Parameters.Keys.ToArray())
                {
                    if (allowedKeys.Contains(parameterKey))
                    {
                        continue;
                    }

                    binding.Parameters.Remove(parameterKey);
                    changed = true;
                }
            }

            var normalizedRoots = binding.Roots
                .Select(static root => root?.Trim())
                .Where(static root => !string.IsNullOrWhiteSpace(root))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Cast<string>()
                .ToList();
            if (!binding.Roots.SequenceEqual(normalizedRoots, StringComparer.OrdinalIgnoreCase))
            {
                binding.Roots = normalizedRoots;
                changed = true;
            }

            var normalizedSelectedTools = binding.SelectedTools
                .Select(static toolName => toolName?.Trim())
                .Where(static toolName => !string.IsNullOrWhiteSpace(toolName))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Cast<string>()
                .ToList();
            if (!binding.SelectedTools.SequenceEqual(normalizedSelectedTools, StringComparer.OrdinalIgnoreCase))
            {
                binding.SelectedTools = normalizedSelectedTools;
                changed = true;
            }
        }

        return changed;
    }

    private async Task AddBindingAsync()
    {
        var binding = new McpServerSessionBinding
        {
            BindingId = Guid.NewGuid(),
            Enabled = true,
            SelectAllTools = true
        };

        Bindings.Add(binding);
        if (binding.BindingId is Guid bindingId)
        {
            _expandedBindings.Add(bindingId);
        }
        await NotifyChangedAsync();
    }

    private async Task RemoveBindingAsync(McpServerSessionBinding binding)
    {
        Bindings.Remove(binding);
        if (binding.BindingId is Guid bindingId)
        {
            _toolsByBindingId.Remove(bindingId);
            _toolCacheKeys.Remove(bindingId);
            _toolErrors.Remove(bindingId);
            _loadingToolBindings.Remove(bindingId);
            _expandedBindings.Remove(bindingId);
        }

        await NotifyChangedAsync();
    }

    private async Task MoveBindingAsync(int index, int delta)
    {
        var targetIndex = index + delta;
        if (index < 0 || index >= Bindings.Count || targetIndex < 0 || targetIndex >= Bindings.Count)
        {
            return;
        }

        (Bindings[index], Bindings[targetIndex]) = (Bindings[targetIndex], Bindings[index]);
        await NotifyChangedAsync();
    }

    private bool IsBindingExpanded(McpServerSessionBinding binding)
    {
        return binding.BindingId is Guid bindingId && _expandedBindings.Contains(bindingId);
    }

    private Task OnBindingExpandedChanged(McpServerSessionBinding binding, bool value)
    {
        if (binding.BindingId is not Guid bindingId || bindingId == Guid.Empty)
        {
            return Task.CompletedTask;
        }

        if (value)
        {
            _expandedBindings.Add(bindingId);
        }
        else
        {
            _expandedBindings.Remove(bindingId);
        }

        return Task.CompletedTask;
    }

    private async Task OnServerChangedAsync(McpServerSessionBinding binding, Guid? serverId)
    {
        if (serverId is not Guid resolvedServerId || resolvedServerId == Guid.Empty)
        {
            binding.ServerId = null;
            binding.ServerName = null;
            binding.Parameters.Clear();
            binding.SelectedTools.Clear();
            await NotifyChangedAsync();
            return;
        }

        var selectedServer = _availableServers.FirstOrDefault(server => server.Id == resolvedServerId);
        binding.ServerId = selectedServer?.Id;
        binding.ServerName = selectedServer?.Name;
        binding.Parameters = FilterParameters(binding.Parameters, selectedServer?.OverrideDefinitions);
        binding.SelectedTools.Clear();

        await NotifyChangedAsync();
        await EnsureToolsAsync(binding, forceReload: true);
    }

    private async Task OnDisplayNameChangedAsync(McpServerSessionBinding binding, string? value)
    {
        binding.DisplayName = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        await NotifyChangedAsync();
    }

    private async Task OnEnabledChangedAsync(McpServerSessionBinding binding, bool value)
    {
        binding.Enabled = value;
        await NotifyChangedAsync();
    }

    private async Task OnStringOverrideChangedAsync(McpServerSessionBinding binding, string key, string? value)
    {
        UpdateParameter(binding, key, string.IsNullOrWhiteSpace(value) ? null : value);
        await NotifyChangedAsync();
        await EnsureToolsAsync(binding, forceReload: true);
    }

    private async Task OnIntOverrideChangedAsync(McpServerSessionBinding binding, string key, int? value)
    {
        UpdateParameter(binding, key, value?.ToString(CultureInfo.InvariantCulture));
        await NotifyChangedAsync();
        await EnsureToolsAsync(binding, forceReload: true);
    }

    private async Task OnBoolOverrideChangedAsync(McpServerSessionBinding binding, string key, bool value)
    {
        UpdateParameter(binding, key, value ? "true" : "false");
        await NotifyChangedAsync();
        await EnsureToolsAsync(binding, forceReload: true);
    }

    private async Task AddRootAsync(McpServerSessionBinding binding)
    {
        binding.Roots.Add(string.Empty);
        await NotifyChangedAsync();
    }

    private async Task OnRootChangedAsync(McpServerSessionBinding binding, int index, string? value)
    {
        if (index < 0 || index >= binding.Roots.Count)
        {
            return;
        }

        binding.Roots[index] = value ?? string.Empty;
        await NotifyChangedAsync();
        await EnsureToolsAsync(binding, forceReload: true);
    }

    private async Task RemoveRootAsync(McpServerSessionBinding binding, int index)
    {
        if (index < 0 || index >= binding.Roots.Count)
        {
            return;
        }

        binding.Roots.RemoveAt(index);
        await NotifyChangedAsync();
        await EnsureToolsAsync(binding, forceReload: true);
    }

    private async Task OnSelectAllToolsChangedAsync(McpServerSessionBinding binding, bool value)
    {
        binding.SelectAllTools = value;
        if (value)
        {
            binding.SelectedTools.Clear();
        }

        await NotifyChangedAsync();
    }

    private async Task OnToolSelectionChangedAsync(McpServerSessionBinding binding, string toolName, bool value)
    {
        if (value)
        {
            if (!binding.SelectedTools.Contains(toolName, StringComparer.OrdinalIgnoreCase))
            {
                binding.SelectedTools.Add(toolName);
            }
        }
        else
        {
            binding.SelectedTools.RemoveAll(selectedTool => string.Equals(selectedTool, toolName, StringComparison.OrdinalIgnoreCase));
        }

        await NotifyChangedAsync();
    }

    private async Task RefreshToolsAsync()
    {
        foreach (var binding in Bindings.ToArray())
        {
            await EnsureToolsAsync(binding);
        }
    }

    private async Task EnsureToolsAsync(McpServerSessionBinding binding, bool forceReload = false)
    {
        if (binding.BindingId is not Guid bindingId || bindingId == Guid.Empty)
        {
            return;
        }

        var selectedServer = GetSelectedServer(binding);
        if (selectedServer is null)
        {
            _toolsByBindingId.Remove(bindingId);
            _toolCacheKeys.Remove(bindingId);
            _toolErrors.Remove(bindingId);
            return;
        }

        var cacheKey = BuildToolCacheKey(binding);
        if (!forceReload &&
            _toolCacheKeys.TryGetValue(bindingId, out var existingCacheKey) &&
            string.Equals(existingCacheKey, cacheKey, StringComparison.Ordinal))
        {
            return;
        }

        _loadingToolBindings.Add(bindingId);
        StateHasChanged();

        try
        {
            var requestContext = new McpClientRequestContext([binding.Clone()]);
            var tools = await AppToolCatalog.ListToolsAsync(requestContext);
            var filteredTools = tools
                .Where(tool => MatchesBinding(tool, binding))
                .OrderBy(static tool => tool.ToolName, StringComparer.OrdinalIgnoreCase)
                .ToList();

            _toolsByBindingId[bindingId] = filteredTools;
            _toolCacheKeys[bindingId] = cacheKey;
            _toolErrors.Remove(bindingId);

            if (!binding.SelectAllTools)
            {
                var availableToolNames = filteredTools
                    .Select(static tool => tool.ToolName)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                var pruned = binding.SelectedTools
                    .Where(availableToolNames.Contains)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();
                if (!binding.SelectedTools.SequenceEqual(pruned, StringComparer.OrdinalIgnoreCase))
                {
                    binding.SelectedTools = pruned;
                    await NotifyChangedAsync();
                }
            }
        }
        catch (Exception ex)
        {
            _toolErrors[bindingId] = ex.Message;
            _toolsByBindingId[bindingId] = [];
        }
        finally
        {
            _loadingToolBindings.Remove(bindingId);
            StateHasChanged();
        }
    }

    private IMcpServerDescriptor? GetSelectedServer(McpServerSessionBinding binding)
    {
        if (binding.ServerId is Guid serverId && serverId != Guid.Empty)
        {
            return _availableServers.FirstOrDefault(server => server.Id == serverId);
        }

        return _availableServers.FirstOrDefault(binding.Matches);
    }

    private List<AppToolDescriptor> GetToolOptions(McpServerSessionBinding binding)
    {
        if (binding.BindingId is Guid bindingId &&
            _toolsByBindingId.TryGetValue(bindingId, out var tools))
        {
            return tools;
        }

        return [];
    }

    private bool IsLoadingTools(McpServerSessionBinding binding)
    {
        return binding.BindingId is Guid bindingId && _loadingToolBindings.Contains(bindingId);
    }

    private string? GetToolLoadError(McpServerSessionBinding binding)
    {
        return binding.BindingId is Guid bindingId && _toolErrors.TryGetValue(bindingId, out var error)
            ? error
            : null;
    }

    private string BuildEditorClass()
    {
        return string.IsNullOrWhiteSpace(Class)
            ? "mcp-bindings-editor"
            : $"mcp-bindings-editor {Class}";
    }

    private string BuildHeaderClass()
    {
        return string.IsNullOrWhiteSpace(Title) && string.IsNullOrWhiteSpace(Description)
            ? "mcp-bindings-editor__header mcp-bindings-editor__header--compact"
            : "mcp-bindings-editor__header";
    }

    private static string GetBindingHeader(McpServerSessionBinding binding, IMcpServerDescriptor? server, int index)
    {
        var serverName = server?.Name ?? binding.ServerName ?? $"MCP Server {index + 1}";
        var displayName = string.IsNullOrWhiteSpace(binding.DisplayName) ? null : binding.DisplayName.Trim();

        if (string.IsNullOrWhiteSpace(displayName) ||
            string.Equals(displayName, serverName, StringComparison.OrdinalIgnoreCase))
        {
            return serverName;
        }

        return $"{displayName} ({serverName})";
    }

    private static string GetBindingStatusSummary(
        McpServerSessionBinding binding,
        IMcpServerDescriptor? server,
        int toolCount)
    {
        List<string> parts = [];

        if (!binding.Enabled)
        {
            parts.Add("Disabled");
        }

        if (server is not null)
        {
            var overrideCount = GetConfiguredOverrideCount(binding, server);
            if (overrideCount > 0)
            {
                parts.Add(FormatCount(overrideCount, "override", "overrides"));
            }

            if (binding.Roots.Count > 0)
            {
                parts.Add(FormatCount(binding.Roots.Count, "Root", "Roots"));
            }
        }

        return parts.Count == 0
            ? string.Empty
            : string.Join(" | ", parts);
    }

    private static int GetConfiguredOverrideCount(McpServerSessionBinding binding, IMcpServerDescriptor? server)
    {
        if (server is null || server.OverrideDefinitions.Count == 0 || binding.Parameters.Count == 0)
        {
            return 0;
        }

        var allowedKeys = server.OverrideDefinitions
            .Select(static definition => definition.Key)
            .Where(static key => !string.IsNullOrWhiteSpace(key))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return binding.Parameters.Keys.Count(allowedKeys.Contains);
    }

    private static string GetToolToggleLabel(McpServerSessionBinding binding, int toolCount)
    {
        if (binding.SelectAllTools)
        {
            return "Expose all tools from this binding";
        }

        var selectedCount = binding.SelectedTools.Count;
        if (toolCount > 0)
        {
            return $"Selected tools: {selectedCount} of {toolCount}";
        }

        return selectedCount > 0
            ? $"Selected tools: {selectedCount}"
            : "Selected tools";
    }

    private static string FormatCount(int value, string singular, string plural)
    {
        return value == 1
            ? $"1 {singular}"
            : $"{value} {plural}";
    }


    private static string GetOverrideLabel(McpOverrideDefinition definition)
    {
        var label = string.IsNullOrWhiteSpace(definition.Label) ? definition.Key : definition.Label.Trim();
        return definition.Required ? $"{label} *" : label;
    }

    private static string GetStringOverrideValue(McpServerSessionBinding binding, string key)
    {
        return binding.Parameters.TryGetValue(key, out var value) ? value ?? string.Empty : string.Empty;
    }

    private static int? GetIntOverrideValue(McpServerSessionBinding binding, string key)
    {
        if (!binding.Parameters.TryGetValue(key, out var value) || string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : null;
    }

    private static bool GetBoolOverrideValue(McpServerSessionBinding binding, string key)
    {
        return binding.Parameters.TryGetValue(key, out var value) &&
               bool.TryParse(value, out var parsed) &&
               parsed;
    }

    private static void UpdateParameter(McpServerSessionBinding binding, string key, string? value)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        if (value is null)
        {
            binding.Parameters.Remove(key);
            return;
        }

        binding.Parameters[key] = value;
    }

    private static Dictionary<string, string?> FilterParameters(
        IDictionary<string, string?> parameters,
        IReadOnlyList<McpOverrideDefinition>? definitions)
    {
        if (definitions is null || definitions.Count == 0)
        {
            return new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        }

        var allowedKeys = definitions
            .Select(static definition => definition.Key)
            .Where(static key => !string.IsNullOrWhiteSpace(key))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        Dictionary<string, string?> filtered = new(StringComparer.OrdinalIgnoreCase);
        foreach (var (key, value) in parameters)
        {
            if (allowedKeys.Contains(key))
            {
                filtered[key] = value;
            }
        }

        return filtered;
    }

    private static string BuildToolCacheKey(McpServerSessionBinding binding)
    {
        var parameters = binding.Parameters
            .OrderBy(static pair => pair.Key, StringComparer.OrdinalIgnoreCase)
            .Select(static pair => $"{pair.Key}={pair.Value}")
            .ToArray();
        var roots = binding.Roots
            .OrderBy(static root => root, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return string.Join(
            "|",
            binding.ServerId?.ToString("D") ?? binding.ServerName ?? string.Empty,
            string.Join(";", roots),
            string.Join(";", parameters));
    }

    private static bool MatchesBinding(AppToolDescriptor tool, McpServerSessionBinding binding)
    {
        if (binding.BindingId is Guid bindingId && bindingId != Guid.Empty)
        {
            return tool.BindingId == bindingId;
        }

        if (!string.IsNullOrWhiteSpace(binding.ServerName))
        {
            return string.Equals(tool.BaseServerName, binding.ServerName.Trim(), StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private static bool IsToolSelected(McpServerSessionBinding binding, string toolName)
    {
        return binding.SelectedTools.Contains(toolName, StringComparer.OrdinalIgnoreCase);
    }

    private Task NotifyChangedAsync() =>
        BindingsChanged.InvokeAsync(Bindings);
}

