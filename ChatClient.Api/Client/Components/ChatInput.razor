@using ChatClient.Api.Client.Services
@using ChatClient.Application.Services
@using ChatClient.Domain.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using MudBlazor
@implements IAsyncDisposable
@inject IUserSettingsService UserSettingsService
@inject IVoiceInputService VoiceInputService
@inject IJSRuntime JSRuntime
@inject ILogger<ChatInput> Logger
@inject ISnackbar Snackbar

<MudPaper Class="pa-2" Elevation="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
        <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                       FilesChanged="OnFilesChanged"
                       multiple="true"
                       MaximumFileCount="10"
                       Accept=".pdf,.txt,.doc,.docx,.jpg,.jpeg,.png,.gif,.bmp,.webp">
            <ActivatorContent>
                <MudIconButton Icon="@Icons.Material.Filled.AttachFile"
                               Color="Color.Primary"
                               Size="Size.Small"
                               tooltip="Attach files (max 10)" />
            </ActivatorContent>
        </MudFileUpload>

        <MudTextField T="string"
                      @bind-Value="CurrentText"
                      DebounceInterval="200"
                      Lines="3"
                      MaxLines="15"
                      InputId="@_messageInputId"
                      AutoGrow="true"
                      Label="Type your message"
                      Variant="Variant.Outlined"
                      Style="flex-grow:1"
                      Margin="Margin.Dense"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(ShowStopButton ? Icons.Material.Filled.Stop : Icons.Material.Filled.Send)"
                      AdornmentColor="@(ShowStopButton ? Color.Error : Color.Primary)"
                      OnAdornmentClick="HandleAdornmentClick"
                      OnKeyDown="HandleKeyDown"
                      ShrinkLabel="true"
                      title="@(ShowStopButton ? "Stop generation" : "Send message (Ctrl+Enter)")" />

        @if (CanShowVoiceButton)
        {
            <MudTooltip Text="@VoiceButtonTooltip">
                <MudIconButton Icon="@VoiceButtonIcon"
                               Color="@VoiceButtonColor"
                               Size="Size.Medium"
                               Disabled="@_isVoiceProcessing"
                               OnClick="ToggleVoiceInputAsync"
                               title="@VoiceButtonTooltip" />
            </MudTooltip>
        }
    </MudStack>

    @if (attachedFiles.Count > 0)
    {
        <div class="mt-1">
            <MudText Typo="Typo.caption" Class="mb-1">Attached files (@attachedFiles.Count/10):</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var file in attachedFiles)
                {
                    <MudChip T="string"
                             OnClose="() => RemoveFile(file)"
                             CloseIcon="@Icons.Material.Filled.Clear"
                             Color="Color.Info"
                             Size="Size.Small">
                        <MudIcon Icon="@ChatDisplayHelper.GetFileIcon(file.ContentType)" Class="mr-1" />
                        @file.Name (@ChatDisplayHelper.FormatFileSize(file.Size))
                    </MudChip>
                }
            </MudStack>
        </div>
    }
</MudPaper>

@code {
    [Parameter] public EventCallback<(string text, IReadOnlyList<AppChatMessageFile> files)> OnSend { get; set; }
    [Parameter] public bool ShowStopButton { get; set; } = false;
    [Parameter] public EventCallback OnStopClick { get; set; }
    [Parameter] public bool IsMultiAgent { get; set; } = false;

    private readonly string _messageInputId = $"chat-input-{Guid.NewGuid():N}";
    private VoiceInputSettings _voiceInputSettings = new();
    private string CurrentText { get; set; } = string.Empty;
    private List<AppChatMessageFile> attachedFiles = [];
    private bool _isVoiceRecording;
    private bool _isVoiceProcessing;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        var settings = await UserSettingsService.GetSettingsAsync();
        var defaultMessage = IsMultiAgent ? settings.DefaultMultiAgentChatMessage : settings.DefaultChatMessage;
        _voiceInputSettings = await VoiceInputService.GetSettingsAsync();

        if (!string.IsNullOrEmpty(defaultMessage))
        {
            CurrentText = defaultMessage;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("voiceInputInterop.registerInput", _messageInputId);
    }

    private bool IsSending { get; set; }
    private bool IsTextEntered => !string.IsNullOrWhiteSpace(CurrentText);
    private bool IsSendDisabled => IsSending || !IsTextEntered;
    private bool CanShowVoiceButton =>
        _voiceInputSettings.IsEnabled &&
        _voiceInputSettings.Status == VoiceInputInitializationStatus.Ready;
    private string VoiceButtonIcon =>
        _isVoiceRecording
            ? Icons.Material.Filled.StopCircle
            : _isVoiceProcessing
                ? Icons.Material.Filled.HourglassTop
                : Icons.Material.Filled.Mic;
    private Color VoiceButtonColor => _isVoiceRecording ? Color.Error : Color.Primary;
    private string VoiceButtonTooltip =>
        _isVoiceRecording
            ? "Stop voice input"
            : _isVoiceProcessing
                ? "Recognizing speech..."
                : "Start voice input";

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey && !IsSendDisabled)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (IsSendDisabled)
        {
            return;
        }

        try
        {
            IsSending = true;
            var textToSend = CurrentText.Trim();
            var filesToSend = attachedFiles.ToList();

            CurrentText = string.Empty;
            attachedFiles.Clear();
            await OnSend.InvokeAsync((textToSend, filesToSend));
        }
        finally
        {
            IsSending = false;
        }
    }

    private async Task OnFilesChanged(IReadOnlyList<IBrowserFile> files)
    {
        const int maxFileSize = 10 * 1024 * 1024;
        const int maxFiles = 10;

        if (attachedFiles.Count + files.Count > maxFiles)
        {
            return;
        }

        foreach (var file in files)
        {
            if (file.Size > maxFileSize)
            {
                Snackbar?.Add($"File '{file.Name}' is too large (max {maxFileSize / (1024 * 1024)}MB)", Severity.Warning);
                continue;
            }

            try
            {
                using var stream = file.OpenReadStream(maxFileSize);
                var buffer = new byte[file.Size];
                await stream.ReadExactlyAsync(buffer);

                var chatFile = new AppChatMessageFile(file.Name, file.Size, file.ContentType, buffer);
                attachedFiles.Add(chatFile);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to read file: {FileName}", file.Name);
            }
        }

        StateHasChanged();
    }

    private void RemoveFile(AppChatMessageFile file)
    {
        attachedFiles.Remove(file);
        StateHasChanged();
    }

    private async Task HandleAdornmentClick()
    {
        if (ShowStopButton)
        {
            await OnStopClick.InvokeAsync();
            return;
        }

        await SendMessage();
    }

    private async Task ToggleVoiceInputAsync()
    {
        if (_isVoiceProcessing)
        {
            return;
        }

        if (_isVoiceRecording)
        {
            await StopVoiceInputAsync();
            return;
        }

        await StartVoiceInputAsync();
    }

    private async Task StartVoiceInputAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("voiceInputInterop.startRecording", _messageInputId);
            _isVoiceRecording = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to start voice input.");
            Snackbar.Add(GetVoiceErrorMessage(ex, "Failed to start voice input."), Severity.Warning);
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task StopVoiceInputAsync()
    {
        _isVoiceRecording = false;
        _isVoiceProcessing = true;
        StateHasChanged();

        try
        {
            var recognizedText = await JSRuntime.InvokeAsync<string>(
                "voiceInputInterop.stopRecording",
                _messageInputId,
                "/api/voice-input/transcribe");

            if (string.IsNullOrWhiteSpace(recognizedText))
            {
                Snackbar.Add("No speech recognized.", Severity.Info);
                return;
            }

            var insertion = await JSRuntime.InvokeAsync<VoiceInputInsertionResult?>(
                "voiceInputInterop.insertTextAtSavedSelection",
                _messageInputId,
                recognizedText);

            CurrentText = insertion?.Value ?? recognizedText;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Voice input failed.");
            Snackbar.Add(GetVoiceErrorMessage(ex, "Voice input failed."), Severity.Warning);
        }
        finally
        {
            _isVoiceProcessing = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("voiceInputInterop.dispose", _messageInputId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private static string GetVoiceErrorMessage(Exception exception, string fallbackMessage)
    {
        var message = exception is JSException jsException
            ? jsException.Message
            : exception.Message;

        return string.IsNullOrWhiteSpace(message)
            ? fallbackMessage
            : message;
    }

    private sealed class VoiceInputInsertionResult
    {
        public string Value { get; set; } = string.Empty;
    }
}
