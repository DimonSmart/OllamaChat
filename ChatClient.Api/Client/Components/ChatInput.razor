@using ChatClient.Api.Client.Services
@using ChatClient.Api.VoiceInput
@using ChatClient.Application.Services
@using ChatClient.Domain.Models
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Microsoft.Extensions.Options
@using MudBlazor
@implements IAsyncDisposable
@inject IUserSettingsService UserSettingsService
@inject IVoiceInputService VoiceInputService
@inject IJSRuntime JSRuntime
@inject IOptions<VoiceInputOptions> VoiceInputOptionsAccessor
@inject ILogger<ChatInput> Logger
@inject ISnackbar Snackbar

<MudPaper Class="pa-2" Elevation="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
        @if (AllowFileAttachments)
        {
            <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                           FilesChanged="OnFilesChanged"
                           multiple="true"
                           MaximumFileCount="10"
                           Accept=".pdf,.txt,.doc,.docx,.jpg,.jpeg,.png,.gif,.bmp,.webp">
                <ActivatorContent>
                    <MudIconButton Icon="@Icons.Material.Filled.AttachFile"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   tooltip="Attach files (max 10)" />
                </ActivatorContent>
            </MudFileUpload>
        }

        <MudTextField T="string"
                      Disabled="Disabled"
                      Value="CurrentText"
                      ValueChanged="OnCurrentTextChanged"
                      DebounceInterval="200"
                      Lines="3"
                      MaxLines="15"
                      InputId="@_messageInputId"
                      AutoGrow="true"
                      Label="@Label"
                      Variant="Variant.Outlined"
                      Style="flex-grow:1"
                      Margin="Margin.Dense"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(ShowStopButton ? Icons.Material.Filled.Stop : Icons.Material.Filled.Send)"
                      AdornmentColor="@(ShowStopButton ? Color.Error : Color.Primary)"
                      OnAdornmentClick="HandleAdornmentClick"
                      OnKeyDown="HandleKeyDown"
                      ShrinkLabel="true"
                      title="@(ShowStopButton ? "Stop generation" : "Send message (Ctrl+Enter)")" />

        @if (CanShowVoiceButton)
        {
            <div class="@VoiceInputControlCssClass">
                <MudTooltip Text="@VoiceButtonTooltip">
                    <MudIconButton Icon="@VoiceButtonIcon"
                                   Color="@VoiceButtonColor"
                                   Size="Size.Medium"
                                   Class="@VoiceButtonCssClass"
                                   Disabled="@_isVoiceProcessing"
                                   OnClick="ToggleVoiceInputAsync"
                                   aria-label="@VoiceButtonTooltip"
                                   title="@VoiceButtonTooltip" />
                </MudTooltip>

                @if (_isVoiceRecording)
                {
                    <div class="voice-input-meter" aria-hidden="true">
                        <span class="voice-input-bar" style="@GetVoiceBarStyle(0.65, 0.08)"></span>
                        <span class="voice-input-bar" style="@GetVoiceBarStyle(1.00, 0.14)"></span>
                        <span class="voice-input-bar" style="@GetVoiceBarStyle(0.82, 0.10)"></span>
                    </div>
                }

                @if (_isVoiceProcessing)
                {
                    <div class="voice-input-processing-indicator" aria-hidden="true">
                        <MudProgressCircular Indeterminate="true"
                                             Color="Color.Primary"
                                             Size="Size.Medium"
                                             Class="voice-input-spinner" />
                    </div>
                }
            </div>
        }
    </MudStack>

    @if (attachedFiles.Count > 0)
    {
        <div class="mt-1">
            <MudText Typo="Typo.caption" Class="mb-1">Attached files (@attachedFiles.Count/10):</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var file in attachedFiles)
                {
                    <MudChip T="string"
                             OnClose="() => RemoveFile(file)"
                             CloseIcon="@Icons.Material.Filled.Clear"
                             Color="Color.Info"
                             Size="Size.Small">
                        <MudIcon Icon="@ChatDisplayHelper.GetFileIcon(file.ContentType)" Class="mr-1" />
                        @file.Name (@ChatDisplayHelper.FormatFileSize(file.Size))
                    </MudChip>
                }
            </MudStack>
        </div>
    }
</MudPaper>

@code {
    [Parameter] public EventCallback<(string text, IReadOnlyList<AppChatMessageFile> files)> OnSend { get; set; }
    [Parameter] public bool ShowStopButton { get; set; } = false;
    [Parameter] public EventCallback OnStopClick { get; set; }
    [Parameter] public bool IsMultiAgent { get; set; } = false;
    [Parameter] public bool AllowFileAttachments { get; set; } = true;
    [Parameter] public string Label { get; set; } = "Type your message";
    [Parameter] public string? Text { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<string> TextChanged { get; set; }

    private readonly string _messageInputId = $"chat-input-{Guid.NewGuid():N}";
    private VoiceInputSettings _voiceInputSettings = new();
    private DotNetObjectReference<ChatInput>? _selfReference;
    private string CurrentText { get; set; } = string.Empty;
    private List<AppChatMessageFile> attachedFiles = [];
    private bool _isVoiceRecording;
    private bool _isVoiceProcessing;
    private double _voiceLevel;
    private string? _activeVoiceOperationId;
    private CancellationTokenSource? _voiceRecognitionTimeoutCancellation;
    private TimeSpan VoiceInputInteropTimeout =>
        TimeSpan.FromSeconds(Math.Max(30, VoiceInputOptionsAccessor.Value.InteropCallTimeoutSeconds));

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        var settings = await UserSettingsService.GetSettingsAsync();
        var defaultMessage = IsMultiAgent ? settings.DefaultMultiAgentChatMessage : settings.DefaultChatMessage;
        _voiceInputSettings = await VoiceInputService.GetSettingsAsync();

        if (!string.IsNullOrEmpty(defaultMessage))
        {
            CurrentText = defaultMessage;
        }
    }

    protected override Task OnParametersSetAsync()
    {
        if (Text is not null && !string.Equals(CurrentText, Text, StringComparison.Ordinal))
        {
            CurrentText = Text;
        }

        return base.OnParametersSetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _selfReference ??= DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("voiceInputInterop.registerInput", _messageInputId, _selfReference);
    }

    private bool IsSending { get; set; }
    private bool IsTextEntered => !string.IsNullOrWhiteSpace(CurrentText);
    private bool IsSendDisabled => Disabled || IsSending || !IsTextEntered;
    private bool CanShowVoiceButton =>
        _voiceInputSettings.IsEnabled &&
        _voiceInputSettings.Status == VoiceInputInitializationStatus.Ready;
    private string VoiceButtonIcon =>
        _isVoiceRecording
            ? Icons.Material.Filled.StopCircle
            : _isVoiceProcessing
                ? Icons.Material.Filled.HourglassTop
                : Icons.Material.Filled.Mic;
    private Color VoiceButtonColor => _isVoiceRecording ? Color.Error : Color.Primary;
    private string VoiceButtonTooltip =>
        _isVoiceRecording
            ? "Stop voice input"
            : _isVoiceProcessing
                ? "Recognizing speech..."
                : "Start voice input";
    private string VoiceInputControlCssClass =>
        _isVoiceRecording
            ? "voice-input-control is-recording"
            : _isVoiceProcessing
                ? "voice-input-control is-processing"
                : "voice-input-control";
    private string VoiceButtonCssClass =>
        _isVoiceRecording
            ? "voice-input-button is-recording"
            : _isVoiceProcessing
                ? "voice-input-button is-processing"
                : "voice-input-button";

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey && !IsSendDisabled)
        {
            await SendMessage();
        }
    }

    private async Task OnCurrentTextChanged(string value)
    {
        CurrentText = value;

        if (TextChanged.HasDelegate)
        {
            await TextChanged.InvokeAsync(value);
        }
    }

    private async Task SendMessage()
    {
        if (IsSendDisabled)
        {
            return;
        }

        try
        {
            IsSending = true;
            var textToSend = CurrentText.Trim();
            var filesToSend = attachedFiles.ToList();

            CurrentText = string.Empty;
            if (TextChanged.HasDelegate)
            {
                await TextChanged.InvokeAsync(CurrentText);
            }

            attachedFiles.Clear();
            await OnSend.InvokeAsync((textToSend, filesToSend));
        }
        finally
        {
            IsSending = false;
        }
    }

    private async Task OnFilesChanged(IReadOnlyList<IBrowserFile> files)
    {
        const int maxFileSize = 10 * 1024 * 1024;
        const int maxFiles = 10;

        if (attachedFiles.Count + files.Count > maxFiles)
        {
            return;
        }

        foreach (var file in files)
        {
            if (file.Size > maxFileSize)
            {
                Snackbar?.Add($"File '{file.Name}' is too large (max {maxFileSize / (1024 * 1024)}MB)", Severity.Warning);
                continue;
            }

            try
            {
                using var stream = file.OpenReadStream(maxFileSize);
                var buffer = new byte[file.Size];
                await stream.ReadExactlyAsync(buffer);

                var chatFile = new AppChatMessageFile(file.Name, file.Size, file.ContentType, buffer);
                attachedFiles.Add(chatFile);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to read file: {FileName}", file.Name);
            }
        }

        StateHasChanged();
    }

    private void RemoveFile(AppChatMessageFile file)
    {
        attachedFiles.Remove(file);
        StateHasChanged();
    }

    private async Task HandleAdornmentClick()
    {
        if (ShowStopButton)
        {
            await OnStopClick.InvokeAsync();
            return;
        }

        await SendMessage();
    }

    private async Task ToggleVoiceInputAsync()
    {
        if (_isVoiceProcessing)
        {
            return;
        }

        if (_isVoiceRecording)
        {
            await StopVoiceInputAsync();
            return;
        }

        await StartVoiceInputAsync();
    }

    private async Task StartVoiceInputAsync()
    {
        try
        {
            _voiceLevel = 0;
            await JSRuntime.InvokeVoidAsync("voiceInputInterop.startRecording", _messageInputId);
            _isVoiceRecording = true;
        }
        catch (Exception ex)
        {
            _voiceLevel = 0;
            Logger.LogWarning(ex, "Failed to start voice input.");
            Snackbar.Add(GetVoiceErrorMessage(ex, "Failed to start voice input."), Severity.Warning);
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task StopVoiceInputAsync()
    {
        _isVoiceRecording = false;
        _isVoiceProcessing = true;
        _voiceLevel = 0;
        var operationId = Guid.NewGuid().ToString("N");
        BeginVoiceInputProcessing(operationId);

        try
        {
            await JSRuntime.InvokeVoidAsync(
                "voiceInputInterop.stopRecording",
                _messageInputId,
                "/api/voice-input/transcribe",
                operationId);
        }
        catch (Exception ex)
        {
            await CompleteVoiceInputFailureAsync(operationId, GetVoiceErrorMessage(ex, "Voice input failed."));
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task UpdateVoiceLevel(double level)
    {
        var normalizedLevel = Math.Clamp(level, 0d, 1d);
        if (Math.Abs(_voiceLevel - normalizedLevel) < 0.01d)
        {
            return Task.CompletedTask;
        }

        _voiceLevel = normalizedLevel;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task CompleteVoiceInputTranscription(string operationId, string? recognizedText, string? errorMessage) =>
        InvokeAsync(() => CompleteVoiceInputTranscriptionCoreAsync(operationId, recognizedText, errorMessage));

    public async ValueTask DisposeAsync()
    {
        CancelVoiceInputMonitoring();

        try
        {
            await JSRuntime.InvokeVoidAsync("voiceInputInterop.dispose", _messageInputId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }

        _selfReference?.Dispose();
    }

    private static string GetVoiceErrorMessage(Exception exception, string fallbackMessage)
    {
        var message = exception is JSException jsException
            ? jsException.Message
            : exception.Message;

        return string.IsNullOrWhiteSpace(message)
            ? fallbackMessage
            : message;
    }

    private string GetVoiceBarStyle(double multiplier, double baseline)
    {
        var level = Math.Clamp((_voiceLevel * multiplier) + baseline, 0.12d, 1d);
        var height = 6 + (int)Math.Round(level * 16);
        var opacity = 0.35d + (level * 0.65d);
        return string.Create(
            CultureInfo.InvariantCulture,
            $"height:{height}px;opacity:{opacity:0.##};");
    }

    private void BeginVoiceInputProcessing(string operationId)
    {
        CancelVoiceInputMonitoring();

        _activeVoiceOperationId = operationId;
        _voiceRecognitionTimeoutCancellation = new CancellationTokenSource();
        _ = MonitorVoiceInputTimeoutAsync(operationId, _voiceRecognitionTimeoutCancellation.Token);
    }

    private async Task MonitorVoiceInputTimeoutAsync(string operationId, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(VoiceInputInteropTimeout, cancellationToken);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        await InvokeAsync(() => CompleteVoiceInputTimeoutAsync(operationId));
    }

    private async Task CompleteVoiceInputTranscriptionCoreAsync(
        string operationId,
        string? recognizedText,
        string? errorMessage)
    {
        if (!BeginVoiceInputCompletion(operationId))
        {
            return;
        }

        await AwaitVoiceInputMonitoringAsync();

        if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            Logger.LogWarning("Voice input failed: {Message}", errorMessage);
            Snackbar.Add(errorMessage, Severity.Warning);
            await ResetVoiceInputProcessingStateAsync();
            return;
        }

        if (string.IsNullOrWhiteSpace(recognizedText))
        {
            Snackbar.Add("No speech recognized.", Severity.Info);
            await ResetVoiceInputProcessingStateAsync();
            return;
        }

        try
        {
            var insertion = await JSRuntime.InvokeAsync<VoiceInputInsertionResult?>(
                "voiceInputInterop.insertTextAtSavedSelection",
                _messageInputId,
                recognizedText);

            CurrentText = insertion?.Value ?? recognizedText;
            if (TextChanged.HasDelegate)
            {
                await TextChanged.InvokeAsync(CurrentText);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to insert recognized text into the input.");
            CurrentText += recognizedText;
            if (TextChanged.HasDelegate)
            {
                await TextChanged.InvokeAsync(CurrentText);
            }
        }

        await ResetVoiceInputProcessingStateAsync();
    }

    private async Task CompleteVoiceInputFailureAsync(string operationId, string message)
    {
        if (!BeginVoiceInputCompletion(operationId))
        {
            return;
        }

        await AwaitVoiceInputMonitoringAsync();
        Logger.LogWarning("Voice input failed before transcription completed: {Message}", message);
        Snackbar.Add(message, Severity.Warning);
        await ResetVoiceInputProcessingStateAsync();
    }

    private async Task CompleteVoiceInputTimeoutAsync(string operationId)
    {
        if (!BeginVoiceInputCompletion(operationId))
        {
            return;
        }

        await AwaitVoiceInputMonitoringAsync();
        Logger.LogWarning("Voice input timed out after {TimeoutSeconds} seconds.", (int)VoiceInputInteropTimeout.TotalSeconds);
        Snackbar.Add(
            $"Voice recognition timed out after {(int)VoiceInputInteropTimeout.TotalSeconds} seconds. Try a smaller Whisper model or increase the timeout.",
            Severity.Warning);
        await ResetVoiceInputProcessingStateAsync();
    }

    private bool BeginVoiceInputCompletion(string operationId)
    {
        if (!string.Equals(_activeVoiceOperationId, operationId, StringComparison.Ordinal))
        {
            return false;
        }

        _activeVoiceOperationId = null;
        CancelVoiceInputMonitoring();
        return true;
    }

    private void CancelVoiceInputMonitoring()
    {
        _voiceRecognitionTimeoutCancellation?.Cancel();
    }

    private async Task AwaitVoiceInputMonitoringAsync()
    {
        _voiceRecognitionTimeoutCancellation?.Dispose();
        _voiceRecognitionTimeoutCancellation = null;
    }

    private async Task ResetVoiceInputProcessingStateAsync()
    {
        _isVoiceProcessing = false;
        _voiceLevel = 0;
        await InvokeAsync(StateHasChanged);
    }

    private sealed class VoiceInputInsertionResult
    {
        public string Value { get; set; } = string.Empty;
    }
}
